---
import Base from '../../layouts/Base.astro';

const B = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const villages = [
  {
    slug: 'kawakami',
    name: '川上村',
    prefecture: '長野県',
    tagline: 'レタスと、宇宙と、千曲川源流。',
    status: '公開中',
    accent: '#4ea83a',
    heroBg: 'linear-gradient(155deg, #6e8c4f 0%, #2f5d3d 50%, #163810 100%)',
  },
  // 次の自治体はここに追加
  // { slug: 'xxx', name: '◯◯村', prefecture: '◯◯県', tagline: '...', status: '準備中', accent: '#xxx', heroBg: '...' },
];

// プレースホルダー（横展開イメージ用、空きカード）
const placeholderCount = Math.max(0, 8 - villages.length);
---

<Base title="自治体LP一覧 — 地域おこし協力隊DAO">
  <main class="index">
    <header class="header">
      <p class="eyebrow">Municipality Landing Pages</p>
      <h1>自治体LP<span>一覧</span></h1>
      <p class="lead">各自治体に特化した地域おこし協力隊DAOのランディングページ。</p>
    </header>

    <ul class="grid">
      {villages.map((v) => (
        <li class="card" style={`--accent: ${v.accent}; --hero: ${v.heroBg};`}>
          <a href={`${B}municipalities/${v.slug}`}>
            <div class="thumb"></div>
            <div class="body">
              <p class="pref">{v.prefecture}</p>
              <h2>{v.name}</h2>
              <p class="tagline">{v.tagline}</p>
              <span class="status">{v.status}</span>
            </div>
          </a>
        </li>
      ))}
      {Array.from({ length: placeholderCount }).map(() => (
        <li class="card card-placeholder">
          <div class="thumb thumb-placeholder"></div>
          <div class="body">
            <p class="pref">準備中</p>
            <h2>—</h2>
            <p class="tagline">次の自治体はここに追加されます。</p>
            <span class="status status-pending">Coming soon</span>
          </div>
        </li>
      ))}
    </ul>

    <p class="back"><a href="/">← デザインたたき台一覧へ</a></p>
  </main>
</Base>

<style>
  .index {
    min-height: 100vh;
    background: #fafaf8;
    padding: 64px 28px 80px;
    font-family: 'Noto Sans JP', sans-serif;
    color: #1a1a1a;
    max-width: 1280px;
    margin: 0 auto;
  }
  .header { margin-bottom: 44px; }
  .eyebrow { font-family: 'Inter', sans-serif; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: #999; margin-bottom: 14px; }
  h1 { font-family: 'Noto Serif JP', serif; font-size: clamp(1.8rem, 4.4vw, 2.6rem); font-weight: 700; line-height: 1.3; margin-bottom: 10px; }
  h1 span { font-weight: 300; color: #888; margin-left: 10px; font-size: 0.7em; }
  .lead { color: #666; font-size: 0.88rem; line-height: 1.85; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    list-style: none;
  }
  .card {
    background: #fff;
    border: 1px solid #e8e8e4;
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }
  .card:not(.card-placeholder):hover {
    transform: translateY(-3px);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.08);
  }
  .card a { display: block; color: inherit; }
  .thumb {
    aspect-ratio: 16 / 10;
    background: var(--hero);
  }
  .thumb-placeholder {
    background: repeating-linear-gradient(45deg, #f3f3ef 0 10px, #fafaf8 10px 20px);
  }
  .body { padding: 16px 18px 18px; }
  .pref {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    color: var(--accent, #999);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 6px;
    font-weight: 600;
  }
  .card h2 {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .tagline {
    font-size: 0.78rem;
    color: #666;
    line-height: 1.65;
    margin-bottom: 12px;
    min-height: 2.6em;
  }
  .status {
    display: inline-block;
    font-size: 0.65rem;
    padding: 3px 10px;
    border: 1px solid var(--accent, #ccc);
    color: var(--accent, #999);
    border-radius: 100px;
    letter-spacing: 0.05em;
  }
  .card-placeholder { opacity: 0.5; pointer-events: none; }
  .card-placeholder .pref { color: #aaa; }
  .card-placeholder h2 { color: #ccc; }
  .status-pending { border-color: #ddd; color: #aaa; }

  .back {
    margin-top: 56px;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: #999;
  }
  .back a { color: inherit; transition: color 0.3s; }
  .back a:hover { color: #1a1a1a; }

  @media (max-width: 600px) {
    .index { padding: 40px 18px 60px; }
    .grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; }
    .body { padding: 14px 14px 16px; }
    .card h2 { font-size: 1rem; }
    .tagline { font-size: 0.74rem; min-height: 0; -webkit-line-clamp: 2; display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden; }
  }
</style>
