---
import Base from '../../layouts/Base.astro';

const villages = [
  {
    slug: 'kawakami',
    name: '川上村',
    prefecture: '長野県',
    tagline: 'レタスと星と、千曲川の源流。',
    status: '公開中',
    accent: '#2f5d3d',
    heroBg: 'linear-gradient(155deg, #4a6d4e 0%, #2f4a38 50%, #1a2820 100%)',
  },
  // 次の自治体はここに追加していく
  // { slug: '...', name: '...', prefecture: '...', status: '準備中', ... }
];
---

<Base title="自治体LP一覧 — 地域おこし協力隊DAO">
  <main class="index">
    <header>
      <p class="eyebrow">Municipality Landing Pages</p>
      <h1>自治体LP<span>一覧</span></h1>
      <p class="lead">各自治体に特化した地域おこし協力隊DAOのランディングページ。</p>
    </header>

    <ul class="grid">
      {villages.map((v) => (
        <li class="card" style={`--accent: ${v.accent}; --hero: ${v.heroBg};`}>
          <a href={`/municipalities/${v.slug}`}>
            <div class="thumb"></div>
            <div class="body">
              <p class="pref">{v.prefecture}</p>
              <h2>{v.name}</h2>
              <p class="tagline">{v.tagline}</p>
              <span class="status">{v.status}</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    <p class="back"><a href="/">← デザイン案一覧に戻る</a></p>
  </main>
</Base>

<style>
  .index {
    min-height: 100vh;
    background: #fafaf8;
    padding: 80px 40px;
    font-family: 'Noto Sans JP', sans-serif;
    color: #1a1a1a;
    max-width: 1200px;
    margin: 0 auto;
  }
  .eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999;
    margin-bottom: 16px;
  }
  h1 {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 12px;
  }
  h1 span {
    font-weight: 300;
    color: #888;
    margin-left: 12px;
  }
  .lead {
    color: #666;
    font-size: 0.95rem;
    margin-bottom: 64px;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
    list-style: none;
  }
  .card {
    background: #fff;
    border: 1px solid #e8e8e4;
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.1);
  }
  .card a { display: block; color: inherit; }
  .thumb {
    aspect-ratio: 16 / 9;
    background: var(--hero);
  }
  .body { padding: 28px 32px 32px; }
  .pref {
    font-family: 'Inter', sans-serif;
    font-size: 0.7rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  h2 {
    font-family: 'Noto Serif JP', serif;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .tagline {
    font-size: 0.9rem;
    color: #666;
    line-height: 1.8;
    margin-bottom: 20px;
  }
  .status {
    display: inline-block;
    font-size: 0.7rem;
    padding: 4px 12px;
    border: 1px solid var(--accent);
    color: var(--accent);
    border-radius: 100px;
    letter-spacing: 0.05em;
  }
  .back {
    margin-top: 80px;
    text-align: center;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #999;
  }
  .back a { color: inherit; transition: color 0.3s; }
  .back a:hover { color: #1a1a1a; }

  @media (max-width: 600px) {
    .index { padding: 48px 20px; }
    .grid { grid-template-columns: 1fr; gap: 20px; }
  }
</style>
