---
import Base from '../../../layouts/Base.astro';
import { community, numbers, features, news, images, gallery, profile, organization } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (エディトリアル案) — ${community.prefecture}${community.village}`}>
  <div class="editorial">
    <nav class="nav">
      <span class="nav-left">{community.name}</span>
      <span class="nav-center">Magazine Style</span>
      <a href={community.lineUrl} class="nav-right">Join →</a>
    </nav>

    <section class="hero">
      <div class="hero-col-left">
        <div class="hero-meta"><span>Issue 01</span><span>2026 —</span></div>
        <h1>川上村を、<br /><em>編集</em>する。</h1>
      </div>
      <div class="hero-col-right">
        <div class="hero-photo" style={`background-image: url('${images.hero}');`}></div>
        <p class="hero-caption">{community.name} — {community.prefecture}{community.village}DAOコミュニティ。運営: {community.operator}。</p>
      </div>
    </section>

    <div class="marquee">
      <div class="marquee-track">
        <span>LETTUCE</span><span>×</span><span>COSMOS</span><span>×</span><span>DAO</span><span>×</span><span>関係人口</span><span>×</span><span>{community.villageEn}</span><span>×</span>
        <span>LETTUCE</span><span>×</span><span>COSMOS</span><span>×</span><span>DAO</span><span>×</span><span>関係人口</span><span>×</span><span>{community.villageEn}</span><span>×</span>
      </div>
    </div>

    <section class="story">
      <div class="story-header"><span class="story-label">Feature Story</span><span class="story-num">01</span></div>
      <div class="story-grid">
        <div><h2>レタス生産量、<br />日本一の村に、<br />101人目の<em>仲間</em>を。</h2></div>
        <div class="story-body">
          <p class="story-lead">{community.lead}</p>
          <p>2025年1月に開設したLINEオープンチャットは、最短記録で100名を突破。村内議員・村外大学生・参加者が、自主的に認知活動を展開しています。</p>
          <p>住んでいなくても関われる。オンラインで繋がり、リアルで会う。あなたのペースで川上村と関係を結べる場所、それが「{community.name}」です。</p>
        </div>
      </div>
    </section>

    <section class="columns">
      {features.slice(0, 3).map((f, i) => (
        <div class="column">
          <div class="column-img" style={`background-image: url('${f.image || images.event1}');`}></div>
          <span class="column-tag">No. {String(i + 1).padStart(2, '0')}</span>
          <h3 set:html={f.title.replace('る', 'る<br />')}></h3>
          <p>{f.body}</p>
        </div>
      ))}
    </section>

    <section class="pull-quote" style={`background-image: linear-gradient(rgba(26,26,26,0.7), rgba(26,26,26,0.7)), url('${images.cosmos}');`}>
      <div class="pull-quote-inner">
        <div class="pull-quote-mark">"</div>
        <blockquote>標高1,100m、<br />日本でいちばん宇宙に近い村。</blockquote>
        <div class="pull-quote-line"></div>
      </div>
    </section>

    <section class="news">
      <div class="story-header"><span class="story-label">News &amp; Press</span><span class="story-num">02</span></div>
      <ul class="news-list">
        {news.map((n) => (
          <li>
            <a href={n.href}>
              {n.image && <div class="news-img" style={`background-image: url('${n.image}');`}></div>}
              <div class="news-meta"><time>{n.date}</time><span class={`news-tag news-tag-${n.tag}`}>{n.tagLabel}</span></div>
              <h3>{n.title}</h3>
              <p>{n.excerpt}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="large-type">
      <div class="large-type-inner">
        <span class="large-type-label">By the Numbers</span>
        <div class="numbers-grid">
          {numbers.map((n) => (
            <div><strong>{n.value}{n.unit}</strong><span>{n.label}</span></div>
          ))}
        </div>
      </div>
    </section>

    <section class="organizers">
      <div class="story-header"><span class="story-label">Organizers</span><span class="story-num">03</span></div>
      <div class="org-grid">
        <article class="org-card">
          <div class="org-photo" style={`background-image: url('${profile.photo}');`}></div>
          <span class="column-tag">Person</span>
          <h3>{profile.handle}</h3>
          <p class="org-role">{profile.role}</p>
          <p>{profile.bio}</p>
        </article>
        <article class="org-card">
          <div class="org-mark"><span class="org-initial">A</span><span class="org-en">{organization.nameEn}</span></div>
          <span class="column-tag">Company</span>
          <h3>{organization.name}</h3>
          <p class="org-role">{organization.role}</p>
          <p>{organization.bio}</p>
          <a href={organization.url} target="_blank" rel="noopener" class="org-link">{organization.urlLabel} →</a>
        </article>
      </div>
    </section>

    <section class="cta">
      <div class="cta-left">
        <span class="cta-issue">Next Issue</span>
        <h2>あなたの<br />物語を、<br />次のページに。</h2>
      </div>
      <div class="cta-right">
        <p>関係人口を増やす仲間を募集中。LINEオープンチャットからお気軽にどうぞ。</p>
        <a href={community.lineUrl} class="cta-button">コミュニティに参加する</a>
        <span class="cta-note">Powered by {community.operator}</span>
      </div>
    </section>

    <footer class="footer">
      <span>{community.name} / Issue 01 / {community.operator}</span>
      <span>2026 —</span>
    </footer>

    <a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}municipalities/kawakami`} class="back-link">← 川上村LP一覧に戻る</a>
  </div>
</Base>

<style>
  .editorial { font-family: 'Noto Sans JP', sans-serif; color: #1a1a1a; background: #f2ede6; }

  .nav { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 18px 48px; position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(242, 237, 230, 0.92); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(0, 0, 0, 0.06); }
  .nav-left { font-size: 0.85rem; font-weight: 700; }
  .nav-center { font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: #bbb; }
  .nav-right { text-align: right; font-family: 'Inter', sans-serif; font-size: 0.8rem; color: #C84B31; font-weight: 600; }

  .hero { display: grid; grid-template-columns: 1fr 1fr; min-height: 100vh; padding-top: 72px; }
  .hero-col-left { display: flex; flex-direction: column; justify-content: flex-end; padding: 60px 48px; }
  .hero-meta { display: flex; gap: 16px; font-family: 'Inter', sans-serif; font-size: 0.65rem; letter-spacing: 0.18em; text-transform: uppercase; color: #aaa; margin-bottom: 28px; }
  .hero h1 { font-size: clamp(3rem, 7vw, 6rem); font-weight: 900; line-height: 1.2; letter-spacing: -0.03em; }
  .hero h1 em { font-style: italic; font-family: 'Noto Serif JP', serif; color: #C84B31; }
  .hero-col-right { display: flex; flex-direction: column; }
  .hero-photo { flex: 1; min-height: 400px; background-size: cover; background-position: center; }
  .hero-caption { padding: 22px 32px; font-size: 0.75rem; line-height: 1.8; color: #888; border-top: 1px solid rgba(0, 0, 0, 0.06); }

  .marquee { overflow: hidden; padding: 18px 0; border-top: 1px solid rgba(0, 0, 0, 0.08); border-bottom: 1px solid rgba(0, 0, 0, 0.08); }
  .marquee-track { display: flex; gap: 32px; font-family: 'Inter', sans-serif; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: #ccc; white-space: nowrap; animation: marquee 22s linear infinite; }
  @keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  .story { padding: 110px 48px; }
  .story-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 56px; padding-bottom: 16px; border-bottom: 2px solid #1a1a1a; }
  .story-label { font-family: 'Inter', sans-serif; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: #C84B31; font-weight: 600; }
  .story-num { font-family: 'Inter', sans-serif; font-size: 2.6rem; font-weight: 200; color: #ddd; }
  .story-grid { display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: start; }
  .story-grid h2 { font-size: clamp(1.8rem, 4vw, 3rem); font-weight: 900; line-height: 1.45; }
  .story-grid h2 em { font-style: italic; font-family: 'Noto Serif JP', serif; color: #C84B31; }
  .story-body { display: flex; flex-direction: column; gap: 18px; }
  .story-lead { font-size: 1rem; font-weight: 500; line-height: 2; padding-bottom: 18px; border-bottom: 1px solid rgba(0, 0, 0, 0.08); }
  .story-body p { font-size: 0.88rem; line-height: 2.1; color: #666; font-weight: 300; }

  .columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; padding: 0 48px; }
  .column { padding: 0 30px 44px; border-top: 2px solid #1a1a1a; }
  .column-img { height: 200px; margin: 0 -30px 22px; background-size: cover; background-position: center; }
  .column-tag { font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.22em; text-transform: uppercase; color: #C84B31; display: block; margin-bottom: 12px; }
  .column h3 { font-size: 1.4rem; font-weight: 900; line-height: 1.4; margin-bottom: 14px; }
  .column p { font-size: 0.82rem; line-height: 2; color: #777; font-weight: 300; }

  .pull-quote { padding: 140px 48px; background-size: cover; background-position: center; color: #f2ede6; }
  .pull-quote-inner { max-width: 700px; margin: 0 auto; text-align: center; }
  .pull-quote-mark { font-family: 'Noto Serif JP', serif; font-size: 5rem; line-height: 1; color: #C84B31; opacity: 0.5; margin-bottom: -18px; }
  blockquote { font-family: 'Noto Serif JP', serif; font-size: clamp(1.4rem, 3vw, 2rem); line-height: 1.9; font-weight: 400; }
  .pull-quote-line { width: 40px; height: 2px; background: #C84B31; margin: 28px auto 0; }

  .news { padding: 110px 48px; }
  .news-list { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .news li a { display: block; color: inherit; }
  .news-img { aspect-ratio: 4/3; background-size: cover; background-position: center; margin-bottom: 16px; }
  .news-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; }
  .news-meta time { font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #888; }
  .news-tag { font-size: 0.66rem; padding: 2px 8px; letter-spacing: 0.08em; }
  .news-tag-press { background: #1a1a1a; color: #f2ede6; }
  .news-tag-event { background: #C84B31; color: #f2ede6; }
  .news-tag-milestone { background: #f2ede6; color: #1a1a1a; border: 1px solid #1a1a1a; }
  .news h3 { font-family: 'Noto Serif JP', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 8px; line-height: 1.5; }
  .news p { font-size: 0.82rem; line-height: 1.85; color: #777; font-weight: 300; }

  .large-type { padding: 90px 48px; background: #1a1a1a; color: #f2ede6; }
  .large-type-inner { max-width: 1100px; margin: 0 auto; }
  .large-type-label { font-family: 'Inter', sans-serif; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: #C84B31; display: block; margin-bottom: 32px; }
  .numbers-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; }
  .numbers-grid > div { display: flex; flex-direction: column; gap: 8px; }
  .numbers-grid strong { font-family: 'Noto Serif JP', serif; font-size: 2.4rem; font-weight: 900; }
  .numbers-grid span { font-size: 0.78rem; color: rgba(242, 237, 230, 0.65); letter-spacing: 0.06em; }

  .organizers { padding: 100px 48px; max-width: 1200px; margin: 0 auto; }
  .org-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
  .org-card { padding: 28px 32px 40px; border-top: 2px solid #1a1a1a; }
  .org-photo { aspect-ratio: 4/3; background-size: cover; background-position: center; margin-bottom: 20px; }
  .org-mark { aspect-ratio: 4/3; background: linear-gradient(135deg, #C84B31 0%, #1a1a1a 100%); color: #f2ede6; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 8px; margin-bottom: 20px; }
  .org-initial { font-family: 'Noto Serif JP', serif; font-size: 4rem; font-weight: 900; line-height: 1; font-style: italic; }
  .org-en { font-family: 'Inter', sans-serif; font-size: 0.66rem; letter-spacing: 0.22em; opacity: 0.85; }
  .org-card h3 { font-size: 1.4rem; font-weight: 900; line-height: 1.3; margin: 10px 0 6px; }
  .org-role { font-size: 0.78rem; color: #888; margin-bottom: 14px; }
  .org-card p { font-size: 0.82rem; line-height: 2; color: #777; font-weight: 300; }
  .org-link { display: inline-block; margin-top: 12px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #C84B31; border-bottom: 1px solid #C84B31; padding-bottom: 2px; }

  .cta { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; padding: 110px 48px; align-items: end; }
  .cta-issue { font-family: 'Inter', sans-serif; font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase; color: #C84B31; display: block; margin-bottom: 22px; }
  .cta h2 { font-size: clamp(2rem, 5vw, 4rem); font-weight: 900; line-height: 1.3; letter-spacing: -0.02em; }
  .cta-right p { font-size: 0.9rem; line-height: 2; color: #888; margin-bottom: 28px; font-weight: 300; }
  .cta-button { display: inline-block; padding: 16px 44px; background: #C84B31; color: #fff; font-size: 0.9rem; font-weight: 500; transition: transform 0.3s, opacity 0.3s; }
  .cta-button:hover { transform: translateY(-2px); opacity: 0.9; }
  .cta-note { display: block; margin-top: 22px; font-size: 0.7rem; color: #bbb; font-family: 'Inter', sans-serif; }

  .footer { display: flex; justify-content: space-between; padding: 22px 48px; font-family: 'Inter', sans-serif; font-size: 0.65rem; color: #bbb; border-top: 1px solid rgba(0, 0, 0, 0.06); letter-spacing: 0.05em; }
  .back-link { display: block; text-align: center; padding: 28px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #bbb; }
  .back-link:hover { color: #C84B31; }

  @media (max-width: 768px) {
    .nav { padding: 14px 22px; grid-template-columns: 1fr 1fr; }
    .nav-center { display: none; }
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-col-left { padding: 110px 22px 36px; }
    .hero-col-right { order: -1; }
    .hero-photo { min-height: 240px; }
    .hero-caption { padding: 14px 22px; }
    .story { padding: 70px 22px; }
    .story-grid { grid-template-columns: 1fr; gap: 32px; }
    .columns { grid-template-columns: 1fr; padding: 0 22px; gap: 36px; }
    .pull-quote { padding: 70px 22px; }
    .news { padding: 70px 22px; }
    .news-list { grid-template-columns: 1fr; }
    .large-type { padding: 60px 22px; }
    .numbers-grid { grid-template-columns: repeat(2, 1fr); }
    .organizers { padding: 60px 22px; }
    .org-grid { grid-template-columns: 1fr; gap: 32px; }
    .cta { grid-template-columns: 1fr; gap: 32px; padding: 70px 22px; }
  }
</style>
