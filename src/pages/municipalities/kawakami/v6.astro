---
import Base from '../../../layouts/Base.astro';
import { community, numbers, features, news, images, profile, organization } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (ブルータリズム案) — ${community.prefecture}${community.village}`}>
  <div class="brut">
    <nav class="nav">
      <div class="nav-logo"><span class="logo-mark">[🥬]</span><span class="logo-text">LETTUCE_VILLE</span></div>
      <div class="nav-links">
        <a href="#about">ABOUT</a>
        <a href="#news">NEWS</a>
        <a href={community.lineUrl} class="nav-cta">JOIN →</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-ticker">
        <span>// LIVE</span><span>NODE_COUNT: 100+</span><span>2026.04</span><span>STATUS: OPEN</span>
      </div>
      <div class="hero-grid">
        <div class="hero-tag"><span class="tag-num">No.001</span><span class="tag-label">KAWAKAMI × DAO × WEB3</span></div>
        <h1 class="hero-title">
          <span class="title-line-1">川上村を、</span>
          <span class="title-line-2">耕<span class="title-slash">/</span>す。</span>
        </h1>
        <div class="hero-block">
          <p>レタス生産量日本一の村で、<br />関係人口を増やすDAO。<br /><span class="mark">100名突破！</span></p>
        </div>
        <div class="hero-photo" style={`background-image: url('${images.hero}');`}></div>
        <div class="hero-ctas">
          <a href={community.lineUrl} class="btn-primary">NOW_JOIN →</a>
          <a href="#about" class="btn-ghost">↓ 詳しく</a>
        </div>
      </div>
      <div class="hero-sticker sticker-1">{community.villageEn}<br/>DAO</div>
    </section>

    <section id="about" class="about">
      <div class="section-head"><span class="section-num">[01]</span><span class="section-label">ABOUT // {community.name}とは</span></div>
      <div class="about-grid">
        <h2 class="about-h2">レタスと<br /><span class="hl-yellow">宇宙</span>の、<br />生々しい交差点。</h2>
        <div class="about-text">
          <p>{community.lead}</p>
          <p>住んでない奴も、知らない奴も、ウェルカム。やりたい奴が、やる。</p>
        </div>
      </div>
      <div class="stats">
        {numbers.slice(0, 3).map((n, i) => (
          <div class={`stat-card ${i === 1 ? 'stat-card-alt' : ''} ${i === 2 ? 'stat-card-blue' : ''}`}>
            <span class="stat-num">{n.value}{n.unit}</span>
            <span class="stat-label">{n.label}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="features">
      <div class="section-head"><span class="section-num">[02]</span><span class="section-label">FEATURES // できること</span></div>
      <div class="features-grid">
        {features.map((f, i) => (
          <article class={`f-card ${i % 3 === 0 ? '' : i % 3 === 1 ? 'f-card-yellow' : 'f-card-blue'}`}>
            {f.image && <div class="f-img" style={`background-image: url('${f.image}');`}></div>}
            <div class="f-card-top"><span class="f-num">{String(i + 1).padStart(2, '0')}</span><span class="f-icon">{f.icon}</span></div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="news" class="news">
      <div class="section-head inv-head"><span class="section-num inv">[03]</span><span class="section-label inv">NEWS // 便り</span></div>
      <ul class="news-list">
        {news.map((n) => (
          <li>
            <a href={n.href}>
              {n.image && <div class="n-img" style={`background-image: url('${n.image}');`}></div>}
              <div class="n-body">
                <div class="n-meta"><time>{n.date}</time><span class={`n-tag n-tag-${n.tag}`}>{n.tagLabel}</span></div>
                <h3>{n.title}</h3>
                <p>{n.excerpt}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="organizers">
      <div class="section-head"><span class="section-num">[04]</span><span class="section-label">ORGANIZERS // 運営</span></div>
      <div class="org-grid">
        <article class="org-card">
          <div class="org-photo" style={`background-image: url('${profile.photo}');`}></div>
          <div class="org-body">
            <span class="org-kind">[ PERSON ]</span>
            <h3>{profile.handle}</h3>
            <p class="org-role">{profile.role}</p>
            <p>{profile.bio}</p>
          </div>
        </article>
        <article class="org-card org-card-alt">
          <div class="org-mark"><span class="org-initial">A</span><span class="org-en">{organization.nameEn}</span></div>
          <div class="org-body">
            <span class="org-kind">[ COMPANY ]</span>
            <h3>{organization.name}</h3>
            <p class="org-role">{organization.role}</p>
            <p>{organization.bio}</p>
            <a href={organization.url} target="_blank" rel="noopener" class="org-link">→ {organization.urlLabel}</a>
          </div>
        </article>
      </div>
    </section>

    <section class="cta">
      <div class="cta-marquee"><span>JOIN // 参加する // JOIN // 参加する // JOIN // 参加する // JOIN // 参加する //</span></div>
      <div class="cta-inner">
        <span class="section-num">[04]</span>
        <h2 class="cta-h2">日本一の村の<br /><span class="hl-underline">101人目</span>へ。</h2>
        <p class="cta-sub">登録無料。いつでも離脱OK。気軽にどうぞ。</p>
        <a href={community.lineUrl} class="btn-cta"><span>LINEオープンチャットに参加する</span><span class="btn-cta-arrow">→</span></a>
        <div class="cta-meta"><span>OPERATED_BY</span><strong>{community.operator}</strong></div>
      </div>
    </section>

    <a href="/municipalities/kawakami" class="back-link">← 川上村LP一覧 BACK</a>
  </div>
</Base>

<style>
  .brut { font-family: 'BIZ UDGothic', 'Noto Sans JP', sans-serif; color: #000; background: #faf8f0; min-height: 100vh; font-weight: 700; }

  .nav { display: flex; justify-content: space-between; align-items: center; padding: 16px 32px; border-bottom: 4px solid #000; background: #faf8f0; position: sticky; top: 0; z-index: 100; }
  .nav-logo { display: flex; align-items: center; gap: 10px; font-family: 'Inter', monospace; font-weight: 900; }
  .logo-mark { background: #FF4500; color: #faf8f0; padding: 4px 6px; font-family: monospace; }
  .logo-text { font-size: 0.9rem; letter-spacing: 0.05em; }
  .nav-links { display: flex; gap: 16px; font-family: 'Inter', monospace; font-size: 0.8rem; }
  .nav-links a { padding: 6px 10px; border: 2px solid transparent; }
  .nav-links a:hover { border-color: #000; background: #FFEE00; }
  .nav-cta { background: #000; color: #faf8f0; border: 2px solid #000 !important; }
  .nav-cta:hover { background: #FFEE00 !important; color: #000 !important; }

  .hero { position: relative; padding: 0 0 70px; overflow: hidden; }
  .hero-ticker { display: flex; gap: 36px; padding: 10px 32px; background: #000; color: #FFEE00; font-family: monospace; font-size: 0.72rem; font-weight: 400; letter-spacing: 0.1em; white-space: nowrap; overflow: hidden; border-bottom: 4px solid #000; }
  .hero-grid { padding: 50px 32px 30px; max-width: 1200px; position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1fr; gap: 30px; align-items: start; }
  .hero-grid > .hero-tag, .hero-grid > .hero-title, .hero-grid > .hero-block, .hero-grid > .hero-ctas { grid-column: 1; }
  .hero-grid > .hero-photo { grid-column: 2; grid-row: 1 / span 4; aspect-ratio: 4/5; border: 4px solid #000; box-shadow: 10px 10px 0 #FF4500; background-size: cover; background-position: center; transform: rotate(2deg); }
  .hero-tag { display: inline-flex; align-items: center; gap: 12px; padding: 8px 14px; background: #FFEE00; border: 3px solid #000; box-shadow: 6px 6px 0 #000; font-family: monospace; font-size: 0.78rem; transform: rotate(-1deg); justify-self: start; }
  .tag-num { background: #000; color: #FFEE00; padding: 2px 6px; }
  .hero-title { font-size: clamp(2.6rem, 7vw, 5.5rem); line-height: 0.95; font-weight: 900; letter-spacing: -0.03em; }
  .title-line-1 { display: block; }
  .title-line-2 { display: inline-block; background: #FF4500; color: #faf8f0; padding: 0 14px; transform: translateX(20px) rotate(-1deg); box-shadow: 8px 8px 0 #000; border: 4px solid #000; }
  .title-slash { color: #FFEE00; }
  .hero-block { max-width: 480px; padding: 18px 22px; background: #faf8f0; border: 4px solid #000; box-shadow: 8px 8px 0 #000; }
  .hero-block p { font-size: 1rem; line-height: 1.85; font-weight: 500; }
  .mark { background: #FFEE00; padding: 2px 8px; border: 2px solid #000; font-weight: 900; }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary { padding: 16px 26px; background: #000; color: #FFEE00; border: 4px solid #000; font-family: monospace; font-weight: 900; font-size: 0.95rem; box-shadow: 8px 8px 0 #FF4500; transition: all 0.1s; }
  .btn-primary:hover { transform: translate(4px, 4px); box-shadow: 4px 4px 0 #FF4500; }
  .btn-ghost { padding: 16px 26px; background: transparent; color: #000; border: 4px solid #000; font-family: monospace; font-weight: 700; font-size: 0.95rem; }
  .btn-ghost:hover { background: #000; color: #faf8f0; }
  .hero-sticker { position: absolute; font-family: 'Inter', monospace; font-weight: 900; line-height: 1; pointer-events: none; }
  .sticker-1 { bottom: 60px; right: 6%; font-size: 1.6rem; color: #faf8f0; padding: 12px 16px; background: #0044FF; border: 3px solid #000; transform: rotate(-6deg); }

  .about { padding: 90px 32px; border-top: 6px solid #000; border-bottom: 6px solid #000; background: repeating-linear-gradient(45deg, #faf8f0, #faf8f0 10px, #f0ede0 10px, #f0ede0 11px); }
  .section-head { display: flex; align-items: center; gap: 14px; font-family: monospace; font-size: 0.82rem; margin-bottom: 40px; font-weight: 700; }
  .section-num { background: #000; color: #FFEE00; padding: 4px 10px; }
  .inv { background: #FFEE00; color: #000; }
  .inv-head { color: #faf8f0; }
  .section-label { letter-spacing: 0.05em; }
  .about-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 50px; align-items: start; max-width: 1200px; margin: 0 auto 50px; }
  .about-h2 { font-size: clamp(2rem, 5vw, 3.6rem); line-height: 1.1; font-weight: 900; letter-spacing: -0.02em; }
  .hl-yellow { background: #FFEE00; padding: 0 10px; border: 3px solid #000; display: inline-block; }
  .about-text { padding: 26px; background: #faf8f0; border: 4px solid #000; box-shadow: 8px 8px 0 #0044FF; }
  .about-text p { font-size: 0.92rem; line-height: 2; font-weight: 500; margin-bottom: 14px; }
  .about-text p:last-child { margin: 0; font-family: monospace; padding-top: 14px; border-top: 2px dashed #000; }
  .stats { display: grid; grid-template-columns: repeat(3, 1fr); max-width: 1200px; margin: 0 auto; border: 4px solid #000; }
  .stat-card { padding: 36px 26px; background: #faf8f0; border-right: 4px solid #000; display: flex; flex-direction: column; gap: 10px; }
  .stat-card:last-child { border-right: none; }
  .stat-card-alt { background: #FFEE00; }
  .stat-card-blue { background: #0044FF; color: #faf8f0; }
  .stat-num { font-family: 'Inter', sans-serif; font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 900; line-height: 1; letter-spacing: -0.04em; }
  .stat-label { font-family: monospace; font-size: 0.74rem; letter-spacing: 0.05em; }

  .features { padding: 90px 32px; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; max-width: 1200px; margin: 0 auto; }
  .f-card { background: #faf8f0; color: #000; border: 4px solid #000; box-shadow: 8px 8px 0 #FF4500; transition: all 0.15s; display: flex; flex-direction: column; overflow: hidden; }
  .f-card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0 #FF4500; }
  .f-card-yellow { background: #FFEE00; box-shadow: 8px 8px 0 #0044FF; }
  .f-card-yellow:hover { box-shadow: 12px 12px 0 #0044FF; }
  .f-card-blue { background: #0044FF; color: #faf8f0; box-shadow: 8px 8px 0 #FFEE00; }
  .f-card-blue:hover { box-shadow: 12px 12px 0 #FFEE00; }
  .f-img { aspect-ratio: 16/10; background-size: cover; background-position: center; border-bottom: 4px solid #000; }
  .f-card-top { display: flex; justify-content: space-between; align-items: center; padding: 16px 24px 0; font-family: monospace; }
  .f-num { font-size: 1.2rem; font-weight: 900; }
  .f-icon { font-size: 1.4rem; }
  .f-card h3 { padding: 14px 24px 10px; font-size: 1.15rem; font-weight: 900; line-height: 1.4; }
  .f-card p { padding: 0 24px 24px; font-size: 0.85rem; line-height: 1.85; font-weight: 500; }

  .news { padding: 90px 32px; background: #000; color: #faf8f0; }
  .news-list { list-style: none; max-width: 1100px; margin: 0 auto; display: flex; flex-direction: column; gap: 14px; }
  .news li a { display: grid; grid-template-columns: 200px 1fr; gap: 28px; align-items: center; padding: 24px; background: #faf8f0; color: #000; border: 4px solid #FFEE00; box-shadow: 6px 6px 0 #FF4500; transition: transform 0.15s; }
  .news li a:hover { transform: translate(-3px, -3px); box-shadow: 9px 9px 0 #FF4500; }
  .n-img { aspect-ratio: 4/3; background-size: cover; background-position: center; border: 2px solid #000; }
  .n-body { min-width: 0; }
  .n-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 8px; }
  .n-meta time { font-family: monospace; font-size: 0.78rem; }
  .n-tag { font-family: monospace; font-size: 0.66rem; padding: 3px 8px; letter-spacing: 0.08em; border: 2px solid #000; }
  .n-tag-press { background: #000; color: #FFEE00; }
  .n-tag-event { background: #FFEE00; color: #000; }
  .n-tag-milestone { background: #FF4500; color: #faf8f0; }
  .news h3 { font-size: 1rem; font-weight: 900; margin-bottom: 6px; line-height: 1.5; }
  .news p { font-size: 0.82rem; line-height: 1.85; font-weight: 500; }

  .organizers { padding: 90px 32px; background: #faf8f0; border-top: 6px solid #000; }
  .organizers .section-head { max-width: 1200px; margin: 0 auto 40px; }
  .org-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; max-width: 1200px; margin: 0 auto; }
  .org-card { display: grid; grid-template-columns: 150px 1fr; gap: 22px; padding: 24px; background: #FFEE00; border: 4px solid #000; box-shadow: 8px 8px 0 #FF4500; }
  .org-card-alt { background: #0044FF; color: #faf8f0; box-shadow: 8px 8px 0 #FFEE00; }
  .org-photo { aspect-ratio: 1/1; background-size: cover; background-position: center; border: 3px solid #000; }
  .org-mark { aspect-ratio: 1/1; background: #000; color: #FFEE00; border: 3px solid #000; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; }
  .org-initial { font-family: 'Inter', monospace; font-size: 3.4rem; font-weight: 900; line-height: 1; }
  .org-en { font-family: monospace; font-size: 0.6rem; letter-spacing: 0.2em; }
  .org-kind { font-family: monospace; font-size: 0.72rem; font-weight: 700; display: block; margin-bottom: 8px; }
  .org-card h3 { font-size: 1.3rem; font-weight: 900; margin-bottom: 4px; }
  .org-role { font-family: monospace; font-size: 0.75rem; margin-bottom: 12px; }
  .org-card p { font-size: 0.85rem; line-height: 1.85; font-weight: 500; }
  .org-link { display: inline-block; margin-top: 12px; font-family: monospace; font-size: 0.85rem; font-weight: 900; padding: 6px 12px; border: 2px solid #000; background: #faf8f0; color: #000; }
  .org-card-alt .org-link { background: #FFEE00; color: #000; }
  .org-link:hover { background: #FF4500; color: #faf8f0; }

  .cta { background: #FFEE00; border-top: 6px solid #000; position: relative; overflow: hidden; }
  .cta-marquee { background: #000; color: #FFEE00; padding: 14px 0; overflow: hidden; white-space: nowrap; font-family: monospace; font-size: 1.05rem; font-weight: 900; letter-spacing: 0.1em; border-bottom: 4px solid #000; }
  .cta-marquee span { display: inline-block; animation: marquee 22s linear infinite; }
  @keyframes marquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }
  .cta-inner { padding: 90px 32px; max-width: 800px; margin: 0 auto; text-align: center; }
  .cta-inner .section-num { display: inline-block; margin-bottom: 22px; }
  .cta-h2 { font-size: clamp(2rem, 5vw, 3.4rem); line-height: 1.2; font-weight: 900; letter-spacing: -0.02em; margin-bottom: 22px; }
  .hl-underline { border-bottom: 8px solid #FF4500; padding-bottom: 2px; }
  .cta-sub { font-family: monospace; font-size: 0.92rem; font-weight: 500; margin-bottom: 36px; }
  .btn-cta { display: inline-flex; align-items: center; gap: 18px; padding: 22px 36px; background: #000; color: #faf8f0; border: 4px solid #000; font-weight: 900; font-size: 1.05rem; box-shadow: 10px 10px 0 #FF4500; transition: all 0.1s; }
  .btn-cta:hover { transform: translate(4px, 4px); box-shadow: 4px 4px 0 #FF4500; background: #FF4500; }
  .btn-cta-arrow { font-family: monospace; }
  .cta-meta { margin-top: 42px; padding-top: 22px; border-top: 3px solid #000; display: flex; justify-content: center; gap: 12px; font-family: monospace; font-size: 0.82rem; }

  .back-link { display: block; text-align: center; padding: 24px; font-family: monospace; font-size: 0.82rem; font-weight: 700; background: #000; color: #faf8f0; }
  .back-link:hover { background: #FF4500; }

  @media (max-width: 768px) {
    .nav { flex-direction: column; gap: 12px; padding: 14px 20px; }
    .nav-links { gap: 8px; font-size: 0.7rem; }
    .hero-ticker { gap: 20px; padding: 8px 20px; font-size: 0.68rem; }
    .hero-grid { padding: 36px 20px 20px; grid-template-columns: 1fr; }
    .hero-grid > .hero-photo { grid-column: 1; grid-row: auto; transform: none; }
    .title-line-2 { transform: none; }
    .sticker-1 { display: none; }
    .about { padding: 60px 20px; }
    .about-grid { grid-template-columns: 1fr; gap: 28px; }
    .stats { grid-template-columns: 1fr; }
    .stat-card { border-right: none; border-bottom: 4px solid #000; }
    .stat-card:last-child { border-bottom: none; }
    .features { padding: 60px 20px; }
    .features-grid { grid-template-columns: 1fr; }
    .news { padding: 60px 20px; }
    .news li a { grid-template-columns: 1fr; }
    .organizers { padding: 60px 20px; }
    .org-grid { grid-template-columns: 1fr; }
    .org-card { grid-template-columns: 90px 1fr; gap: 16px; }
    .cta-inner { padding: 60px 20px; }
    .btn-cta { padding: 18px 24px; font-size: 0.92rem; }
  }
</style>
