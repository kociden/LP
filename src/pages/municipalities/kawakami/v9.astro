---
import Base from '../../../layouts/Base.astro';
import { community, numbers, features, news, images, profile, organization } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (ポップカラフル案) — ${community.prefecture}${community.village}`}>
  <div class="pop">
    <svg class="deco deco-1" viewBox="0 0 100 100" aria-hidden="true">
      <path d="M50 5 L61 39 L97 39 L68 60 L79 95 L50 74 L21 95 L32 60 L3 39 L39 39 Z" fill="#FFD93D"/>
    </svg>
    <svg class="deco deco-2" viewBox="0 0 100 100" aria-hidden="true">
      <g fill="#FF6B9D"><circle cx="50" cy="22" r="18"/><circle cx="78" cy="50" r="18"/><circle cx="50" cy="78" r="18"/><circle cx="22" cy="50" r="18"/></g>
      <circle cx="50" cy="50" r="12" fill="#FFD93D"/>
    </svg>

    <nav class="nav">
      <div class="nav-logo"><span class="nav-logo-dot"></span>{community.name}</div>
      <div class="nav-links">
        <a href="#about">知る</a>
        <a href="#news">ニュース</a>
        <a href={community.lineUrl} class="nav-cta">参加する</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-content">
        <div class="hero-badge"><span class="hero-badge-dot"></span>Kawakami DAO Community</div>
        <h1 class="hero-title">
          <span class="hero-word hero-word-1">レタス</span>から、<br />
          <span class="hero-word hero-word-2">宇宙</span>まで。<br />
          <span class="hero-word hero-word-3">川上村と。</span>
        </h1>
        <p class="hero-desc">{community.lead}</p>
        <div class="hero-ctas">
          <a href={community.lineUrl} class="btn btn-primary">LINEで参加 →</a>
          <a href="#about" class="btn btn-ghost">まずは知る</a>
        </div>
      </div>
      <div class="hero-photo"><img src={images.hero} alt="" /></div>
      <svg class="hero-wave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="#FFD93D"/>
      </svg>
    </section>

    <section id="about" class="about">
      <div class="about-inner">
        <div class="sec-label"><span class="sec-num">01</span><span class="sec-tag">About</span></div>
        <h2 class="about-h">川上村は、<br /><span class="marker">レタスと宇宙の村。</span></h2>
        <p class="about-p">{community.lead}</p>

        <div class="stats">
          {numbers.map((n, i) => (
            <div class={`stat stat-${['pink','yellow','green','blue'][i]}`}>
              <div class="stat-num">{n.value}{n.unit}</div>
              <div class="stat-label">{n.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="features">
      <div class="features-inner">
        <div class="sec-label sec-label-light"><span class="sec-num">02</span><span class="sec-tag">Features</span></div>
        <h2 class="features-h">できることは、<span class="hl">いっぱい。</span></h2>

        <div class="cards">
          {features.map((f, i) => (
            <div class={`card card-${['pink','yellow','blue','pink','yellow','blue'][i]}`}>
              {f.image && <div class="card-img"><img src={f.image} alt="" /></div>}
              <div class="card-num">{String(i + 1).padStart(2, '0')}</div>
              <div class="card-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="news" class="news">
      <div class="news-inner">
        <div class="sec-label"><span class="sec-num">03</span><span class="sec-tag">News</span></div>
        <h2 class="news-h">ニュース・<span class="marker">プレスリリース</span></h2>
        <ul>
          {news.map((n) => (
            <li>
              <a href={n.href}>
                {n.image && <div class="n-img"><img src={n.image} alt="" /></div>}
                <div class="n-meta"><time>{n.date}</time><span class={`n-tag n-tag-${n.tag}`}>{n.tagLabel}</span></div>
                <h3>{n.title}</h3>
                <p>{n.excerpt}</p>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <section class="organizers">
      <div class="organizers-inner">
        <div class="sec-label"><span class="sec-num">04</span><span class="sec-tag">Organizers</span></div>
        <h2 class="org-h">運営は、<span class="marker">この2者。</span></h2>
        <div class="org-grid">
          <article class="org-card org-card-pink">
            <div class="org-photo"><img src={profile.photo} alt="" /></div>
            <div class="org-body">
              <span class="org-kind">Person</span>
              <h3>{profile.handle}</h3>
              <p class="org-role">{profile.role}</p>
              <p>{profile.bio}</p>
            </div>
          </article>
          <article class="org-card org-card-blue">
            <div class="org-mark"><span class="org-initial">A</span><span class="org-en">{organization.nameEn}</span></div>
            <div class="org-body">
              <span class="org-kind">Company</span>
              <h3>{organization.name}</h3>
              <p class="org-role">{organization.role}</p>
              <p>{organization.bio}</p>
              <a href={organization.url} target="_blank" rel="noopener" class="org-link">{organization.urlLabel} →</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="cta-inner">
        <svg class="cta-star cta-star-1" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M50 5 L61 39 L97 39 L68 60 L79 95 L50 74 L21 95 L32 60 L3 39 L39 39 Z" fill="#FF6B9D"/>
        </svg>
        <svg class="cta-star cta-star-2" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M50 5 L61 39 L97 39 L68 60 L79 95 L50 74 L21 95 L32 60 L3 39 L39 39 Z" fill="#4D96FF"/>
        </svg>
        <p class="cta-label">Join the DAO</p>
        <h2 class="cta-h">あなたの地域との関わりを、<br /><span class="cta-hl">ここから。</span></h2>
        <a href={community.lineUrl} class="btn btn-big">LINEオープンチャットに参加 →</a>
        <p class="cta-note">運営: {community.operator}</p>
      </div>
    </section>

    <a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}municipalities/kawakami`} class="back-link">← 川上村LP一覧に戻る</a>
  </div>
</Base>

<style>
  .pop { font-family: 'Noto Sans JP', 'Inter', sans-serif; color: #1a1a3a; background: #FFF8E7; min-height: 100vh; position: relative; overflow: hidden; }
  .deco { position: absolute; pointer-events: none; z-index: 0; }
  .deco-1 { width: 80px; height: 80px; top: 18%; right: 8%; animation: spin 18s linear infinite; }
  .deco-2 { width: 110px; height: 110px; top: 70%; left: 4%; animation: bob 6s ease-in-out infinite; }
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes bob { 0%, 100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-20px) rotate(8deg); } }
  @keyframes tilt { 0%, 100% { transform: rotate(-2deg); } 50% { transform: rotate(2deg); } }

  .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 36px; position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255, 248, 231, 0.88); backdrop-filter: blur(12px); border-bottom: 2px solid #1a1a3a; }
  .nav-logo { display: flex; align-items: center; gap: 10px; font-weight: 900; font-size: 1rem; }
  .nav-logo-dot { width: 14px; height: 14px; border-radius: 50%; background: #FF6B9D; box-shadow: 0 0 0 3px #FFD93D; }
  .nav-links { display: flex; gap: 24px; align-items: center; font-size: 0.88rem; font-weight: 700; }
  .nav-links a:hover { color: #FF6B9D; }
  .nav-cta { padding: 10px 20px; background: #1a1a3a; color: #FFF8E7 !important; border-radius: 999px; border: 2px solid #1a1a3a; transition: transform 0.2s, background 0.2s; }
  .nav-cta:hover { background: #FF6B9D; transform: translateY(-2px); }

  .hero { min-height: 100vh; padding: 120px 36px 160px; max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; display: grid; grid-template-columns: 1.1fr 1fr; gap: 40px; align-items: center; }
  .hero-badge { display: inline-flex; align-items: center; gap: 10px; padding: 8px 18px; border: 2px solid #1a1a3a; border-radius: 999px; background: #FFD93D; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; margin-bottom: 28px; transform: rotate(-1.5deg); }
  .hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: #FF6B9D; animation: pulse 1.5s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.4); opacity: 0.6; } }
  .hero-title { font-size: clamp(2.4rem, 6.5vw, 5rem); font-weight: 900; line-height: 1.2; margin-bottom: 32px; }
  .hero-word { display: inline-block; padding: 0 14px; border-radius: 999px; }
  .hero-word-1 { background: #FF6B9D; color: #FFF8E7; transform: rotate(-2deg); animation: tilt 4s ease-in-out infinite; }
  .hero-word-2 { background: #4D96FF; color: #FFF8E7; transform: rotate(1.5deg); animation: tilt 4s ease-in-out infinite 0.5s; }
  .hero-word-3 { background: #6BCB77; color: #1a1a3a; transform: rotate(-1deg); animation: tilt 4s ease-in-out infinite 1s; }
  .hero-desc { font-size: 1rem; line-height: 2; color: #3a3a5a; max-width: 480px; margin-bottom: 36px; font-weight: 500; }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn { display: inline-block; padding: 16px 32px; border-radius: 999px; font-weight: 700; font-size: 0.95rem; transition: transform 0.2s, box-shadow 0.2s; border: 2px solid #1a1a3a; }
  .btn-primary { background: #FF6B9D; color: #FFF8E7; box-shadow: 4px 4px 0 #1a1a3a; }
  .btn-primary:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #1a1a3a; }
  .btn-ghost { background: #FFF8E7; color: #1a1a3a; }
  .btn-ghost:hover { background: #FFD93D; transform: translateY(-2px); }
  .btn-big { padding: 22px 44px; font-size: 1.05rem; background: #FFD93D; color: #1a1a3a; box-shadow: 6px 6px 0 #1a1a3a; }
  .btn-big:hover { transform: translate(-3px, -3px); box-shadow: 9px 9px 0 #1a1a3a; }

  .hero-photo { position: relative; aspect-ratio: 4/5; border: 4px solid #1a1a3a; border-radius: 36px; overflow: hidden; box-shadow: 8px 8px 0 #FF6B9D; transform: rotate(2deg); }
  .hero-photo img { width: 100%; height: 100%; object-fit: cover; }

  .hero-wave { position: absolute; bottom: 0; left: 0; right: 0; width: 100%; height: 80px; display: block; }

  .about { background: #FFD93D; padding: 110px 36px; position: relative; z-index: 1; border-top: 3px solid #1a1a3a; border-bottom: 3px solid #1a1a3a; }
  .about-inner { max-width: 1100px; margin: 0 auto; }
  .sec-label { display: inline-flex; align-items: baseline; gap: 12px; margin-bottom: 26px; font-family: 'Inter', sans-serif; }
  .sec-num { font-size: 0.82rem; font-weight: 700; padding: 4px 12px; background: #1a1a3a; color: #FFF8E7; border-radius: 999px; }
  .sec-tag { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; }
  .about-h { font-size: clamp(2rem, 5vw, 3.4rem); line-height: 1.35; font-weight: 900; margin-bottom: 28px; }
  .marker { background: linear-gradient(transparent 55%, #FF6B9D 55%); padding: 0 4px; }
  .about-p { font-size: 1rem; line-height: 2.1; max-width: 720px; font-weight: 500; margin-bottom: 48px; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .stat { padding: 28px 22px; border-radius: 26px; border: 3px solid #1a1a3a; text-align: center; transition: transform 0.25s; }
  .stat:hover { transform: translateY(-6px) rotate(-1deg); }
  .stat-pink { background: #FF6B9D; color: #FFF8E7; }
  .stat-yellow { background: #FFF8E7; }
  .stat-green { background: #6BCB77; color: #1a1a3a; }
  .stat-blue { background: #4D96FF; color: #FFF8E7; }
  .stat-num { font-family: 'Inter', sans-serif; font-size: 2.2rem; font-weight: 900; line-height: 1; margin-bottom: 8px; }
  .stat-label { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.05em; }

  .features { background: #1a1a3a; color: #FFF8E7; padding: 110px 36px; position: relative; z-index: 1; overflow: hidden; }
  .features-inner { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }
  .sec-label-light .sec-num { background: #FFD93D; color: #1a1a3a; }
  .sec-label-light .sec-tag { color: #FFF8E7; }
  .features-h { font-size: clamp(2rem, 5vw, 3.2rem); line-height: 1.4; font-weight: 900; margin-bottom: 56px; }
  .hl { color: #FFD93D; }
  .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .card { padding: 0; border-radius: 28px; border: 3px solid #1a1a3a; color: #1a1a3a; transition: transform 0.3s; overflow: hidden; }
  .card:hover { transform: translateY(-6px) rotate(-1deg); }
  .card-pink { background: #FF6B9D; color: #FFF8E7; }
  .card-yellow { background: #FFD93D; }
  .card-blue { background: #4D96FF; color: #FFF8E7; }
  .card-img { aspect-ratio: 16/10; border-bottom: 3px solid #1a1a3a; }
  .card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .card-num { font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 800; padding: 4px 12px; background: #FFF8E7; color: #1a1a3a; border-radius: 999px; border: 2px solid #1a1a3a; display: inline-block; margin: 22px 24px 0; }
  .card-icon { font-size: 2rem; padding: 16px 24px 0; }
  .card h3 { font-size: 1.25rem; font-weight: 900; padding: 12px 24px 8px; }
  .card p { padding: 0 24px 26px; font-size: 0.88rem; line-height: 1.85; font-weight: 500; }

  .news { background: #FFEAF2; padding: 110px 36px; position: relative; z-index: 1; }
  .news-inner { max-width: 1100px; margin: 0 auto; }
  .news-h { font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.4; font-weight: 900; margin-bottom: 44px; }
  .news ul { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .news li a { display: block; background: #FFF8E7; border: 3px solid #1a1a3a; border-radius: 22px; overflow: hidden; box-shadow: 4px 4px 0 #1a1a3a; transition: transform 0.2s; color: inherit; }
  .news li a:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 #1a1a3a; }
  .n-img { aspect-ratio: 16/10; border-bottom: 3px solid #1a1a3a; }
  .n-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .n-meta { display: flex; gap: 12px; align-items: center; padding: 18px 22px 6px; }
  .n-meta time { font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 700; }
  .n-tag { font-size: 0.66rem; padding: 3px 10px; border-radius: 999px; font-weight: 700; border: 2px solid #1a1a3a; }
  .n-tag-press { background: #1a1a3a; color: #FFF8E7; }
  .n-tag-event { background: #FFD93D; color: #1a1a3a; }
  .n-tag-milestone { background: #FF6B9D; color: #FFF8E7; }
  .news h3 { font-size: 1.05rem; font-weight: 900; padding: 4px 22px 8px; line-height: 1.5; }
  .news p { font-size: 0.84rem; line-height: 1.85; padding: 0 22px 22px; font-weight: 500; }

  .organizers { background: #FFF8E7; padding: 100px 36px; position: relative; z-index: 1; border-top: 3px solid #1a1a3a; }
  .organizers-inner { max-width: 1100px; margin: 0 auto; }
  .org-h { font-size: clamp(1.8rem, 4vw, 2.6rem); line-height: 1.45; font-weight: 900; margin-bottom: 36px; }
  .org-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .org-card { display: grid; grid-template-columns: 130px 1fr; gap: 22px; padding: 26px; border: 3px solid #1a1a3a; border-radius: 26px; box-shadow: 5px 5px 0 #1a1a3a; }
  .org-card-pink { background: #FFEAF2; }
  .org-card-blue { background: #D6E9FF; }
  .org-photo { aspect-ratio: 1/1; border: 3px solid #1a1a3a; border-radius: 16px; overflow: hidden; }
  .org-photo img { width: 100%; height: 100%; object-fit: cover; }
  .org-mark { aspect-ratio: 1/1; border: 3px solid #1a1a3a; border-radius: 16px; background: linear-gradient(135deg, #4D96FF 0%, #1a1a3a 100%); color: #FFF8E7; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; }
  .org-initial { font-family: 'Inter', sans-serif; font-size: 3rem; font-weight: 900; line-height: 1; }
  .org-en { font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.22em; opacity: 0.85; }
  .org-kind { font-family: 'Inter', sans-serif; font-size: 0.72rem; font-weight: 800; color: #1a1a3a; background: #FFD93D; border: 2px solid #1a1a3a; border-radius: 999px; padding: 2px 10px; display: inline-block; margin-bottom: 8px; }
  .org-card h3 { font-size: 1.25rem; font-weight: 900; margin-bottom: 4px; }
  .org-role { font-size: 0.78rem; font-weight: 600; color: #3a3a5a; margin-bottom: 12px; }
  .org-card p { font-size: 0.85rem; line-height: 1.85; font-weight: 500; }
  .org-link { display: inline-block; margin-top: 12px; font-family: 'Inter', sans-serif; font-size: 0.82rem; font-weight: 700; padding: 6px 14px; border: 2px solid #1a1a3a; background: #FFD93D; color: #1a1a3a; border-radius: 999px; }
  .org-link:hover { background: #FF6B9D; color: #FFF8E7; }

  .cta { background: #FFEAF2; padding: 140px 36px; text-align: center; position: relative; overflow: hidden; z-index: 1; border-top: 3px solid #1a1a3a; }
  .cta-inner { max-width: 720px; margin: 0 auto; position: relative; }
  .cta-star { position: absolute; pointer-events: none; }
  .cta-star-1 { width: 70px; height: 70px; top: -40px; left: 10%; animation: spin 14s linear infinite; }
  .cta-star-2 { width: 55px; height: 55px; bottom: -30px; right: 12%; animation: spin 20s linear infinite reverse; }
  .cta-label { display: inline-block; font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 800; letter-spacing: 0.18em; text-transform: uppercase; color: #1a1a3a; padding: 6px 16px; background: #FFD93D; border-radius: 999px; border: 2px solid #1a1a3a; margin-bottom: 26px; }
  .cta-h { font-size: clamp(2rem, 5vw, 3rem); line-height: 1.4; font-weight: 900; margin-bottom: 44px; }
  .cta-hl { color: #FF6B9D; }
  .cta-note { margin-top: 28px; font-size: 0.85rem; color: #3a3a5a; font-weight: 600; }

  .back-link { display: block; text-align: center; padding: 28px; font-family: 'Inter', sans-serif; font-size: 0.85rem; font-weight: 700; color: #1a1a3a; background: #FFF8E7; border-top: 3px solid #1a1a3a; }
  .back-link:hover { background: #1a1a3a; color: #FFD93D; }

  @media (max-width: 768px) {
    .nav { padding: 12px 18px; }
    .nav-links { gap: 12px; font-size: 0.78rem; }
    .nav-cta { padding: 8px 14px; }
    .hero { padding: 110px 22px 130px; grid-template-columns: 1fr; gap: 28px; }
    .hero-photo { transform: none; max-width: 320px; justify-self: center; }
    .hero-ctas { flex-direction: column; }
    .btn { text-align: center; }
    .deco-1, .deco-2 { width: 50px; height: 50px; }
    .about, .features, .news, .cta { padding: 70px 22px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .cards, .news ul { grid-template-columns: 1fr; }
    .organizers { padding: 70px 22px; }
    .org-grid { grid-template-columns: 1fr; gap: 16px; }
    .org-card { grid-template-columns: 90px 1fr; gap: 16px; padding: 20px; }
  }
</style>
