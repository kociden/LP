---
import Base from '../../../layouts/Base.astro';
import { community, numbers, features, news, steps, images, gallery, profile, organization } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (ミニマル白案) — ${community.prefecture}${community.village}`}>
  <div class="minimal">
    <nav class="nav">
      <span class="nav-name">{community.name}</span>
      <div class="nav-right">
        <a href="#about">About</a>
        <a href="#news">News</a>
        <a href="#join" class="nav-join">Join</a>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-center">
        <p class="hero-eyebrow">A Decentralized Community for {community.villageEn}</p>
        <h1>レタスから、<br />宇宙まで。</h1>
        <p class="hero-sub">{community.prefecture}{community.village}と、つながる場所。</p>
      </div>
      <div class="hero-footer">
        <span>by {community.operator}</span>
        <span>Est. 2025</span>
      </div>
    </section>

    <section class="hero-photo">
      <img src={images.hero} alt="" />
    </section>

    <section class="statement">
      <p>
        川上村は、レタス生産量日本一の村。<br />
        宇宙飛行士を輩出した村。<br /><br />
        この村と関わる人を、増やしていく。
      </p>
    </section>

    <section id="about" class="about">
      <div class="about-row">
        <div><span class="label">What we do</span></div>
        <div>
          <h2>つながる。学ぶ。動く。</h2>
          <p>{community.lead}</p>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="features-header"><span class="label">Features</span><h2>できること</h2></div>
      <div class="features-list">
        {features.map((f) => (
          <div class="f-item">
            {f.image && <div class="f-img"><img src={f.image} alt="" /></div>}
            <div class="f-text"><h3>{f.title}</h3><p>{f.body}</p></div>
          </div>
        ))}
      </div>
    </section>

    <section class="numbers">
      <div class="numbers-grid">
        {numbers.map((n) => (
          <div class="number-item">
            <span class="number-big">{n.value}{n.unit}</span>
            <span class="number-label">{n.label}</span>
          </div>
        ))}
      </div>
    </section>

    <section id="news" class="news">
      <div class="news-header"><span class="label">News &amp; Press</span><h2>ニュース</h2></div>
      <ul>
        {news.map((n) => (
          <li>
            <a href={n.href}>
              {n.image && <div class="n-img"><img src={n.image} alt="" /></div>}
              <div class="n-meta"><time>{n.date}</time><span class={`n-tag n-tag-${n.tag}`}>{n.tagLabel}</span></div>
              <h3>{n.title}</h3>
              <p>{n.excerpt}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="gallery">
      <div class="gallery-grid">
        {gallery.slice(0, 6).map((g) => (
          <img src={g} alt="" />
        ))}
      </div>
    </section>

    <section class="organizers">
      <div class="org-header"><span class="label">Organizers</span><h2>運営</h2></div>
      <div class="org-grid">
        <div class="org-card">
          <div class="org-photo"><img src={profile.photo} alt="" /></div>
          <div class="org-body">
            <span class="org-kind">Person</span>
            <h3>{profile.handle}</h3>
            <p class="org-role">{profile.role}</p>
            <p>{profile.bio}</p>
          </div>
        </div>
        <div class="org-card">
          <div class="org-mark"><span class="org-initial">A</span><span class="org-en">{organization.nameEn}</span></div>
          <div class="org-body">
            <span class="org-kind">Company</span>
            <h3>{organization.name}</h3>
            <p class="org-role">{organization.role}</p>
            <p>{organization.bio}</p>
            <a href={organization.url} target="_blank" rel="noopener" class="org-link">{organization.urlLabel} →</a>
          </div>
        </div>
      </div>
    </section>

    <section id="join" class="cta">
      <h2>始めよう。</h2>
      <p>あなたの「川上村と関わりたい」が、最初の一歩。</p>
      <a href={community.lineUrl} class="cta-btn">LINEで参加する</a>
    </section>

    <footer class="footer">
      <span>{community.name}</span>
      <span>運営: {community.operator}</span>
    </footer>

    <a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}municipalities/kawakami`} class="back-link">← 川上村LP一覧に戻る</a>
  </div>
</Base>

<style>
  .minimal { font-family: 'Noto Sans JP', sans-serif; color: #111; background: #fff; }
  .label { font-family: 'Inter', sans-serif; font-size: 0.65rem; letter-spacing: 0.22em; text-transform: uppercase; color: #aaa; }

  .nav { display: flex; justify-content: space-between; align-items: center; padding: 22px 64px; position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(20px); border-bottom: 1px solid #f0f0f0; }
  .nav-name { font-size: 0.85rem; font-weight: 700; }
  .nav-right { display: flex; gap: 32px; font-family: 'Inter', sans-serif; font-size: 0.8rem; }
  .nav-right a { color: #888; transition: color 0.2s; }
  .nav-right a:hover { color: #111; }
  .nav-join { color: #111 !important; font-weight: 600; }

  .hero { min-height: 90vh; display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; padding: 0 64px; position: relative; }
  .hero-eyebrow { font-family: 'Inter', sans-serif; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: #bbb; margin-bottom: 36px; }
  .hero h1 { font-size: clamp(3rem, 8vw, 6.5rem); font-weight: 900; line-height: 1.25; letter-spacing: -0.02em; margin-bottom: 28px; }
  .hero-sub { font-size: 1rem; color: #888; font-weight: 300; letter-spacing: 0.05em; }
  .hero-footer { position: absolute; bottom: 40px; left: 64px; right: 64px; display: flex; justify-content: space-between; font-family: 'Inter', sans-serif; font-size: 0.65rem; color: #ccc; letter-spacing: 0.1em; }

  .hero-photo { padding: 0 64px 80px; }
  .hero-photo img { width: 100%; max-width: 1200px; margin: 0 auto; display: block; aspect-ratio: 21 / 9; object-fit: cover; }

  .statement { padding: 140px 64px; border-top: 1px solid #f0f0f0; text-align: center; }
  .statement p { font-size: 1.1rem; line-height: 2.4; font-weight: 300; color: #444; max-width: 560px; margin: 0 auto; }

  .about { padding: 120px 64px; border-top: 1px solid #f0f0f0; }
  .about-row { display: grid; grid-template-columns: 240px 1fr; gap: 80px; max-width: 900px; }
  .about-row > div:first-child { padding-top: 8px; }
  .about-row h2 { font-size: 2rem; font-weight: 900; margin-bottom: 24px; letter-spacing: -0.01em; }
  .about-row p { font-size: 0.95rem; line-height: 2.2; color: #666; font-weight: 300; max-width: 480px; }

  .features { padding: 120px 64px; border-top: 1px solid #f0f0f0; }
  .features-header { margin-bottom: 80px; }
  .features-header h2 { font-size: 1.4rem; font-weight: 900; margin-top: 12px; }
  .features-list { display: flex; flex-direction: column; max-width: 800px; }
  .f-item { display: grid; grid-template-columns: 200px 1fr; gap: 40px; padding: 36px 0; border-top: 1px solid #eee; align-items: center; }
  .f-img img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .f-img:empty { display: none; }
  .f-item:has(.f-img:empty) { grid-template-columns: 1fr; }
  .f-text h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 10px; }
  .f-text p { font-size: 0.88rem; line-height: 1.95; color: #888; font-weight: 300; }

  .numbers { padding: 90px 64px; border-top: 1px solid #f0f0f0; border-bottom: 1px solid #f0f0f0; }
  .numbers-grid { display: grid; grid-template-columns: repeat(4, 1fr); text-align: center; max-width: 900px; margin: 0 auto; gap: 24px; }
  .number-big { font-family: 'Inter', sans-serif; font-size: 2.4rem; font-weight: 200; letter-spacing: -0.02em; display: block; margin-bottom: 8px; }
  .number-label { font-size: 0.75rem; color: #bbb; }

  .news { padding: 120px 64px; }
  .news-header { margin-bottom: 64px; }
  .news-header h2 { font-size: 1.4rem; font-weight: 900; margin-top: 12px; }
  .news ul { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; max-width: 1100px; }
  .news li a { display: block; color: inherit; }
  .n-img { margin-bottom: 16px; }
  .n-img img { width: 100%; aspect-ratio: 4/3; object-fit: cover; }
  .n-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; }
  .n-meta time { font-family: 'Inter', sans-serif; font-size: 0.75rem; color: #bbb; }
  .n-tag { font-size: 0.66rem; padding: 2px 8px; border: 1px solid #ddd; }
  .n-tag-press { border-color: #111; color: #111; }
  .n-tag-event { border-color: #888; color: #555; }
  .n-tag-milestone { border-color: #6BCB77; color: #4a8a3f; }
  .news li h3 { font-size: 1rem; font-weight: 700; margin-bottom: 8px; line-height: 1.5; }
  .news li p { font-size: 0.82rem; line-height: 1.8; color: #888; font-weight: 300; }

  .gallery { padding: 80px 64px; border-top: 1px solid #f0f0f0; }
  .gallery-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 4px; max-width: 1200px; margin: 0 auto; }
  .gallery-grid img { width: 100%; aspect-ratio: 1/1; object-fit: cover; }

  .organizers { padding: 120px 64px; border-top: 1px solid #f0f0f0; max-width: 1000px; margin: 0 auto; }
  .org-header { margin-bottom: 64px; }
  .org-header h2 { font-size: 1.4rem; font-weight: 900; margin-top: 12px; }
  .org-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
  .org-card { display: grid; grid-template-columns: 100px 1fr; gap: 28px; }
  .org-photo img { width: 100%; aspect-ratio: 1/1; object-fit: cover; }
  .org-mark { aspect-ratio: 1/1; background: #111; color: #fff; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; }
  .org-initial { font-family: 'Inter', sans-serif; font-size: 2.6rem; font-weight: 200; line-height: 1; }
  .org-en { font-family: 'Inter', sans-serif; font-size: 0.56rem; letter-spacing: 0.22em; opacity: 0.75; }
  .org-kind { font-family: 'Inter', sans-serif; font-size: 0.62rem; letter-spacing: 0.22em; color: #aaa; display: block; margin-bottom: 8px; }
  .org-body h3 { font-size: 1.1rem; font-weight: 900; margin-bottom: 4px; }
  .org-role { font-size: 0.78rem; color: #aaa; margin-bottom: 12px; }
  .org-body p { font-size: 0.82rem; line-height: 1.95; color: #888; font-weight: 300; }
  .org-link { display: inline-block; margin-top: 12px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #111; border-bottom: 1px solid #111; padding-bottom: 2px; }

  .cta { padding: 180px 64px; text-align: center; border-top: 1px solid #f0f0f0; }
  .cta h2 { font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 900; margin-bottom: 20px; }
  .cta p { font-size: 0.9rem; color: #888; font-weight: 300; margin-bottom: 44px; }
  .cta-btn { display: inline-block; padding: 18px 64px; background: #111; color: #fff; font-size: 0.85rem; letter-spacing: 0.05em; transition: opacity 0.3s, transform 0.3s; }
  .cta-btn:hover { opacity: 0.85; transform: translateY(-2px); }

  .footer { border-top: 1px solid #f0f0f0; padding: 28px 64px; display: flex; justify-content: space-between; font-size: 0.7rem; color: #ccc; font-family: 'Inter', sans-serif; }
  .back-link { display: block; text-align: center; padding: 28px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #ccc; }
  .back-link:hover { color: #111; }

  @media (max-width: 768px) {
    .nav { padding: 14px 22px; }
    .hero { padding: 0 22px; min-height: 70vh; }
    .hero-footer { left: 22px; right: 22px; }
    .hero-photo { padding: 0 22px 60px; }
    .statement, .about, .features, .news, .gallery, .cta { padding: 70px 22px; }
    .about-row { grid-template-columns: 1fr; gap: 24px; }
    .f-item { grid-template-columns: 1fr; gap: 16px; padding: 24px 0; }
    .numbers-grid { grid-template-columns: repeat(2, 1fr); gap: 32px; }
    .news ul { grid-template-columns: 1fr; }
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
    .organizers { padding: 70px 22px; }
    .org-grid { grid-template-columns: 1fr; gap: 32px; }
    .footer { padding: 22px; flex-direction: column; gap: 6px; text-align: center; }
  }
</style>
