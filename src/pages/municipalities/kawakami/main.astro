---
import Base from '../../../layouts/Base.astro';
import { community, numbers, concepts, features, news, steps, faqs, images, gallery, profile, organization } from '../../../data/kawakami.ts';
---

<Base
  title={`${community.name} — ${community.prefecture}${community.village}DAO`}
  description={`${community.prefecture}${community.village}のDAOコミュニティ「${community.name}」。レタス生産量日本一・宇宙飛行士を輩出した村で、関係人口を増やす仲間を募集中。`}
>
  <div class="page">
    <!-- Nav -->
    <nav class="nav">
      <a href="#hero" class="nav-logo">
        <span class="nav-mark">🥬</span>
        <span class="nav-text">{community.name}</span>
      </a>
      <div class="nav-links">
        <a href="#about">川上村とは</a>
        <a href="#features">できること</a>
        <a href="#news">ニュース</a>
        <a href="#profile">運営者</a>
        <a href="#faq">FAQ</a>
        <a href={community.lineUrl} target="_blank" rel="noopener" class="nav-cta">LINEで参加</a>
      </div>
    </nav>

    <!-- Hero -->
    <section id="hero" class="hero">
      <div class="hero-blob hero-blob-1" aria-hidden="true"></div>
      <div class="hero-blob hero-blob-2" aria-hidden="true"></div>
      <div class="hero-emoji hero-emoji-1" aria-hidden="true">🥬</div>
      <div class="hero-emoji hero-emoji-2" aria-hidden="true">🚀</div>
      <div class="hero-emoji hero-emoji-3" aria-hidden="true">⭐</div>

      <div class="hero-inner">
        <span class="hero-badge">
          <span class="hero-badge-dot"></span>
          川上村DAO・参加者100名突破
        </span>
        <h1 class="hero-title" set:html={community.catchcopy}></h1>
        <p class="hero-lead">{community.lead}</p>
        <div class="hero-actions">
          <a href={community.lineUrl} class="btn btn-primary btn-lg">
            <span>LINEオープンチャットに参加する</span>
            <span class="btn-arrow">→</span>
          </a>
          <a href="#about" class="btn btn-ghost">まずは村のことを知る</a>
        </div>
        <p class="hero-note">登録無料／いつでも退出OK／顔出し不要</p>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="about">
      <header class="section-head">
        <span class="section-num">01</span>
        <span class="section-tag">ABOUT KAWAKAMI</span>
      </header>
      <h2 class="section-title">川上村って、<br class="br-sm" />こんな村。</h2>
      <p class="section-lead">
        標高1,100mの高原に広がる、長野県南佐久郡の小さな村。<br />
        「食」と「宇宙」、ふたつの強烈なアイデンティティがあります。
      </p>

      <div class="about-grid">
        {concepts.map((c, i) => (
          <article class={`concept ${i === 0 ? 'concept-lettuce' : 'concept-cosmos'}`}>
            {i === 1 && (
              <div class="concept-photo" style={`background-image: url('${images.cosmos}');`} aria-hidden="true"></div>
            )}
            <div class="concept-body">
              <div class="concept-emoji">{c.icon}</div>
              <h3 set:html={c.title.replace('、', '、<br />')}></h3>
              <p>{c.body}</p>
              <ul>
                {c.bullets.map((b) => (
                  <li><span>{i === 0 ? '●' : '★'}</span>{b}</li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="features">
      <header class="section-head">
        <span class="section-num">02</span>
        <span class="section-tag">WHAT WE DO</span>
      </header>
      <h2 class="section-title">レタスペビレッジで、<br class="br-sm" />できること。</h2>
      <p class="section-lead">
        オンラインで気軽に。リアルでがっつり。<br />
        自分のペースで、川上村と関わりを持てます。
      </p>

      <div class="features-grid">
        {features.map((f) => (
          <div class={`feature ${f.image ? 'feature-with-photo' : ''}`}>
            {f.image && (
              <div class="feature-photo" style={`background-image: url('${f.image}');`} aria-hidden="true"></div>
            )}
            <div class="feature-body">
              <div class="feature-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Gallery -->
    <section class="gallery">
      <div class="gallery-head">
        <span class="gallery-tag">SNAPSHOTS</span>
        <p>活動の記録。</p>
      </div>
      <div class="gallery-grid">
        {gallery.slice(0, 8).map((g) => (
          <div class="gallery-item" style={`background-image: url('${g}');`} aria-hidden="true"></div>
        ))}
      </div>
    </section>

    <!-- Stats -->
    <section id="stats" class="stats">
      <header class="section-head light">
        <span class="section-num">03</span>
        <span class="section-tag">BY THE NUMBERS</span>
      </header>
      <h2 class="section-title light">数字で見る、<br class="br-sm" />レタスペビレッジ。</h2>

      <div class="stats-grid">
        {numbers.map((n) => (
          <div class="stat">
            <p class="stat-value">{n.value}<span class="stat-unit">{n.unit}</span></p>
            <p class="stat-label">{n.label}</p>
            <p class="stat-note">{n.note}</p>
          </div>
        ))}
      </div>
      <p class="stats-foot">
        村内議員・村外大学生・参加者が、自主的に認知活動を展開中。<br />
        コミュニティの広がり方も「自律分散型」です。
      </p>
    </section>

    <!-- News / Press -->
    <section id="news" class="news">
      <header class="section-head">
        <span class="section-num">04</span>
        <span class="section-tag">NEWS &amp; PRESS</span>
      </header>
      <div class="news-top">
        <h2 class="section-title">ニュース・<br class="br-sm" />プレスリリース。</h2>
        <a href="#" class="news-all">すべて見る →</a>
      </div>

      <ul class="news-list">
        {news.map((n) => (
          <li class="news-item">
            <a href={n.href} class="news-link">
              {n.image && (
                <div class="news-thumb" style={`background-image: url('${n.image}');`} aria-hidden="true"></div>
              )}
              <div class="news-meta">
                <time class="news-date">{n.date}</time>
                <span class={`news-tag news-tag-${n.tag}`}>{n.tagLabel}</span>
              </div>
              <div class="news-body">
                <h3 class="news-title">{n.title}</h3>
                <p class="news-excerpt">{n.excerpt}</p>
              </div>
              <span class="news-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Steps -->
    <section id="steps" class="steps">
      <header class="section-head">
        <span class="section-num">05</span>
        <span class="section-tag">HOW TO JOIN</span>
      </header>
      <h2 class="section-title">参加の流れは、3ステップ。</h2>

      <ol class="steps-list">
        {steps.map((s) => (
          <li class="step">
            <div class="step-num">{s.n}</div>
            <div class="step-body">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- Organizers -->
    <section id="profile" class="profile">
      <header class="section-head">
        <span class="section-num">06</span>
        <span class="section-tag">ORGANIZERS</span>
      </header>
      <h2 class="section-title">運営について。</h2>
      <p class="profile-lead">
        レタスペビレッジは、<strong>川上村 地域おこし協力隊員「つっちー」</strong>と、<strong>{organization.name}</strong>の協働で運営されています。
      </p>

      <div class="profile-grid">
        <!-- つっちー -->
        <article class="profile-card">
          <div class="profile-photo" style={`background-image: url('${profile.photo}');`} aria-hidden="true"></div>
          <div class="profile-body">
            <span class="profile-kind">ORGANIZER / PERSON</span>
            <p class="profile-handle">{profile.handle}</p>
            <p class="profile-role">{profile.role} ／ {profile.org}</p>
            <p class="profile-bio">{profile.bio}</p>
            <blockquote class="profile-message">{profile.message}</blockquote>
            <ul class="profile-tags">
              {profile.tags.map((t) => <li>#{t}</li>)}
            </ul>
          </div>
        </article>

        <!-- あるやうむ -->
        <article class="profile-card profile-card-org">
          <div class="profile-org-mark">
            <span class="profile-org-initial">A</span>
            <span class="profile-org-en">{organization.nameEn}</span>
          </div>
          <div class="profile-body">
            <span class="profile-kind">ORGANIZER / COMPANY</span>
            <p class="profile-handle">{organization.name}</p>
            <p class="profile-role">{organization.role}</p>
            <p class="profile-bio">{organization.bio}</p>
            <a href={organization.url} target="_blank" rel="noopener" class="profile-link">
              <span>{organization.urlLabel}</span>
              <span aria-hidden="true">↗</span>
            </a>
            <ul class="profile-tags">
              {organization.tags.map((t) => <li>#{t}</li>)}
            </ul>
          </div>
        </article>
      </div>
    </section>

    <!-- FAQ -->
    <section id="faq" class="faq">
      <header class="section-head">
        <span class="section-num">07</span>
        <span class="section-tag">FAQ</span>
      </header>
      <h2 class="section-title">よくある質問</h2>

      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>
              <span>{f.q}</span>
              <span class="faq-icon" aria-hidden="true">＋</span>
            </summary>
            <div class="faq-body">{f.a}</div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section id="cta" class="cta">
      <div class="cta-emoji cta-emoji-1" aria-hidden="true">🥬</div>
      <div class="cta-emoji cta-emoji-2" aria-hidden="true">🚀</div>
      <div class="cta-inner">
        <p class="cta-eyebrow">JOIN LETTUCE-VILLE</p>
        <h2>日本一の村の<br class="br-sm" />101人目に、<br />あなたを待っています。</h2>
        <p class="cta-lead">
          「ちょっと興味あるかも」のテンションで大丈夫。<br />
          まずはLINEオープンチャットを覗いてみてください。
        </p>
        <a href={community.lineUrl} class="btn btn-primary btn-xl">
          <span>LINEオープンチャットに参加する</span>
          <span class="btn-arrow">→</span>
        </a>
        <p class="cta-note">登録無料／いつでも退出OK／顔出し不要</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <div>
          <p class="footer-name">
            <span class="nav-mark">🥬</span> {community.name}
          </p>
          <p class="footer-note">{community.prefecture}{community.village}DAOコミュニティ</p>
          <p class="footer-note">
            運営：<a href={organization.url} target="_blank" rel="noopener">{organization.name}</a> ／ {community.operator}
          </p>
        </div>
        <div class="footer-meta">
          <p>{community.prefecture}{community.district} {community.village}</p>
          <p>© 2026 {community.name} / {organization.nameEn}</p>
        </div>
      </div>
      <div class="footer-bottom">
        <a href="/municipalities/kawakami">← デザイン10案カタログ</a>
        <a href="/municipalities">自治体一覧</a>
      </div>
    </footer>

    <a href={community.lineUrl} class="sticky-cta">LINEで参加する →</a>
  </div>
</Base>

<style>
  /* ============ Tokens ============ */
  .page {
    --lettuce-50:  #f1faec;
    --lettuce-100: #dff3d2;
    --lettuce-300: #9bd175;
    --lettuce-500: #4ea83a;
    --lettuce-600: #3d8a2c;
    --lettuce-700: #2f6d22;
    --lettuce-900: #163810;

    --cosmos-500: #3b3f8a;
    --cosmos-700: #262a63;
    --cosmos-900: #0f1238;

    --cream:   #fbf7ee;
    --paper:   #ffffff;
    --line:    #d9e7cf;
    --ink:     #163810;
    --ink-soft:#3d5630;
    --ink-mute:#75897a;
    --gold:    #f5c14a;

    color: var(--ink);
    background: var(--cream);
    font-family: 'Noto Sans JP', sans-serif;
    min-height: 100vh;
  }

  /* ============ Buttons ============ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: 999px;
    border: 2px solid var(--lettuce-900);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s, color 0.2s;
  }
  .btn-primary {
    background: var(--lettuce-500);
    color: #fff;
    box-shadow: 5px 5px 0 var(--lettuce-900);
  }
  .btn-primary:hover { transform: translate(-2px, -2px); box-shadow: 8px 8px 0 var(--lettuce-900); }
  .btn-ghost { background: var(--cream); color: var(--ink); }
  .btn-ghost:hover { background: var(--lettuce-100); }
  .btn-lg  { padding: 18px 34px; font-size: 1rem; }
  .btn-xl  { padding: 22px 44px; font-size: 1.1rem; box-shadow: 7px 7px 0 var(--lettuce-900); }
  .btn-xl:hover { box-shadow: 10px 10px 0 var(--lettuce-900); }
  .btn-arrow { font-family: 'Inter', sans-serif; }

  /* ============ Nav ============ */
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 32px;
    background: rgba(251, 247, 238, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--lettuce-100);
  }
  .nav-logo { display: inline-flex; align-items: center; gap: 10px; font-weight: 900; color: var(--lettuce-900); }
  .nav-mark {
    display: inline-flex;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at 35% 35%, var(--lettuce-300) 0%, var(--lettuce-500) 55%, var(--lettuce-700) 100%);
    border-radius: 50%;
    font-size: 1.1rem;
    box-shadow: 3px 3px 0 var(--lettuce-900);
  }
  .nav-text { letter-spacing: 0.05em; }
  .nav-links { display: flex; align-items: center; gap: 24px; font-size: 0.85rem; font-weight: 700; color: var(--ink-soft); }
  .nav-links a:hover { color: var(--lettuce-500); }
  .nav-cta {
    padding: 8px 18px;
    background: var(--lettuce-500);
    color: #fff !important;
    border-radius: 999px;
    box-shadow: 3px 3px 0 var(--lettuce-900);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .nav-cta:hover { transform: translate(-1px, -1px); box-shadow: 5px 5px 0 var(--lettuce-900); }

  /* ============ Hero ============ */
  .hero {
    position: relative;
    padding: 140px 32px 120px;
    background:
      radial-gradient(circle at 18% 30%, rgba(78, 168, 58, 0.18) 0, transparent 22%),
      radial-gradient(circle at 82% 60%, rgba(78, 168, 58, 0.14) 0, transparent 22%),
      var(--cream);
    overflow: hidden;
  }
  .hero-blob { position: absolute; border-radius: 50%; filter: blur(60px); pointer-events: none; opacity: 0.4; }
  .hero-blob-1 { width: 360px; height: 360px; background: var(--lettuce-300); top: -100px; left: -120px; }
  .hero-blob-2 { width: 280px; height: 280px; background: var(--cosmos-500); bottom: -80px; right: -100px; opacity: 0.25; }
  .hero-emoji { position: absolute; pointer-events: none; user-select: none; line-height: 1; animation: float-y 5s ease-in-out infinite; }
  .hero-emoji-1 { top: 130px; right: 8%; font-size: 5.5rem; }
  .hero-emoji-2 { bottom: 80px; left: 6%; font-size: 4.5rem; animation-delay: 1s; }
  .hero-emoji-3 { top: 45%; left: 55%; font-size: 2rem; animation-delay: 2s; }
  @keyframes float-y { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }

  .hero-inner { position: relative; z-index: 1; max-width: 880px; margin: 0 auto; text-align: center; }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 8px 18px;
    background: #fff;
    border: 2px solid var(--lettuce-900);
    border-radius: 999px;
    font-size: 0.78rem; font-weight: 700;
    color: var(--lettuce-900);
    box-shadow: 4px 4px 0 var(--lettuce-900);
    margin-bottom: 28px;
  }
  .hero-badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--lettuce-500); animation: pulse 1.5s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.4); opacity: 0.6; } }

  .hero-title { font-family: 'Noto Serif JP', serif; font-size: clamp(2.4rem, 6vw, 4.6rem); font-weight: 900; line-height: 1.3; color: var(--lettuce-900); margin-bottom: 24px; }
  .hero-lead { font-size: 1rem; line-height: 2; color: var(--ink-soft); max-width: 620px; margin: 0 auto 36px; }
  .hero-actions { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }
  .hero-note { margin-top: 24px; font-size: 0.78rem; color: var(--ink-mute); }

  /* ============ Section common ============ */
  .section-head { display: inline-flex; align-items: center; gap: 12px; margin-bottom: 18px; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 700; color: var(--ink-mute); }
  .section-head .section-num { padding: 4px 10px; background: var(--lettuce-900); color: var(--cream); border-radius: 4px; }
  .section-head.light { color: rgba(251,247,238,0.7); }
  .section-head.light .section-num { background: var(--gold); color: var(--cosmos-900); }
  .section-tag { letter-spacing: 0.18em; text-transform: uppercase; }
  .section-title { font-family: 'Noto Serif JP', serif; font-size: clamp(2rem, 4.5vw, 3.2rem); font-weight: 900; line-height: 1.5; color: var(--lettuce-900); margin-bottom: 20px; }
  .section-title.light { color: var(--cream); }
  .section-lead { font-size: 0.95rem; line-height: 2; color: var(--ink-soft); margin-bottom: 56px; max-width: 620px; }
  .br-sm { display: none; }

  /* ============ About ============ */
  .about { max-width: 1100px; margin: 0 auto; padding: 120px 32px; text-align: center; }
  .about .section-head { justify-content: center; }
  .about .section-lead { margin-left: auto; margin-right: auto; }
  .about-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 28px; text-align: left; }
  .concept { position: relative; padding: 0; border-radius: 28px; border: 2px solid var(--lettuce-900); box-shadow: 6px 6px 0 var(--lettuce-900); overflow: hidden; display: flex; flex-direction: column; }
  .concept-body { padding: 40px 36px; position: relative; }
  .concept-lettuce { background: #fff; color: var(--ink); }
  .concept-lettuce::before {
    content: ''; position: absolute; top: -60px; right: -60px;
    width: 180px; height: 180px; border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, var(--lettuce-300) 0%, var(--lettuce-500) 55%, var(--lettuce-700) 100%);
    opacity: 0.25;
    z-index: 0;
  }
  .concept-cosmos {
    background:
      radial-gradient(1px 1px at 25% 30%, rgba(255,255,255,0.85), transparent),
      radial-gradient(1px 1px at 70% 60%, rgba(255,255,255,0.7), transparent),
      radial-gradient(1.5px 1.5px at 45% 85%, rgba(255,255,255,0.85), transparent),
      var(--cosmos-900);
    color: var(--cream);
    border-color: var(--cosmos-900);
    box-shadow: 6px 6px 0 var(--cosmos-900);
  }
  .concept-photo {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    border-bottom: 2px solid var(--cosmos-900);
  }
  .concept-emoji { position: relative; font-size: 3.4rem; margin-bottom: 18px; z-index: 1; }
  .concept h3 { position: relative; font-family: 'Noto Serif JP', serif; font-size: 1.6rem; font-weight: 900; line-height: 1.5; margin-bottom: 14px; z-index: 1; }
  .concept p { position: relative; font-size: 0.92rem; line-height: 2; margin-bottom: 22px; z-index: 1; }
  .concept-cosmos p { color: rgba(251,247,238,0.85); }
  .concept ul { position: relative; list-style: none; display: flex; flex-direction: column; gap: 8px; font-size: 0.85rem; z-index: 1; }
  .concept li { display: flex; align-items: flex-start; gap: 10px; }
  .concept-lettuce li span { color: var(--lettuce-500); }
  .concept-cosmos li span  { color: var(--gold); }

  /* ============ Features ============ */
  .features { max-width: 1100px; margin: 0 auto; padding: 100px 32px; text-align: center; border-top: 2px dashed var(--line); }
  .features .section-head { justify-content: center; }
  .features .section-lead { margin-left: auto; margin-right: auto; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; text-align: left; }
  .feature { background: #fff; border: 2px solid var(--lettuce-900); border-radius: 20px; overflow: hidden; box-shadow: 4px 4px 0 var(--lettuce-900); transition: transform 0.25s ease; display: flex; flex-direction: column; }
  .feature:hover { transform: translateY(-4px); }
  .feature-photo { width: 100%; aspect-ratio: 16 / 10; background-size: cover; background-position: center; border-bottom: 2px solid var(--lettuce-900); }
  .feature-body { padding: 24px 22px; }
  .feature-with-photo .feature-icon { font-size: 1.8rem; margin-bottom: 10px; }
  .feature-icon { font-size: 2.4rem; margin-bottom: 14px; }
  .feature h3 { font-size: 1.05rem; font-weight: 700; color: var(--lettuce-900); margin-bottom: 10px; }
  .feature p { font-size: 0.85rem; line-height: 1.9; color: var(--ink-soft); }

  /* ============ Gallery ============ */
