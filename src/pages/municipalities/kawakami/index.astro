---
import Base from '../../../layouts/Base.astro';
import { community, variants } from '../../../data/kawakami.ts';

// ステータス管理: 完成済みのスラグだけリスト化
const ready = new Set(['v1-wa-modern']);
---

<Base title={`${community.name} デザイン10案 — ${community.prefecture}${community.village}DAO`}>
  <main class="catalog">
    <header class="header">
      <p class="eyebrow">Kawakami / Design Variants</p>
      <h1>{community.name}<br /><span>デザイン10案カタログ</span></h1>
      <p class="lead">
        {community.prefecture}{community.village}DAO「{community.name}」のランディングページを、
        10種類のデザイン方向性で並べました。担当者と見比べて、採用案を決めるためのカタログです。
      </p>
      <div class="header-links">
        <a href="/municipalities/kawakami" class="link link-primary">→ 現行採用案 (メイン)</a>
        <a href="/municipalities" class="link">← 自治体一覧</a>
        <a href="/" class="link">← デザインたたき台一覧</a>
      </div>
    </header>

    <ul class="grid">
      {variants.map((v) => {
        const isReady = ready.has(v.slug);
        return (
          <li class="card" style={`--accent: ${v.accent};`}>
            {isReady ? (
              <a href={`/municipalities/kawakami/${v.slug}`}>
                <span class="num">{v.n}</span>
                <h2>{v.title}</h2>
                <p>{v.desc}</p>
                <span class="status status-ready">公開中 →</span>
              </a>
            ) : (
              <div class="card-disabled">
                <span class="num">{v.n}</span>
                <h2>{v.title}</h2>
                <p>{v.desc}</p>
                <span class="status status-pending">準備中</span>
              </div>
            )}
          </li>
        );
      })}
    </ul>
  </main>
</Base>

<style>
  .catalog {
    min-height: 100vh;
    background: #fafaf8;
    padding: 80px 32px;
    font-family: 'Noto Sans JP', sans-serif;
    color: #1a1a1a;
    max-width: 1280px;
    margin: 0 auto;
  }
  .header { margin-bottom: 56px; }
  .eyebrow { font-family: 'Inter', sans-serif; font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase; color: #999; margin-bottom: 16px; }
  h1 { font-family: 'Noto Serif JP', serif; font-size: clamp(2rem, 5vw, 3.4rem); font-weight: 900; line-height: 1.3; margin-bottom: 12px; }
  h1 span { font-weight: 300; font-size: 0.5em; color: #888; display: block; margin-top: 8px; font-family: 'Inter', sans-serif; letter-spacing: 0.06em; text-transform: uppercase; }
  .lead { color: #666; font-size: 0.95rem; max-width: 640px; line-height: 2; margin-bottom: 28px; }
  .header-links { display: flex; gap: 18px; flex-wrap: wrap; font-size: 0.85rem; }
  .link {
    display: inline-block;
    padding: 8px 16px;
    border: 1px solid #ccc;
    border-radius: 999px;
    color: #555;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .link:hover { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
  .link-primary { background: #4ea83a; color: #fff; border-color: #4ea83a; font-weight: 700; }
  .link-primary:hover { background: #2f6d22; border-color: #2f6d22; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    list-style: none;
  }
  .card {
    background: #fff;
    border: 1px solid #e8e8e4;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }
  .card:hover { transform: translateY(-6px); box-shadow: 0 18px 50px rgba(0, 0, 0, 0.08); }
  .card a, .card-disabled {
    display: block;
    padding: 36px 28px;
    color: inherit;
    position: relative;
  }
  .card-disabled { opacity: 0.55; cursor: default; }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .card:hover::before { transform: scaleX(1); }
  .num { font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 600; color: #ccc; letter-spacing: 0.1em; display: block; margin-bottom: 14px; }
  .card h2 { font-family: 'Noto Serif JP', serif; font-size: 1.4rem; font-weight: 700; margin-bottom: 10px; }
  .card p { font-size: 0.85rem; color: #666; line-height: 1.85; margin-bottom: 18px; min-height: 3.7em; }
  .status { display: inline-block; font-size: 0.72rem; padding: 4px 12px; border-radius: 100px; font-weight: 600; }
  .status-ready { color: var(--accent); border: 1px solid var(--accent); }
  .status-pending { color: #999; border: 1px solid #ddd; background: #fafafa; }

  @media (max-width: 600px) {
    .catalog { padding: 48px 22px; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
