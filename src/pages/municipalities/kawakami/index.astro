---
import Base from '../../../layouts/Base.astro';
import { community, variants, images } from '../../../data/kawakami.ts';

// 完成済みのスラグ
const ready = new Set(['v1', 'v2', 'v3', 'v4', 'v5', 'v6', 'v7', 'v8', 'v9', 'v10']);
---

<Base title={`${community.name} デザイン10案 — ${community.prefecture}${community.village}DAO`}>
  <main class="catalog">
    <header class="header">
      <p class="eyebrow">{community.prefecture}{community.village} ／ Design Variants</p>
      <h1>{community.name}<br /><span>デザイン10案カタログ</span></h1>
      <p class="lead">
        {community.prefecture}{community.village}DAO「{community.name}」のランディングページを、
        10種類のデザイン方向性で並べました。<br />
        担当者と見比べて、採用案を決めるためのカタログです。
      </p>
      <div class="header-links">
        <a href="/municipalities/kawakami/main" class="link link-primary">→ 採用案メイン (現行)</a>
        <a href="/municipalities" class="link">← 自治体一覧</a>
      </div>
    </header>

    <ul class="grid">
      {variants.map((v) => {
        const isReady = ready.has(v.slug);
        return (
          <li class="card" style={`--accent: ${v.accent};`}>
            {isReady ? (
              <a href={`/municipalities/kawakami/${v.slug}`}>
                <span class="card-num">{v.n}</span>
                <h2>{v.title}</h2>
                <p>{v.desc}</p>
                <span class="status status-ready">公開中 →</span>
              </a>
            ) : (
              <div class="card-disabled">
                <span class="card-num">{v.n}</span>
                <h2>{v.title}</h2>
                <p>{v.desc}</p>
                <span class="status status-pending">準備中</span>
              </div>
            )}
          </li>
        );
      })}
    </ul>
  </main>
</Base>

<style>
  .catalog {
    min-height: 100vh;
    background: #fafaf8;
    padding: 64px 32px 80px;
    font-family: 'Noto Sans JP', sans-serif;
    color: #1a1a1a;
    max-width: 1280px;
    margin: 0 auto;
  }
  .header { margin-bottom: 48px; }
  .eyebrow { font-family: 'Inter', sans-serif; font-size: 0.7rem; letter-spacing: 0.22em; text-transform: uppercase; color: #999; margin-bottom: 14px; }
  h1 { font-family: 'Noto Serif JP', serif; font-size: clamp(1.8rem, 4.4vw, 3rem); font-weight: 900; line-height: 1.35; margin-bottom: 12px; }
  h1 span { font-weight: 300; font-size: 0.5em; color: #888; display: block; margin-top: 8px; font-family: 'Inter', sans-serif; letter-spacing: 0.06em; text-transform: uppercase; }
  .lead { color: #666; font-size: 0.9rem; max-width: 640px; line-height: 1.95; margin-bottom: 24px; }
  .header-links { display: flex; gap: 14px; flex-wrap: wrap; font-size: 0.82rem; }
  .link { display: inline-block; padding: 8px 16px; border: 1px solid #ccc; border-radius: 999px; color: #555; transition: background 0.2s, color 0.2s, border-color 0.2s; }
  .link:hover { background: #1a1a1a; color: #fff; border-color: #1a1a1a; }
  .link-primary { background: #4ea83a; color: #fff; border-color: #4ea83a; font-weight: 700; }
  .link-primary:hover { background: #2f6d22; border-color: #2f6d22; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
    list-style: none;
  }
  .card {
    background: #fff;
    border: 1px solid #e8e8e4;
    border-radius: 10px;
    overflow: hidden;
    position: relative;
    transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
  }
  .card:hover { transform: translateY(-4px); box-shadow: 0 14px 40px rgba(0, 0, 0, 0.07); }
  .card a, .card-disabled { display: block; padding: 22px 20px; color: inherit; position: relative; }
  .card-disabled { opacity: 0.55; cursor: default; }
  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .card:hover::before { transform: scaleX(1); }
  .card-num { font-family: 'Inter', sans-serif; font-size: 0.7rem; font-weight: 700; color: var(--accent); letter-spacing: 0.1em; display: block; margin-bottom: 8px; }
  .card h2 { font-family: 'Noto Serif JP', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 8px; line-height: 1.45; }
  .card p { font-size: 0.78rem; color: #777; line-height: 1.7; margin-bottom: 14px; min-height: 4em; }
  .status { display: inline-block; font-size: 0.68rem; padding: 3px 10px; border-radius: 100px; font-weight: 600; }
  .status-ready { color: var(--accent); border: 1px solid var(--accent); }
  .status-pending { color: #999; border: 1px solid #ddd; background: #fafafa; }

  @media (max-width: 600px) {
    .catalog { padding: 40px 18px 60px; }
    .grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 12px; }
    .card a, .card-disabled { padding: 18px 16px; }
    .card h2 { font-size: 0.98rem; }
    .card p { font-size: 0.74rem; min-height: 0; -webkit-line-clamp: 3; display: -webkit-box; -webkit-box-orient: vertical; overflow: hidden; }
  }
</style>
