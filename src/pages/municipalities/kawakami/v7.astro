---
import Base from '../../../layouts/Base.astro';
import { community, numbers, features, news, images, gallery } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (グラスモーフィズム案) — ${community.prefecture}${community.village}`}>
  <div class="glass">
    <div class="bg-orbs" aria-hidden="true">
      <span class="orb orb-1"></span><span class="orb orb-2"></span><span class="orb orb-3"></span><span class="orb orb-4"></span>
    </div>

    <nav class="nav">
      <div class="nav-inner">
        <div class="nav-logo"><span class="logo-mark"></span>{community.name}</div>
        <div class="nav-links">
          <a href="#about">About</a>
          <a href="#features">Features</a>
          <a href="#news">News</a>
          <a href={community.lineUrl} class="nav-cta">Join</a>
        </div>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-card">
        <span class="hero-tag">KAWAKAMI × DAO × COMMUNITY</span>
        <h1>レタスから、<br /><span class="grad-text">宇宙</span>まで。</h1>
        <p class="hero-desc">{community.lead}</p>
        <div class="hero-actions">
          <a href={community.lineUrl} class="btn-primary">LINEで参加する →</a>
          <a href="#about" class="btn-ghost">詳しく見る</a>
        </div>
      </div>
      <div class="hero-photo">
        <div class="hero-img" style={`background-image: url('${images.hero}');`}></div>
        <div class="float-card float-card-1">
          <span class="float-dot"></span>
          <div><div class="float-k">{numbers[0].value}{numbers[0].unit}</div><div class="float-v">{numbers[0].label}</div></div>
        </div>
        <div class="float-card float-card-2">
          <span class="float-dot float-dot-2"></span>
          <div><div class="float-k">DAO</div><div class="float-v">分散型コミュニティ</div></div>
        </div>
      </div>
    </section>

    <section id="about" class="about">
      <div class="about-card">
        <div class="section-head"><span class="section-num">01</span><span class="section-title">About</span></div>
        <h2>{community.name}<br />とは何か</h2>
        <p>{community.lead}<br />2025年1月のオプチャ開設から、最短記録で100名を突破しました。</p>
        <div class="stats">
          {numbers.slice(0, 3).map((n, i) => (
            <>
              {i > 0 && <div class="stat-divider"></div>}
              <div class="stat">
                <span class="stat-num">{n.value}{n.unit}</span>
                <span class="stat-label">{n.label}</span>
              </div>
            </>
          ))}
        </div>
      </div>
    </section>

    <section id="features" class="features">
      <div class="section-head section-head-center"><span class="section-num">02</span><span class="section-title">Features</span></div>
      <h2 class="features-title">関わる方法は、<span class="grad-text">いろいろ。</span></h2>
      <div class="f-cards">
        {features.map((f) => (
          <div class="f-card">
            {f.image && <div class="f-img" style={`background-image: url('${f.image}');`}></div>}
            <div class="f-body">
              <div class="f-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="news" class="news">
      <div class="section-head section-head-center"><span class="section-num">03</span><span class="section-title">News</span></div>
      <h2 class="features-title">ニュース・<span class="grad-text">プレスリリース。</span></h2>
      <ul>
        {news.map((n) => (
          <li class="n-card">
            <a href={n.href}>
              {n.image && <div class="n-img" style={`background-image: url('${n.image}');`}></div>}
              <div class="n-body">
                <div class="n-meta"><time>{n.date}</time><span class={`n-tag n-tag-${n.tag}`}>{n.tagLabel}</span></div>
                <h3>{n.title}</h3>
                <p>{n.excerpt}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="cta">
      <div class="cta-card">
        <p class="cta-label">Join the DAO</p>
        <h2>あなたの<br /><span class="grad-text">「興味あるかも」</span>を、<br />ここから始めよう。</h2>
        <p class="cta-desc">まずはLINEオープンチャットを覗いてみてください。<br />匿名OK・退出自由です。</p>
        <a href={community.lineUrl} class="btn-primary btn-large">LINEオープンチャットに参加 →</a>
        <p class="cta-note">運営: {community.operator}</p>
      </div>
    </section>

    <a href="/municipalities/kawakami" class="back-link">← 川上村LP一覧に戻る</a>
  </div>
</Base>

<style>
  .glass {
    font-family: 'Noto Sans JP', sans-serif;
    color: #ffffff;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 10%, #4c6ef5 0%, transparent 45%),
      radial-gradient(ellipse at 80% 20%, #c084fc 0%, transparent 45%),
      radial-gradient(ellipse at 70% 80%, #f093fb 0%, transparent 45%),
      linear-gradient(135deg, #1e1b4b 0%, #312e81 35%, #5b21b6 70%, #9333ea 100%);
  }

  .bg-orbs { position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden; }
  .orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.5; animation: float 18s ease-in-out infinite; }
  .orb-1 { width: 420px; height: 420px; background: #667eea; top: -120px; left: -100px; }
  .orb-2 { width: 520px; height: 520px; background: #f093fb; top: 30%; right: -180px; animation-delay: -6s; }
  .orb-3 { width: 360px; height: 360px; background: #764ba2; bottom: 10%; left: 20%; animation-delay: -3s; }
  .orb-4 { width: 280px; height: 280px; background: #60a5fa; bottom: -80px; right: 25%; animation-delay: -9s; }
  @keyframes float { 0%, 100% { transform: translate(0, 0) scale(1); } 33% { transform: translate(40px, -30px) scale(1.05); } 66% { transform: translate(-30px, 40px) scale(0.95); } }

  .nav { position: fixed; top: 16px; left: 16px; right: 16px; z-index: 100; display: flex; justify-content: center; }
  .nav-inner { display: flex; justify-content: space-between; align-items: center; width: 100%; max-width: 1100px; padding: 14px 24px; background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.18); border-radius: 999px; box-shadow: 0 8px 32px rgba(31, 38, 135, 0.2); }
  .nav-logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 0.95rem; letter-spacing: 0.05em; }
  .logo-mark { width: 14px; height: 14px; border-radius: 4px; background: linear-gradient(135deg, #f093fb, #4c6ef5); box-shadow: 0 0 16px rgba(240, 147, 251, 0.6); }
  .nav-links { display: flex; gap: 24px; font-size: 0.85rem; align-items: center; }
  .nav-links a { color: rgba(255, 255, 255, 0.85); transition: color 0.3s; }
  .nav-links a:hover { color: #fff; }
  .nav-cta { padding: 6px 16px; background: rgba(255, 255, 255, 0.15); border-radius: 999px; }

  .hero { position: relative; z-index: 1; min-height: 100vh; display: grid; grid-template-columns: 1.1fr 0.9fr; align-items: center; gap: 40px; padding: 130px 48px 80px; max-width: 1200px; margin: 0 auto; }
  .hero-card { padding: 44px; background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.18); border-radius: 28px; box-shadow: 0 20px 60px rgba(31, 38, 135, 0.25); }
  .hero-tag { display: inline-block; font-family: 'Inter', sans-serif; font-size: 0.7rem; letter-spacing: 0.22em; color: rgba(255, 255, 255, 0.78); padding: 6px 14px; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 999px; margin-bottom: 26px; }
  .hero-card h1 { font-size: clamp(2.2rem, 4.5vw, 3.6rem); font-weight: 700; line-height: 1.4; margin-bottom: 22px; letter-spacing: 0.02em; }
  .grad-text { background: linear-gradient(135deg, #f9a8d4 0%, #c084fc 50%, #93c5fd 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .hero-desc { font-size: 0.95rem; line-height: 2; color: rgba(255, 255, 255, 0.82); font-weight: 300; margin-bottom: 32px; }
  .hero-actions { display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 30px; background: linear-gradient(135deg, #f093fb 0%, #764ba2 100%); color: #fff; font-size: 0.9rem; font-weight: 500; letter-spacing: 0.06em; border-radius: 999px; border: 1px solid rgba(255, 255, 255, 0.25); box-shadow: 0 8px 24px rgba(240, 147, 251, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.3); transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(240, 147, 251, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.3); }
  .btn-large { padding: 18px 44px; font-size: 0.95rem; }
  .btn-ghost { color: rgba(255, 255, 255, 0.85); font-size: 0.88rem; padding: 14px 18px; }
  .btn-ghost:hover { color: #fff; }

  .hero-photo { position: relative; height: 440px; }
  .hero-img { position: absolute; inset: 0; background-size: cover; background-position: center; border-radius: 24px; border: 1px solid rgba(255, 255, 255, 0.2); box-shadow: 0 20px 60px rgba(31, 38, 135, 0.4); }
  .float-card { position: absolute; display: flex; align-items: center; gap: 14px; padding: 16px 20px; background: rgba(255, 255, 255, 0.12); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.25); border-radius: 18px; box-shadow: 0 12px 40px rgba(31, 38, 135, 0.25); animation: float 8s ease-in-out infinite; }
  .float-card-1 { top: 30px; left: -20px; }
  .float-card-2 { bottom: 30px; right: -10px; animation-delay: -4s; }
  .float-dot { width: 10px; height: 10px; border-radius: 50%; background: #86efac; box-shadow: 0 0 12px #86efac; }
  .float-dot-2 { background: #f9a8d4; box-shadow: 0 0 12px #f9a8d4; }
  .float-k { font-family: 'Inter', sans-serif; font-size: 1.3rem; font-weight: 700; }
  .float-v { font-size: 0.7rem; color: rgba(255, 255, 255, 0.78); letter-spacing: 0.05em; }

  .section-head { display: flex; align-items: center; gap: 14px; margin-bottom: 22px; }
  .section-head-center { justify-content: center; }
  .section-num { font-family: 'Inter', sans-serif; font-size: 0.72rem; color: rgba(255, 255, 255, 0.6); letter-spacing: 0.15em; }
  .section-title { font-family: 'Inter', sans-serif; font-size: 0.78rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255, 255, 255, 0.85); padding: 4px 12px; background: rgba(255, 255, 255, 0.1); border: 1px solid rgba(255, 255, 255, 0.18); border-radius: 999px; }

  .about { position: relative; z-index: 1; padding: 80px 48px; max-width: 1100px; margin: 0 auto; }
  .about-card { padding: 56px; background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.18); border-radius: 32px; box-shadow: 0 20px 60px rgba(31, 38, 135, 0.2); }
  .about-card h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1.6; margin-bottom: 24px; font-weight: 700; }
  .about-card p { font-size: 0.95rem; line-height: 2.1; color: rgba(255, 255, 255, 0.82); font-weight: 300; max-width: 680px; }
  .stats { display: flex; align-items: center; gap: 36px; margin-top: 40px; padding-top: 34px; border-top: 1px solid rgba(255, 255, 255, 0.15); }
  .stat { display: flex; flex-direction: column; gap: 6px; }
  .stat-num { font-size: 1.8rem; font-weight: 700; font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #fff 0%, #c7d2fe 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }
  .stat-label { font-size: 0.75rem; color: rgba(255, 255, 255, 0.7); }
  .stat-divider { width: 1px; height: 40px; background: rgba(255, 255, 255, 0.18); }

  .features { position: relative; z-index: 1; padding: 110px 48px; max-width: 1200px; margin: 0 auto; text-align: center; }
  .features-title { font-size: clamp(1.7rem, 3.2vw, 2.6rem); line-height: 1.6; margin: 22px auto 56px; font-weight: 700; max-width: 820px; }
  .f-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; text-align: left; }
  .f-card { background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 22px; box-shadow: 0 12px 40px rgba(31, 38, 135, 0.2); transition: transform 0.3s, border-color 0.3s; overflow: hidden; }
  .f-card:hover { transform: translateY(-4px); border-color: rgba(255, 255, 255, 0.3); }
  .f-img { aspect-ratio: 16/10; background-size: cover; background-position: center; border-bottom: 1px solid rgba(255, 255, 255, 0.15); }
  .f-body { padding: 26px 24px; }
  .f-icon { font-size: 1.6rem; margin-bottom: 12px; }
  .f-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; }
  .f-card p { font-size: 0.84rem; line-height: 1.95; color: rgba(255, 255, 255, 0.78); font-weight: 300; }

  .news { position: relative; z-index: 1; padding: 80px 48px; max-width: 1100px; margin: 0 auto; text-align: center; }
  .news ul { list-style: none; display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; text-align: left; }
  .n-card { background: rgba(255, 255, 255, 0.08); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 22px; overflow: hidden; transition: transform 0.3s; }
  .n-card:hover { transform: translateY(-4px); }
  .n-card a { display: block; color: inherit; }
  .n-img { aspect-ratio: 16/10; background-size: cover; background-position: center; }
  .n-body { padding: 22px 24px; }
  .n-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 8px; }
  .n-meta time { font-family: 'Inter', sans-serif; font-size: 0.78rem; color: rgba(255, 255, 255, 0.65); }
  .n-tag { font-size: 0.66rem; padding: 2px 8px; border-radius: 4px; letter-spacing: 0.06em; }
  .n-tag-press { background: rgba(255, 255, 255, 0.85); color: #1e1b4b; }
  .n-tag-event { background: rgba(240, 147, 251, 0.85); color: #1e1b4b; }
  .n-tag-milestone { background: rgba(134, 239, 172, 0.85); color: #1e1b4b; }
  .n-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; line-height: 1.5; }
  .n-card p { font-size: 0.82rem; line-height: 1.85; color: rgba(255, 255, 255, 0.7); font-weight: 300; }

  .cta { position: relative; z-index: 1; padding: 80px 48px 110px; max-width: 900px; margin: 0 auto; }
  .cta-card { padding: 64px 44px; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(24px); border: 1px solid rgba(255, 255, 255, 0.22); border-radius: 32px; box-shadow: 0 20px 60px rgba(31, 38, 135, 0.3); text-align: center; }
  .cta-label { font-family: 'Inter', sans-serif; font-size: 0.75rem; letter-spacing: 0.22em; text-transform: uppercase; color: rgba(255, 255, 255, 0.7); margin-bottom: 22px; }
  .cta-card h2 { font-size: clamp(1.6rem, 3vw, 2.4rem); line-height: 1.6; margin-bottom: 24px; font-weight: 700; }
  .cta-desc { font-size: 0.9rem; line-height: 2; color: rgba(255, 255, 255, 0.78); font-weight: 300; margin-bottom: 36px; }
  .cta-note { margin-top: 24px; font-size: 0.75rem; color: rgba(255, 255, 255, 0.6); }

  .back-link { position: relative; z-index: 1; display: block; text-align: center; padding: 28px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: rgba(255, 255, 255, 0.65); border-top: 1px solid rgba(255, 255, 255, 0.1); }
  .back-link:hover { color: #fff; }

  @media (max-width: 768px) {
    .nav { top: 12px; left: 12px; right: 12px; }
    .nav-inner { padding: 10px 18px; }
    .nav-links { gap: 14px; font-size: 0.78rem; }
    .hero { grid-template-columns: 1fr; padding: 110px 22px 60px; gap: 24px; min-height: auto; }
    .hero-card { padding: 30px 24px; border-radius: 22px; }
    .hero-photo { height: 280px; }
    .float-card { padding: 12px 16px; }
    .float-card-1 { left: 8px; }
    .float-card-2 { right: 8px; }
    .about, .features, .news, .cta { padding: 60px 22px; }
    .about-card { padding: 32px 24px; border-radius: 22px; }
    .stats { flex-direction: column; align-items: flex-start; gap: 16px; }
    .stat-divider { display: none; }
    .f-cards, .news ul { grid-template-columns: 1fr; }
    .cta-card { padding: 40px 22px; }
    .orb { filter: blur(60px); opacity: 0.4; }
    .orb-1, .orb-2, .orb-3, .orb-4 { width: 240px; height: 240px; }
  }
</style>
