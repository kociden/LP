---
import Base from '../../../layouts/Base.astro';
import { community, numbers, features, news, images, gallery, profile, organization } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (ダークモード案) — ${community.prefecture}${community.village}`}>
  <div class="dark">
    <nav class="nav">
      <div class="nav-logo">
        <span class="logo-mark">
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none">
            <circle cx="10" cy="10" r="9" stroke="#00D4AA" stroke-width="1.5"/>
            <circle cx="10" cy="10" r="3" fill="#00D4AA"/>
          </svg>
        </span>
        <span>{community.name}</span>
      </div>
      <div class="nav-links">
        <a href="#mission">Mission</a>
        <a href="#features">Features</a>
        <a href="#news">News</a>
        <a href={community.lineUrl} class="nav-btn">Join</a>
      </div>
    </nav>

    <section class="hero" style={`background-image: linear-gradient(180deg, rgba(10,10,10,0.4) 0%, rgba(10,10,10,0.95) 100%), url('${images.cosmos}');`}>
      <div class="hero-grid-bg"></div>
      <div class="hero-glow"></div>
      <div class="hero-content">
        <div class="hero-badge"><span class="hero-badge-dot"></span>{community.prefecture}{community.village} DAO Community</div>
        <h1>レタスから、<br /><span class="gradient-text">宇宙</span>まで。</h1>
        <p class="hero-desc">{community.lead}</p>
        <div class="hero-actions">
          <a href={community.lineUrl} class="btn-primary">LINEで参加 →</a>
          <a href="#mission" class="btn-ghost">Learn more</a>
        </div>
      </div>
      <div class="hero-stats">
        {numbers.slice(0, 3).map((n, i) => (
          <>
            {i > 0 && <div class="hero-stat-divider"></div>}
            <div class="hero-stat">
              <span class="hero-stat-num">{n.value}{n.unit}</span>
              <span class="hero-stat-label">{n.label}</span>
            </div>
          </>
        ))}
      </div>
    </section>

    <section id="mission" class="mission">
      <div class="mission-inner">
        <span class="section-label">Mission</span>
        <h2>関係人口を、<br />分散型でデザインする。</h2>
        <p>{community.prefecture}{community.village}DAOコミュニティ「{community.name}」は、関係人口を増やすための実験的コミュニティ。村のイベント・体験・人と出会いながら、新しい関わり方をつくっています。</p>
      </div>
    </section>

    <section id="features" class="features">
      <div class="features-header"><span class="section-label">Features</span><h2>What we offer</h2></div>
      <div class="features-grid">
        {features.map((f) => (
          <div class={`feature-card ${f.image ? 'has-photo' : ''}`}>
            {f.image && <div class="feature-photo" style={`background-image: url('${f.image}');`}></div>}
            <div class="feature-body">
              <div class="feature-icon">{f.icon}</div>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section id="news" class="news">
      <div class="news-header"><span class="section-label">News</span><h2>Latest updates</h2></div>
      <ul>
        {news.map((n) => (
          <li>
            <a href={n.href}>
              {n.image && <div class="n-img" style={`background-image: url('${n.image}');`}></div>}
              <div class="n-body">
                <div class="n-meta"><time>{n.date}</time><span class={`n-tag n-tag-${n.tag}`}>{n.tagLabel}</span></div>
                <h3>{n.title}</h3>
                <p>{n.excerpt}</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <section class="gallery">
      <div class="gallery-grid">
        {gallery.slice(0, 8).map((g) => (
          <div class="g-item" style={`background-image: url('${g}');`}></div>
        ))}
      </div>
    </section>

    <section class="organizers">
      <div class="org-header"><span class="section-label">Organizers</span><h2>運営</h2></div>
      <div class="org-grid">
        <div class="org-card">
          <div class="org-photo" style={`background-image: url('${profile.photo}');`}></div>
          <div class="org-body">
            <span class="org-kind">PERSON</span>
            <h3>{profile.handle}</h3>
            <p class="org-role">{profile.role}</p>
            <p>{profile.bio}</p>
          </div>
        </div>
        <div class="org-card">
          <div class="org-mark"><span class="org-initial">A</span><span class="org-en">{organization.nameEn}</span></div>
          <div class="org-body">
            <span class="org-kind">COMPANY</span>
            <h3>{organization.name}</h3>
            <p class="org-role">{organization.role}</p>
            <p>{organization.bio}</p>
            <a href={organization.url} target="_blank" rel="noopener" class="org-link">{organization.urlLabel} →</a>
          </div>
        </div>
      </div>
    </section>

    <section class="cta">
      <div class="cta-glow"></div>
      <div class="cta-content">
        <span class="section-label">Join the movement</span>
        <h2>{community.village}を、<br />一緒に動かそう。</h2>
        <p>「ちょっと興味あるかも」のテンションで大丈夫。</p>
        <a href={community.lineUrl} class="btn-primary btn-large">DAOに参加する →</a>
      </div>
    </section>

    <footer class="footer">
      <span class="footer-logo">{community.name}</span>
      <span class="footer-org">運営: {community.operator}</span>
    </footer>

    <a href={`${import.meta.env.BASE_URL.replace(/\/?$/, '/')}municipalities/kawakami`} class="back-link">← 川上村LP一覧に戻る</a>
  </div>
</Base>

<style>
  .dark { font-family: 'Noto Sans JP', sans-serif; color: #e0e0e0; background: #0a0a0a; }
  .section-label { font-family: 'Inter', sans-serif; font-size: 0.65rem; letter-spacing: 0.25em; text-transform: uppercase; color: #00D4AA; display: block; margin-bottom: 16px; }

  .nav { display: flex; justify-content: space-between; align-items: center; padding: 18px 48px; position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(10, 10, 10, 0.85); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255, 255, 255, 0.06); }
  .nav-logo { display: flex; align-items: center; gap: 10px; font-size: 0.9rem; font-weight: 700; color: #fff; }
  .logo-mark { display: inline-flex; }
  .nav-links { display: flex; align-items: center; gap: 28px; font-family: 'Inter', sans-serif; font-size: 0.8rem; }
  .nav-links a { color: #666; transition: color 0.2s; }
  .nav-links a:hover { color: #fff; }
  .nav-btn { color: #0a0a0a !important; background: #00D4AA; padding: 8px 20px; border-radius: 6px; font-weight: 600; }

  .hero { min-height: 100vh; display: flex; flex-direction: column; justify-content: center; padding: 130px 48px 60px; position: relative; overflow: hidden; background-size: cover; background-position: center; }
  .hero-grid-bg { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.04) 1px, transparent 1px); background-size: 60px 60px; pointer-events: none; opacity: 0.5; }
  .hero-glow { position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%); width: 600px; height: 600px; background: radial-gradient(circle, rgba(0, 212, 170, 0.18) 0%, transparent 70%); pointer-events: none; }
  .hero-content { position: relative; z-index: 1; max-width: 800px; }
  .hero-badge { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border: 1px solid rgba(255, 255, 255, 0.15); border-radius: 100px; font-family: 'Inter', sans-serif; font-size: 0.7rem; color: #aaa; margin-bottom: 36px; background: rgba(0,0,0,0.4); }
  .hero-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #00D4AA; animation: pulse 2s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .hero h1 { font-size: clamp(2.6rem, 6vw, 4.8rem); font-weight: 900; line-height: 1.3; color: #fff; margin-bottom: 28px; letter-spacing: -0.02em; }
  .gradient-text { background: linear-gradient(135deg, #00D4AA, #00A3FF); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero-desc { font-size: 1rem; line-height: 1.95; color: #aaa; max-width: 540px; margin-bottom: 40px; }
  .hero-actions { display: flex; gap: 16px; align-items: center; }
  .btn-primary { display: inline-block; padding: 14px 30px; background: #00D4AA; color: #0a0a0a; font-size: 0.88rem; font-weight: 600; border-radius: 8px; transition: transform 0.2s, box-shadow 0.3s; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(0, 212, 170, 0.3); }
  .btn-large { padding: 18px 44px; font-size: 0.95rem; }
  .btn-ghost { font-family: 'Inter', sans-serif; font-size: 0.85rem; color: #aaa; transition: color 0.2s; padding: 14px 0; }
  .btn-ghost:hover { color: #00D4AA; }
  .hero-stats { position: relative; z-index: 1; display: flex; align-items: center; gap: 40px; margin-top: 80px; padding-top: 40px; border-top: 1px solid rgba(255, 255, 255, 0.08); }
  .hero-stat-num { font-family: 'Inter', sans-serif; font-size: 1.8rem; font-weight: 700; color: #fff; display: block; margin-bottom: 4px; }
  .hero-stat-label { font-family: 'Inter', sans-serif; font-size: 0.7rem; color: #666; letter-spacing: 0.08em; }
  .hero-stat-divider { width: 1px; height: 40px; background: rgba(255, 255, 255, 0.08); }

  .mission { padding: 140px 48px; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .mission-inner { max-width: 720px; }
  .mission h2 { font-size: clamp(1.7rem, 3.4vw, 2.6rem); font-weight: 700; line-height: 1.6; color: #fff; margin-bottom: 28px; }
  .mission p { font-size: 0.95rem; line-height: 2.1; color: #888; }

  .features { padding: 120px 48px; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .features-header { margin-bottom: 56px; }
  .features-header h2 { font-family: 'Inter', sans-serif; font-size: 1.4rem; font-weight: 600; color: #fff; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 1200px; }
  .feature-card { border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; background: rgba(255, 255, 255, 0.02); overflow: hidden; transition: border-color 0.3s, background 0.3s; }
  .feature-card:hover { border-color: rgba(0, 212, 170, 0.3); background: rgba(0, 212, 170, 0.03); }
  .feature-photo { aspect-ratio: 16/10; background-size: cover; background-position: center; border-bottom: 1px solid rgba(255, 255, 255, 0.06); filter: brightness(0.8); }
  .feature-body { padding: 28px 26px; }
  .feature-icon { font-size: 1.6rem; margin-bottom: 14px; }
  .feature-card h3 { font-size: 1.05rem; font-weight: 700; color: #fff; margin-bottom: 10px; }
  .feature-card p { font-size: 0.82rem; line-height: 1.85; color: #888; }

  .news { padding: 120px 48px; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .news-header { margin-bottom: 56px; }
  .news-header h2 { font-family: 'Inter', sans-serif; font-size: 1.4rem; font-weight: 600; color: #fff; }
  .news ul { list-style: none; display: flex; flex-direction: column; gap: 0; max-width: 980px; }
  .news li a { display: grid; grid-template-columns: 200px 1fr; gap: 32px; padding: 28px 0; border-top: 1px solid rgba(255, 255, 255, 0.06); align-items: center; transition: background 0.2s; }
  .news li a:hover { background: rgba(0, 212, 170, 0.03); }
  .n-img { aspect-ratio: 16/10; background-size: cover; background-position: center; border-radius: 6px; filter: brightness(0.8); }
  .n-body { min-width: 0; }
  .n-meta { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; }
  .n-meta time { font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #888; }
  .n-tag { font-family: 'Inter', sans-serif; font-size: 0.66rem; padding: 3px 8px; border-radius: 3px; letter-spacing: 0.08em; }
  .n-tag-press { background: #00D4AA; color: #0a0a0a; }
  .n-tag-event { background: #00A3FF; color: #0a0a0a; }
  .n-tag-milestone { background: rgba(0, 212, 170, 0.2); color: #00D4AA; border: 1px solid rgba(0, 212, 170, 0.3); }
  .news h3 { font-size: 1.05rem; color: #fff; margin-bottom: 6px; line-height: 1.5; }
  .news p { font-size: 0.85rem; line-height: 1.85; color: #777; }

  .gallery { padding: 80px 48px; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; max-width: 1200px; margin: 0 auto; }
  .g-item { aspect-ratio: 1/1; background-size: cover; background-position: center; border-radius: 4px; transition: transform 0.3s, filter 0.3s; filter: brightness(0.85); }
  .g-item:hover { transform: scale(1.04); filter: brightness(1); }

  .organizers { padding: 120px 48px; border-top: 1px solid rgba(255, 255, 255, 0.06); max-width: 1100px; margin: 0 auto; }
  .org-header { margin-bottom: 56px; }
  .org-header h2 { font-family: 'Inter', sans-serif; font-size: 1.4rem; font-weight: 600; color: #fff; }
  .org-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .org-card { display: grid; grid-template-columns: 120px 1fr; gap: 24px; padding: 28px; border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 12px; background: rgba(255, 255, 255, 0.02); }
  .org-photo { aspect-ratio: 1/1; background-size: cover; background-position: center; border-radius: 10px; filter: brightness(0.85); }
  .org-mark { aspect-ratio: 1/1; border-radius: 10px; background: linear-gradient(135deg, #00D4AA 0%, #00A3FF 100%); color: #0a0a0a; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 5px; }
  .org-initial { font-family: 'Inter', sans-serif; font-size: 2.8rem; font-weight: 900; line-height: 1; letter-spacing: -0.04em; }
  .org-en { font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.22em; opacity: 0.75; font-weight: 600; }
  .org-kind { font-family: 'Inter', sans-serif; font-size: 0.62rem; letter-spacing: 0.22em; color: #00D4AA; display: block; margin-bottom: 8px; }
  .org-body h3 { font-size: 1.1rem; color: #fff; font-weight: 700; margin-bottom: 4px; }
  .org-role { font-size: 0.78rem; color: #888; margin-bottom: 12px; }
  .org-body p { font-size: 0.82rem; line-height: 1.85; color: #888; }
  .org-link { display: inline-block; margin-top: 12px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #00D4AA; border-bottom: 1px solid #00D4AA; padding-bottom: 2px; }
  .org-link:hover { opacity: 0.75; }

  .cta { padding: 180px 48px; text-align: center; position: relative; overflow: hidden; }
  .cta-glow { position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 400px; background: radial-gradient(ellipse, rgba(0, 212, 170, 0.1) 0%, transparent 70%); pointer-events: none; }
  .cta-content { position: relative; z-index: 1; }
  .cta h2 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; color: #fff; line-height: 1.4; margin-bottom: 18px; }
  .cta p { font-size: 0.9rem; color: #888; margin-bottom: 44px; }

  .footer { border-top: 1px solid rgba(255, 255, 255, 0.06); padding: 28px 48px; display: flex; justify-content: space-between; }
  .footer-logo { font-size: 0.85rem; font-weight: 700; color: #aaa; }
  .footer-org { font-size: 0.7rem; color: #555; font-family: 'Inter', sans-serif; }
  .back-link { display: block; text-align: center; padding: 28px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #555; border-top: 1px solid rgba(255, 255, 255, 0.06); }
  .back-link:hover { color: #00D4AA; }

  @media (max-width: 768px) {
    .nav { padding: 14px 22px; }
    .hero { padding: 120px 22px 60px; }
    .hero-actions { flex-direction: column; align-items: stretch; }
    .hero-stats { flex-direction: column; align-items: flex-start; gap: 20px; }
    .hero-stat-divider { display: none; }
    .mission, .features, .news, .gallery, .cta { padding: 80px 22px; }
    .features-grid { grid-template-columns: 1fr; }
    .news li a { grid-template-columns: 1fr; gap: 14px; }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .organizers { padding: 70px 22px; }
    .org-grid { grid-template-columns: 1fr; }
    .org-card { grid-template-columns: 90px 1fr; gap: 18px; padding: 22px; }
    .footer { padding: 20px; flex-direction: column; gap: 6px; text-align: center; }
  }
</style>
