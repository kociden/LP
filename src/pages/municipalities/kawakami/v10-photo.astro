---
import Base from '../../../layouts/Base.astro';
import { community, numbers, features, news, images, gallery } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (フォトジャーナル案) — ${community.prefecture}${community.village}`}>
  <div class="journal">
    <nav class="nav">
      <div class="nav-inner">
        <a href="#" class="nav-logo">
          <span class="nav-logo-mark">—</span>
          <span class="nav-logo-text">{community.name}</span>
          <span class="nav-logo-sub">JOURNAL</span>
        </a>
        <div class="nav-links">
          <a href="#about"><span class="nav-num">01</span>知る</a>
          <a href="#news"><span class="nav-num">02</span>便り</a>
          <a href={community.lineUrl}><span class="nav-num">03</span>参加</a>
        </div>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-photo" style={`background-image: url('${images.hero}');`}>
        <div class="photo-caption">
          <span class="caption-label">FIG. 01</span>
          <span class="caption-text">{community.prefecture}{community.village}、地域おこし協力隊員と仲間たち。</span>
        </div>
      </div>
      <div class="hero-content">
        <div class="hero-meta">
          <span class="hero-vol">VOL. 01 / SPRING 2026</span>
          <span class="hero-dot"></span>
          <span class="hero-issue">{community.name}</span>
        </div>
        <h1 class="hero-title">レタスから、<br />宇宙まで。<br />日本一の村と。</h1>
        <p class="hero-lede">
          {community.lead}<br />
          現役隊員、村外サポーター、村内議員、大学生——<br />
          自主的な認知活動で、すでに100名を超える仲間が集っています。
        </p>
        <div class="hero-credits">
          <div class="credit-item"><span class="credit-label">EDITED BY</span><span class="credit-value">{community.operator}</span></div>
          <div class="credit-item"><span class="credit-label">PUBLISHED</span><span class="credit-value">2026.04</span></div>
        </div>
        <a href={community.lineUrl} class="hero-cta">→ LINEオープンチャットに参加する</a>
      </div>
    </section>

    <div class="strip">
      <div class="strip-inner">
        <span>FIELD NOTES</span><span class="strip-dot">◆</span>
        <span>KAWAKAMI</span><span class="strip-dot">◆</span>
        <span>SINCE 2025</span><span class="strip-dot">◆</span>
        <span>100+ MEMBERS</span><span class="strip-dot">◆</span>
        <span>DECENTRALIZED</span>
      </div>
    </div>

    <section id="about" class="about">
      <div class="section-head"><span class="section-num">— 01 —</span><span class="section-kicker">ABOUT</span></div>
      <div class="about-grid">
        <div class="about-lead">
          <p class="drop-cap">
            <span class="drop">川</span>上村は、{community.prefecture}{community.district}の標高1,100mに位置する、人口約4,000人の小さな村だ。レタス生産量で日本一を誇り、宇宙飛行士・油井亀美也さんの故郷としても知られる。
          </p>
          <p>
            この村と関わる人を、全国に増やしていきたい——「{community.name}」は、そんな思いから始まったDAOコミュニティ。住んでいなくても関われる新しい関係性のかたちを、村と外の人たちが共に育てている。
          </p>
        </div>
        <div class="about-photo">
          <div class="photo" style={`background-image: url('${images.idea}');`}></div>
          <div class="photo-caption"><span class="caption-label">FIG. 02</span><span class="caption-text">川上村について考える会議。ハイブリッド形式で月例開催。</span></div>
        </div>
      </div>
      <div class="stats">
        {numbers.map((n) => (
          <div class="stat">
            <span class="stat-num">{n.value}{n.unit && <span class="stat-plus">{n.unit}</span>}</span>
            <span class="stat-unit">{n.label}</span>
            <span class="stat-note">{n.note}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="spread">
      <div class="photo" style={`background-image: url('${images.cosmos}');`}></div>
      <div class="spread-quote">
        <p>「日本でいちばん、</p>
        <p>宇宙に近い村から。」</p>
        <span class="spread-author">— LETTUCE-VILLE / VOL. 01</span>
      </div>
    </section>

    <section class="pillars">
      <div class="section-head"><span class="section-num">— 02 —</span><span class="section-kicker">WHAT YOU CAN DO</span></div>
      <h2 class="pillars-title">川上村との<br />関わり方は、いろいろ。</h2>
      <div class="pillars-grid">
        {features.slice(0, 3).map((f, i) => (
          <article class="pillar">
            <div class="photo" style={`background-image: url('${f.image || images.event1}');`}></div>
            <div class="pillar-body">
              <span class="pillar-num">{['I.', 'II.', 'III.'][i]}</span>
              <h3>{f.title}</h3>
              <p>{f.body}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section id="news" class="dispatch">
      <div class="section-head"><span class="section-num">— 03 —</span><span class="section-kicker">NEWS &amp; PRESS</span></div>
      <div class="dispatch-grid">
        {news.map((n) => (
          <article class="dispatch-item">
            {n.image && <div class="photo dispatch-photo" style={`background-image: url('${n.image}');`}></div>}
            <span class={`dispatch-tag dispatch-tag-${n.tag}`}>{n.tagLabel} ／ {n.date}</span>
            <h4>{n.title}</h4>
            <p>{n.excerpt}</p>
          </article>
        ))}
        <article class="dispatch-item">
          <div class="photo dispatch-photo" style={`background-image: url('${images.event2}');`}></div>
          <span class="dispatch-tag dispatch-tag-event">EVENT ／ 2026.03</span>
          <h4>地域内イベントの様子</h4>
          <p>村内外メンバーが集まる現地企画も活発。</p>
        </article>
      </div>
    </section>

    <section class="gallery-section">
      <div class="section-head"><span class="section-num">— 04 —</span><span class="section-kicker">SNAPSHOTS</span></div>
      <div class="gallery-grid">
        {gallery.slice(0, 8).map((g) => (
          <div class="g-item" style={`background-image: url('${g}');`}></div>
        ))}
      </div>
    </section>

    <section class="cta">
      <div class="cta-photo">
        <div class="photo" style={`background-image: url('${images.event3}');`}></div>
      </div>
      <div class="cta-body">
        <span class="cta-kicker">— JOIN THE JOURNAL —</span>
        <h2>あなたの川上村との関わりを、<br />次の号に、書き加えよう。</h2>
        <p class="cta-lede">現役隊員、関心ある方、村外サポーター。<br />対話の場は、すでにひらかれています。</p>
        <a href={community.lineUrl} class="cta-button"><span>LINEオープンチャットに参加する</span><span class="cta-arrow">→</span></a>
        <div class="cta-foot"><span>運営 — {community.operator}</span><span class="cta-sep">/</span><span>EST. 2025</span></div>
      </div>
    </section>

    <footer class="foot">
      <div class="foot-inner">
        <span>{community.name} JOURNAL — VOL.01</span>
        <span>© 2026 LETTUCE-VILLE</span>
      </div>
    </footer>

    <a href="/municipalities/kawakami" class="back-link">← 川上村LP一覧に戻る</a>
  </div>
</Base>

<style>
  .journal { font-family: 'Noto Sans JP', sans-serif; color: #1a1a1a; background: #f5f3ee; min-height: 100vh; font-weight: 400; }
  .photo { width: 100%; height: 100%; min-height: 240px; position: relative; background-size: cover; background-position: center; background-color: #cfcfcf; }
  .photo::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.1), transparent 55%), radial-gradient(ellipse at 70% 80%, rgba(0,0,0,0.12), transparent 55%); pointer-events: none; }

  .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(245, 243, 238, 0.94); backdrop-filter: blur(8px); border-bottom: 1px solid #d4cfc4; }
  .nav-inner { display: flex; justify-content: space-between; align-items: center; padding: 16px 48px; max-width: 1400px; margin: 0 auto; }
  .nav-logo { display: flex; align-items: baseline; gap: 10px; }
  .nav-logo-mark { color: #1a1a1a; font-family: 'Inter', sans-serif; font-weight: 300; }
  .nav-logo-text { font-family: 'Noto Serif JP', serif; font-weight: 700; font-size: 1rem; letter-spacing: 0.04em; }
  .nav-logo-sub { font-family: 'Inter', sans-serif; font-size: 0.62rem; letter-spacing: 0.28em; color: #8a8276; }
  .nav-links { display: flex; gap: 32px; }
  .nav-links a { display: inline-flex; align-items: baseline; gap: 8px; font-size: 0.85rem; letter-spacing: 0.06em; }
  .nav-links a:hover { color: #8a6a3f; }
  .nav-num { font-family: 'Inter', sans-serif; font-size: 0.62rem; color: #8a8276; letter-spacing: 0.14em; }

  .hero { padding: 110px 48px 56px; max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1.15fr 1fr; gap: 56px; align-items: stretch; }
  .hero-photo { display: flex; flex-direction: column; min-height: 540px; }
  .hero-photo .photo-caption { margin-top: auto; }
  .photo-caption { display: flex; gap: 12px; font-family: 'Inter', sans-serif; font-size: 0.72rem; color: #6b645a; line-height: 1.6; padding: 10px 0 0; border-top: 1px solid #d4cfc4; background: #f5f3ee; }
  .hero-photo > .photo-caption { padding: 8px 14px; background: rgba(245, 243, 238, 0.92); position: absolute; bottom: 0; left: 0; right: 0; }
  .hero-photo { position: relative; background-size: cover; background-position: center; }
  .caption-label { font-weight: 600; letter-spacing: 0.12em; color: #1a1a1a; flex-shrink: 0; }
  .caption-text { font-family: 'Noto Sans JP', sans-serif; }

  .hero-content { display: flex; flex-direction: column; justify-content: space-between; padding: 8px 0; }
  .hero-meta { display: flex; align-items: center; gap: 14px; font-family: 'Inter', sans-serif; font-size: 0.72rem; letter-spacing: 0.16em; color: #6b645a; padding-bottom: 28px; border-bottom: 1px solid #d4cfc4; }
  .hero-vol { font-weight: 600; }
  .hero-dot { width: 4px; height: 4px; border-radius: 50%; background: #8a6a3f; }
  .hero-issue { font-family: 'Noto Sans JP', sans-serif; color: #1a1a1a; letter-spacing: 0.1em; }
  .hero-title { font-family: 'Noto Serif JP', serif; font-size: clamp(2.4rem, 5vw, 4.4rem); font-weight: 700; line-height: 1.3; letter-spacing: 0.02em; margin: 38px 0; }
  .hero-lede { font-family: 'Noto Serif JP', serif; font-size: 0.96rem; line-height: 2; color: #3a3530; max-width: 480px; }
  .hero-credits { display: flex; gap: 44px; margin-top: 36px; padding-top: 26px; border-top: 1px solid #d4cfc4; }
  .credit-item { display: flex; flex-direction: column; gap: 6px; }
  .credit-label { font-family: 'Inter', sans-serif; font-size: 0.62rem; letter-spacing: 0.18em; color: #8a8276; }
  .credit-value { font-family: 'Noto Serif JP', serif; font-size: 0.92rem; font-weight: 700; }
  .hero-cta { margin-top: 28px; display: inline-block; padding: 16px 28px; background: #1a1a1a; color: #f5f3ee; font-size: 0.85rem; letter-spacing: 0.12em; transition: background 0.3s; align-self: flex-start; }
  .hero-cta:hover { background: #8a6a3f; }

  .strip { border-top: 1px solid #d4cfc4; border-bottom: 1px solid #d4cfc4; overflow: hidden; background: #1a1a1a; color: #f5f3ee; }
  .strip-inner { display: flex; gap: 32px; padding: 12px 48px; font-family: 'Inter', sans-serif; font-size: 0.7rem; letter-spacing: 0.24em; justify-content: center; flex-wrap: wrap; }
  .strip-dot { color: #8a6a3f; }

  .about { padding: 110px 48px 100px; max-width: 1400px; margin: 0 auto; }
  .section-head { display: flex; align-items: center; gap: 14px; margin-bottom: 56px; font-family: 'Inter', sans-serif; }
  .section-num { font-size: 0.72rem; letter-spacing: 0.18em; color: #8a6a3f; font-weight: 500; }
  .section-kicker { font-size: 0.72rem; letter-spacing: 0.28em; color: #1a1a1a; font-weight: 600; }
  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; margin-bottom: 80px; }
  .about-lead p { font-family: 'Noto Serif JP', serif; font-size: 1rem; line-height: 2.15; color: #2d2822; margin-bottom: 22px; }
  .drop { font-size: 3.2rem; font-weight: 700; float: left; line-height: 1; padding: 6px 12px 0 0; color: #8a6a3f; font-family: 'Noto Serif JP', serif; }
  .about-photo .photo { min-height: 380px; }
  .about-photo .photo-caption { padding-top: 8px; border-top: 1px solid #d4cfc4; margin-top: 12px; }

  .stats { display: grid; grid-template-columns: repeat(4, 1fr); border-top: 1px solid #1a1a1a; border-bottom: 1px solid #1a1a1a; }
  .stat { padding: 32px 22px; display: flex; flex-direction: column; gap: 8px; border-right: 1px solid #d4cfc4; }
  .stat:last-child { border-right: none; }
  .stat-num { font-family: 'Noto Serif JP', serif; font-size: 2.4rem; font-weight: 700; line-height: 1; }
  .stat-plus { font-size: 1.3rem; color: #8a6a3f; vertical-align: super; }
  .stat-unit { font-size: 0.85rem; font-weight: 500; margin-top: 4px; }
  .stat-note { font-family: 'Inter', sans-serif; font-size: 0.7rem; color: #6b645a; letter-spacing: 0.04em; margin-top: 6px; }

  .spread { position: relative; height: 64vh; min-height: 420px; overflow: hidden; }
  .spread .photo { position: absolute; inset: 0; min-height: 100%; }
  .spread-quote { position: absolute; inset: 0; display: flex; flex-direction: column; justify-content: center; align-items: center; color: #f5f3ee; font-family: 'Noto Serif JP', serif; text-align: center; padding: 0 32px; text-shadow: 0 2px 24px rgba(0,0,0,0.5); z-index: 2; background: rgba(0,0,0,0.35); }
  .spread-quote p { font-size: clamp(1.5rem, 3.6vw, 2.6rem); font-weight: 700; line-height: 1.7; letter-spacing: 0.04em; }
  .spread-author { margin-top: 24px; font-family: 'Inter', sans-serif; font-size: 0.74rem; letter-spacing: 0.2em; opacity: 0.85; }

  .pillars { padding: 110px 48px 100px; max-width: 1400px; margin: 0 auto; }
  .pillars-title { font-family: 'Noto Serif JP', serif; font-size: clamp(1.8rem, 3.4vw, 2.6rem); font-weight: 700; line-height: 1.7; margin-bottom: 64px; max-width: 900px; }
  .pillars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 36px; }
  .pillar { display: flex; flex-direction: column; gap: 18px; }
  .pillar .photo { min-height: 300px; }
  .pillar-body { padding: 14px 0 0; border-top: 1px solid #1a1a1a; }
  .pillar-num { display: block; font-family: 'Inter', sans-serif; font-size: 0.78rem; font-weight: 600; letter-spacing: 0.14em; color: #8a6a3f; margin-bottom: 12px; }
  .pillar-body h3 { font-family: 'Noto Serif JP', serif; font-size: 1.25rem; font-weight: 700; margin-bottom: 14px; letter-spacing: 0.02em; }
  .pillar-body p { font-size: 0.86rem; line-height: 1.95; color: #3a3530; font-weight: 300; }

  .dispatch { padding: 30px 48px 110px; max-width: 1400px; margin: 0 auto; }
  .dispatch-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 26px; }
  .dispatch-item { display: flex; flex-direction: column; gap: 12px; }
  .dispatch-photo { min-height: 200px !important; }
  .dispatch-tag { font-family: 'Inter', sans-serif; font-size: 0.66rem; letter-spacing: 0.16em; color: #8a6a3f; font-weight: 600; margin-top: 4px; }
  .dispatch-tag-press { color: #1a1a1a; }
  .dispatch-tag-milestone { color: #5c7b6d; }
  .dispatch-item h4 { font-family: 'Noto Serif JP', serif; font-size: 1rem; font-weight: 700; line-height: 1.55; }
  .dispatch-item p { font-size: 0.8rem; line-height: 1.85; color: #6b645a; }

  .gallery-section { padding: 30px 48px 100px; max-width: 1400px; margin: 0 auto; }
  .gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; }
  .g-item { aspect-ratio: 1/1; background-size: cover; background-position: center; transition: transform 0.3s; }
  .g-item:hover { transform: scale(1.03); }

  .cta { display: grid; grid-template-columns: 1fr 1fr; min-height: 70vh; border-top: 1px solid #d4cfc4; }
  .cta-photo { position: relative; overflow: hidden; }
  .cta-photo .photo { height: 100%; min-height: 100%; }
  .cta-body { padding: 80px 56px; display: flex; flex-direction: column; justify-content: center; background: #f5f3ee; }
  .cta-kicker { font-family: 'Inter', sans-serif; font-size: 0.72rem; letter-spacing: 0.28em; color: #8a6a3f; font-weight: 600; margin-bottom: 26px; }
  .cta h2 { font-family: 'Noto Serif JP', serif; font-size: clamp(1.7rem, 3.2vw, 2.4rem); font-weight: 700; line-height: 1.7; margin-bottom: 28px; }
  .cta-lede { font-family: 'Noto Serif JP', serif; font-size: 0.95rem; line-height: 2.05; color: #3a3530; margin-bottom: 40px; max-width: 460px; }
  .cta-button { display: inline-flex; align-items: center; justify-content: space-between; gap: 18px; padding: 20px 30px; background: #1a1a1a; color: #f5f3ee; font-size: 0.86rem; letter-spacing: 0.14em; max-width: 360px; transition: background 0.3s, transform 0.3s; border: 1px solid #1a1a1a; }
  .cta-button:hover { background: #8a6a3f; border-color: #8a6a3f; transform: translateX(4px); }
  .cta-foot { display: flex; gap: 14px; align-items: center; margin-top: 40px; padding-top: 22px; border-top: 1px solid #d4cfc4; font-family: 'Inter', sans-serif; font-size: 0.72rem; letter-spacing: 0.14em; color: #6b645a; }
  .cta-sep { color: #8a6a3f; }

  .foot { border-top: 1px solid #d4cfc4; background: #1a1a1a; color: #a8a198; }
  .foot-inner { max-width: 1400px; margin: 0 auto; padding: 22px 48px; display: flex; justify-content: space-between; font-family: 'Inter', sans-serif; font-size: 0.72rem; letter-spacing: 0.16em; }

  .back-link { display: block; text-align: center; padding: 26px; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #8a8276; background: #f5f3ee; border-top: 1px solid #d4cfc4; letter-spacing: 0.1em; }
  .back-link:hover { color: #1a1a1a; }

  @media (max-width: 968px) {
    .hero { grid-template-columns: 1fr; gap: 36px; padding: 96px 22px 44px; }
    .hero-photo { min-height: 320px; }
    .about-grid { grid-template-columns: 1fr; gap: 32px; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .stat:nth-child(2) { border-right: none; }
    .stat:nth-child(1), .stat:nth-child(2) { border-bottom: 1px solid #d4cfc4; }
    .pillars-grid { grid-template-columns: 1fr; gap: 36px; }
    .dispatch-grid { grid-template-columns: repeat(2, 1fr); }
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .cta { grid-template-columns: 1fr; }
    .cta-photo .photo { min-height: 280px; }
  }

  @media (max-width: 768px) {
    .nav-inner { padding: 14px 22px; }
    .nav-logo-sub { display: none; }
    .nav-links { gap: 16px; }
    .nav-links a { font-size: 0.78rem; }
    .nav-num { display: none; }
    .strip-inner { padding: 10px 22px; gap: 16px; font-size: 0.62rem; letter-spacing: 0.18em; }
    .about, .pillars, .dispatch, .gallery-section { padding: 70px 22px; }
    .dispatch-grid { grid-template-columns: 1fr; }
    .cta-body { padding: 56px 22px; }
    .cta-button { max-width: none; width: 100%; padding: 16px 22px; }
    .foot-inner { flex-direction: column; gap: 8px; padding: 18px 22px; text-align: center; }
  }
</style>
