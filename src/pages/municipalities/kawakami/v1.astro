---
import Base from '../../../layouts/Base.astro';
import { community, numbers, concepts, features, news, steps, images, profile, organization } from '../../../data/kawakami.ts';
---

<Base title={`${community.name} (和モダン案) — ${community.prefecture}${community.village}`}>
  <div class="wa">
    <!-- Nav -->
    <nav class="nav">
      <div class="nav-logo">{community.name}</div>
      <div class="nav-links">
        <a href="#about">知る</a>
        <a href="#concepts">理念</a>
        <a href="#news">便り</a>
        <a href="#join">参加する</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-vertical">
        <p class="hero-vertical-text">レタスから、宇宙まで。</p>
      </div>
      <div class="hero-main">
        <h1>
          <span class="hero-sub">{community.prefecture}{community.village}DAO ／ {community.name}</span>
          つながりが、<br />村を耕す。
        </h1>
        <p class="hero-desc">
          {community.shortLead}<br />
          村のイベント・体験・人と出会いながら、<br />関係人口の輪をひろげる場所です。
        </p>
        <div class="hero-line"></div>
        <a href={community.lineUrl} class="hero-cta">▶ LINEオープンチャットに参加する</a>
      </div>
      <div class="hero-accent">
        <span class="hero-accent-char">耕</span>
        <span class="hero-accent-char">す</span>
      </div>
    </section>

    <!-- Photo strip -->
    <div class="photo-strip">
      <div class="strip-img" style={`background-image: url('${images.hero}');`}></div>
      <div class="strip-img" style={`background-image: url('${images.cosmos}');`}></div>
      <div class="strip-img" style={`background-image: url('${images.idea}');`}></div>
    </div>

    <!-- About -->
    <section id="about" class="about">
      <div class="about-grid">
        <div class="about-label">
          <span class="section-num">01</span>
          <span class="section-title">About</span>
        </div>
        <div class="about-content">
          <h2>川上村と、<br />レタスペビレッジ。</h2>
          <p>
            標高1,100m、{community.prefecture}{community.district}{community.village}。
            夏秋レタスの生産量で日本一を誇り、宇宙飛行士・油井亀美也さんの故郷でもあります。
            この村と関わる人を増やしたい——「レタスペビレッジ」は、そんな思いから始まったDAOコミュニティです。
          </p>
          <div class="about-stats">
            {numbers.map((n) => (
              <div class="stat">
                <span class="stat-num">{n.value}{n.unit}</span>
                <span class="stat-label">{n.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Concepts -->
    <section id="concepts" class="vision">
      <div class="vision-bg-text">耕</div>
      <div class="vision-content">
        <span class="section-num">02</span>
        <h2>食と、宇宙と。<br />ふたつの軸を持つ村。</h2>
        <div class="vision-cards">
          {concepts.map((c, i) => (
            <div class="vision-card">
              <div class="vision-card-num">{i === 0 ? '壱' : '弐'}</div>
              <h3>{c.title}</h3>
              <p>{c.body}</p>
            </div>
          ))}
          <div class="vision-card">
            <div class="vision-card-num">参</div>
            <h3>関係人口を、ともに耕す。</h3>
            <p>住んでいなくても、行ったことがなくても、村と関われる場所。あなたのペースで、村と関係を結べます。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- News -->
    <section id="news" class="news">
      <div class="news-head">
        <span class="section-num">03</span>
        <h2>便り。 <span class="news-en">/ News &amp; Press</span></h2>
      </div>
      <ul class="news-list">
        {news.map((n) => (
          <li class="news-item">
            <a href={n.href}>
              {n.image && <div class="news-thumb" style={`background-image: url('${n.image}');`}></div>}
              <div class="news-meta">
                <time>{n.date}</time>
                <span class={`news-tag news-tag-${n.tag}`}>{n.tagLabel}</span>
              </div>
              <p class="news-title">{n.title}</p>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="section-head">
        <span class="section-num">04</span>
        <h2>できること。</h2>
      </div>
      <div class="features-grid">
        {features.map((f) => (
          <div class="feature">
            {f.image && <div class="feature-img" style={`background-image: url('${f.image}');`}></div>}
            <p class="feature-icon">{f.icon}</p>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Organizers -->
    <section class="organizers">
      <div class="section-head">
        <span class="section-num">05</span>
        <h2>運営。</h2>
      </div>
      <div class="org-grid">
        <article class="org-card">
          <div class="org-photo" style={`background-image: url('${profile.photo}');`}></div>
          <div class="org-body">
            <span class="org-kind">PERSON</span>
            <p class="org-name">{profile.handle}</p>
            <p class="org-role">{profile.role}</p>
            <p class="org-bio">{profile.bio}</p>
          </div>
        </article>
        <article class="org-card">
          <div class="org-mark">
            <span class="org-initial">A</span>
            <span class="org-en">{organization.nameEn}</span>
          </div>
          <div class="org-body">
            <span class="org-kind">COMPANY</span>
            <p class="org-name">{organization.name}</p>
            <p class="org-role">{organization.role}</p>
            <p class="org-bio">{organization.bio}</p>
            <a href={organization.url} target="_blank" rel="noopener" class="org-link">{organization.urlLabel} ↗</a>
          </div>
        </article>
      </div>
    </section>

    <!-- Steps + CTA -->
    <section id="join" class="cta">
      <div class="cta-inner">
        <p class="cta-label">Join the DAO</p>
        <h2>一〇一人目の村人に、<br />あなたを待っています。</h2>
        <ol class="steps">
          {steps.map((s) => (
            <li><span class="step-n">{s.n}</span><span class="step-t">{s.title}</span></li>
          ))}
        </ol>
        <a href={community.lineUrl} class="cta-button">LINEオープンチャットに参加する ▶</a>
        <p class="cta-note">運営: {community.operator}</p>
      </div>
    </section>

    <a href="/municipalities/kawakami" class="back-link">← 川上村LP一覧 / 採用案を見る</a>
  </div>
</Base>

<style>
  .wa { font-family: 'Noto Serif JP', serif; color: #2d2926; background: #f7f5f0; min-height: 100vh; }

  /* Nav */
  .nav { display: flex; justify-content: space-between; align-items: center; padding: 24px 48px; position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(247, 245, 240, 0.9); backdrop-filter: blur(10px); }
  .nav-logo { font-weight: 700; font-size: 1.05rem; letter-spacing: 0.12em; }
  .nav-links { display: flex; gap: 32px; font-size: 0.85rem; font-family: 'Noto Sans JP', sans-serif; }
  .nav-links a { letter-spacing: 0.1em; transition: opacity 0.3s; }
  .nav-links a:hover { opacity: 0.5; }

  /* Hero */
  .hero { min-height: 100vh; display: grid; grid-template-columns: 80px 1fr 120px; align-items: center; padding: 0 48px; position: relative; }
  .hero-vertical { writing-mode: vertical-rl; justify-self: center; }
  .hero-vertical-text { font-size: 0.85rem; letter-spacing: 0.5em; color: #999; font-family: 'Noto Sans JP', sans-serif; }
  .hero-main h1 { font-size: clamp(2.2rem, 5vw, 4rem); font-weight: 700; line-height: 1.6; margin-bottom: 32px; }
  .hero-sub { display: block; font-size: 0.4em; font-weight: 400; letter-spacing: 0.2em; color: #999; margin-bottom: 16px; font-family: 'Noto Sans JP', sans-serif; }
  .hero-desc { font-size: 1rem; line-height: 2.2; color: #555; font-family: 'Noto Sans JP', sans-serif; font-weight: 300; }
  .hero-line { width: 60px; height: 1px; background: #2d2926; margin: 40px 0 28px; }
  .hero-cta { display: inline-block; padding: 14px 32px; background: #2d2926; color: #f7f5f0; font-family: 'Noto Sans JP', sans-serif; font-size: 0.9rem; letter-spacing: 0.1em; transition: opacity 0.2s, transform 0.2s; }
  .hero-cta:hover { opacity: 0.85; transform: translateY(-2px); }
  .hero-accent { writing-mode: vertical-rl; justify-self: center; display: flex; gap: 8px; }
  .hero-accent-char { font-size: 4rem; opacity: 0.05; font-weight: 700; }

  /* Photo strip */
  .photo-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; border-top: 1px solid #e0ddd5; border-bottom: 1px solid #e0ddd5; }
  .strip-img { aspect-ratio: 4 / 3; background-size: cover; background-position: center; filter: saturate(0.85); }

  /* About */
  .about { padding: 140px 48px; }
  .about-grid { display: grid; grid-template-columns: 200px 1fr; gap: 80px; max-width: 1000px; margin: 0 auto; }
  .about-label { display: flex; flex-direction: column; gap: 8px; }
  .section-num { font-family: 'Inter', sans-serif; font-size: 0.7rem; color: #bbb; letter-spacing: 0.1em; }
  .section-title { font-family: 'Inter', sans-serif; font-size: 0.8rem; letter-spacing: 0.15em; text-transform: uppercase; color: #999; }
  .about-content h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); line-height: 1.8; margin-bottom: 32px; font-weight: 700; }
  .about-content p { font-size: 0.95rem; line-height: 2.2; color: #555; font-family: 'Noto Sans JP', sans-serif; font-weight: 300; max-width: 600px; }
  .about-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; margin-top: 48px; padding-top: 40px; border-top: 1px solid #e0ddd5; }
  .stat { display: flex; flex-direction: column; gap: 6px; }
  .stat-num { font-size: 1.6rem; font-weight: 700; font-family: 'Inter', sans-serif; }
  .stat-label { font-size: 0.72rem; color: #999; font-family: 'Noto Sans JP', sans-serif; }

  /* Vision */
  .vision { padding: 140px 48px; position: relative; overflow: hidden; background: #2d2926; color: #f7f5f0; }
  .vision-bg-text { position: absolute; right: -30px; top: 50%; transform: translateY(-50%); font-size: 22rem; opacity: 0.04; font-weight: 700; pointer-events: none; }
  .vision-content { position: relative; z-index: 1; max-width: 1000px; margin: 0 auto; }
  .vision-content h2 { font-size: clamp(1.5rem, 3vw, 2.4rem); line-height: 1.8; margin: 24px 0 64px; font-weight: 700; }
  .vision-cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .vision-card { padding: 36px 0 0; border-top: 1px solid rgba(247, 245, 240, 0.18); }
  .vision-card-num { font-size: 1.4rem; opacity: 0.4; margin-bottom: 18px; }
  .vision-card h3 { font-size: 1.15rem; margin-bottom: 14px; font-weight: 700; line-height: 1.6; }
  .vision-card p { font-size: 0.85rem; line-height: 2; color: rgba(247, 245, 240, 0.65); font-family: 'Noto Sans JP', sans-serif; font-weight: 300; }

  /* News */
  .news { padding: 140px 48px; max-width: 1000px; margin: 0 auto; }
  .news-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 48px; }
  .news-head h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 700; }
  .news-en { font-family: 'Inter', sans-serif; font-size: 0.7em; color: #bbb; font-weight: 400; margin-left: 8px; letter-spacing: 0.1em; }
  .news-list { list-style: none; }
  .news-item { border-top: 1px solid #e0ddd5; }
  .news-item:last-child { border-bottom: 1px solid #e0ddd5; }
  .news-item a { display: grid; grid-template-columns: 110px 180px 1fr; gap: 20px; align-items: center; padding: 20px 8px; transition: background 0.2s; }
  .news-item a:hover { background: rgba(45, 41, 38, 0.04); }
  .news-thumb { aspect-ratio: 4 / 3; background-size: cover; background-position: center; border: 1px solid #e0ddd5; filter: saturate(0.85); }
  .news-meta { display: flex; flex-direction: column; gap: 6px; min-width: 0; }
  .news-item time { font-family: 'Inter', sans-serif; font-size: 0.82rem; color: #888; letter-spacing: 0.04em; }
  .news-tag { font-family: 'Noto Sans JP', sans-serif; font-size: 0.68rem; padding: 3px 10px; letter-spacing: 0.1em; text-align: center; align-self: flex-start; }
  .news-tag-press { background: #2d2926; color: #f7f5f0; }
  .news-tag-event { background: #c89344; color: #2d2926; }
  .news-tag-milestone { background: #6b8e57; color: #f7f5f0; }
  .news-title { font-size: 0.98rem; font-weight: 700; line-height: 1.7; min-width: 0; font-family: 'Noto Serif JP', serif; }

  /* Features */
  .features { padding: 140px 48px; max-width: 1100px; margin: 0 auto; border-top: 1px solid #e0ddd5; }
  .section-head { display: flex; align-items: baseline; gap: 16px; margin-bottom: 56px; }
  .section-head h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 700; }
  .features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px 28px; }
  .feature { padding-top: 28px; border-top: 1px solid #e0ddd5; }
  .feature-img { aspect-ratio: 4 / 3; background-size: cover; background-position: center; margin-bottom: 20px; filter: saturate(0.85); }
  .feature-icon { font-size: 1.6rem; margin-bottom: 14px; }
  .feature h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 10px; }
  .feature p { font-size: 0.85rem; line-height: 2; color: #666; font-family: 'Noto Sans JP', sans-serif; font-weight: 300; }

  /* Organizers */
  .organizers { padding: 140px 48px; max-width: 1000px; margin: 0 auto; border-top: 1px solid #e0ddd5; }
  .org-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .org-card { display: grid; grid-template-columns: 120px 1fr; gap: 24px; align-items: start; padding: 28px 0; border-top: 1px solid #e0ddd5; }
  .org-photo { aspect-ratio: 1/1; background-size: cover; background-position: center; }
  .org-mark { aspect-ratio: 1/1; background: #2d2926; color: #f7f5f0; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; }
  .org-initial { font-family: 'Noto Serif JP', serif; font-size: 3rem; font-weight: 900; line-height: 1; }
  .org-en { font-family: 'Inter', sans-serif; font-size: 0.62rem; letter-spacing: 0.22em; opacity: 0.7; }
  .org-kind { font-family: 'Inter', sans-serif; font-size: 0.62rem; letter-spacing: 0.22em; color: #999; display: block; margin-bottom: 6px; }
  .org-name { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
  .org-role { font-size: 0.78rem; color: #888; font-family: 'Noto Sans JP', sans-serif; margin-bottom: 12px; }
  .org-bio { font-size: 0.82rem; line-height: 2; color: #555; font-family: 'Noto Sans JP', sans-serif; font-weight: 300; margin-bottom: 12px; }
  .org-link { display: inline-block; font-family: 'Inter', sans-serif; font-size: 0.78rem; color: #2d2926; border-bottom: 1px solid #2d2926; padding-bottom: 2px; }
  .org-link:hover { opacity: 0.6; }

  /* CTA */
  .cta { padding: 160px 48px; text-align: center; background: #f0eee7; }
  .cta-inner { max-width: 640px; margin: 0 auto; }
  .cta-label { font-family: 'Inter', sans-serif; font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: #999; margin-bottom: 24px; }
  .cta h2 { font-size: clamp(1.5rem, 3vw, 2.4rem); line-height: 1.8; margin-bottom: 40px; font-weight: 700; }
  .steps { list-style: none; display: flex; flex-direction: column; gap: 0; max-width: 480px; margin: 0 auto 48px; text-align: left; }
  .steps li { display: flex; align-items: center; gap: 18px; padding: 18px 0; border-top: 1px solid #d8d4ca; font-family: 'Noto Sans JP', sans-serif; font-size: 0.92rem; }
  .steps li:last-child { border-bottom: 1px solid #d8d4ca; }
  .step-n { font-family: 'Inter', sans-serif; font-size: 0.85rem; color: #999; min-width: 28px; }
  .step-t { font-weight: 500; }
  .cta-button { display: inline-block; padding: 18px 48px; background: #2d2926; color: #f7f5f0; font-family: 'Noto Sans JP', sans-serif; font-size: 0.95rem; letter-spacing: 0.1em; transition: transform 0.3s ease, opacity 0.3s ease; }
  .cta-button:hover { transform: translateY(-2px); opacity: 0.85; }
  .cta-note { margin-top: 28px; font-size: 0.78rem; color: #999; font-family: 'Noto Sans JP', sans-serif; }

  .back-link { display: block; text-align: center; padding: 32px; font-family: 'Inter', sans-serif; font-size: 0.8rem; color: #999; border-top: 1px solid #e0ddd5; transition: color 0.3s; }
  .back-link:hover { color: #2d2926; }

  @media (max-width: 768px) {
    .nav { padding: 16px 22px; }
    .nav-links { gap: 16px; font-size: 0.78rem; }
    .hero { grid-template-columns: 1fr; padding: 120px 22px 60px; min-height: auto; }
    .hero-vertical, .hero-accent { display: none; }
    .about { padding: 80px 22px; }
    .about-grid { grid-template-columns: 1fr; gap: 32px; }
    .about-stats { grid-template-columns: repeat(2, 1fr); }
    .vision { padding: 80px 22px; }
    .vision-cards { grid-template-columns: 1fr; gap: 24px; }
    .news { padding: 80px 22px; }
    .news-item a { grid-template-columns: 110px 1fr; grid-template-rows: auto auto; gap: 8px 14px; padding: 18px 4px; }
    .news-thumb { grid-row: 1 / 3; }
    .features { padding: 80px 22px; }
    .features-grid { grid-template-columns: 1fr; gap: 0; }
    .organizers { padding: 70px 22px; }
    .org-grid { grid-template-columns: 1fr; gap: 0; }
    .org-card { grid-template-columns: 80px 1fr; gap: 18px; }
    .photo-strip { grid-template-columns: repeat(3, 1fr); }
    .cta { padding: 80px 22px; }
  }
</style>
