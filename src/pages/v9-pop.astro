---
import Base from '../layouts/Base.astro';
---

<Base title="ポップカラフル — 地域おこし協力隊DAO">
  <div class="pop">
    <!-- 装飾SVG（背景に散らす星と花） -->
    <svg class="deco deco-star deco-1" viewBox="0 0 100 100" aria-hidden="true">
      <path d="M50 5 L61 39 L97 39 L68 60 L79 95 L50 74 L21 95 L32 60 L3 39 L39 39 Z" fill="#FFD93D"/>
    </svg>
    <svg class="deco deco-flower deco-2" viewBox="0 0 100 100" aria-hidden="true">
      <g fill="#FF6B9D">
        <circle cx="50" cy="22" r="18"/>
        <circle cx="78" cy="50" r="18"/>
        <circle cx="50" cy="78" r="18"/>
        <circle cx="22" cy="50" r="18"/>
      </g>
      <circle cx="50" cy="50" r="12" fill="#FFD93D"/>
    </svg>
    <svg class="deco deco-blob deco-3" viewBox="0 0 200 200" aria-hidden="true">
      <path d="M44.1,-58.1C56.3,-48.2,64.5,-33.1,68.7,-16.9C72.9,-0.7,73.2,16.6,65.6,29.5C58,42.4,42.5,51,26.6,57.2C10.7,63.4,-5.6,67.2,-21.8,64.6C-38,62,-54.1,53,-63.2,39.2C-72.3,25.5,-74.4,7,-70.6,-9.3C-66.8,-25.5,-57.1,-39.6,-44.3,-49.4C-31.5,-59.3,-15.8,-65,0.8,-66C17.4,-67.1,31.8,-68,44.1,-58.1Z" transform="translate(100 100)" fill="#6BCB77"/>
    </svg>

    <!-- Navigation -->
    <nav class="nav">
      <div class="nav-logo">
        <span class="nav-logo-dot"></span>
        協力隊DAO
      </div>
      <div class="nav-links">
        <a href="#about">知る</a>
        <a href="#vision">理念</a>
        <a href="#join" class="nav-cta">参加する</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        Regional DAO Community
      </div>
      <h1 class="hero-title">
        <span class="hero-word hero-word-1">地域</span>を、<br />
        <span class="hero-word hero-word-2">みんな</span>で、<br />
        <span class="hero-word hero-word-3">おもしろく。</span>
      </h1>
      <p class="hero-desc">
        全国の協力隊員がDAOでつながる。<br />
        知恵を持ちより、地域の未来をたのしく共創する。
      </p>
      <div class="hero-ctas">
        <a href="#join" class="btn btn-primary">コミュニティに参加する →</a>
        <a href="#about" class="btn btn-ghost">まずは知る</a>
      </div>

      <!-- 浮遊パーツ -->
      <div class="float float-a"></div>
      <div class="float float-b"></div>
      <div class="float float-c"></div>
      <svg class="hero-wave" viewBox="0 0 1440 120" preserveAspectRatio="none" aria-hidden="true">
        <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="#FFD93D"/>
      </svg>
    </section>

    <!-- About -->
    <section id="about" class="about">
      <div class="about-inner">
        <div class="sec-label">
          <span class="sec-num">01</span>
          <span class="sec-tag">About</span>
        </div>
        <h2 class="about-h">
          DAOって、<br />
          <span class="marker">みんなでつくる</span>場所。
        </h2>
        <p class="about-p">
          地域おこし協力隊DAOは、経験者・現役隊員・地域に関わるすべての人をつなぐ、分散型コミュニティ。株式会社あるやうむが運営し、Web3の仕組みを活用しながら、地域課題の解決と新しい価値の共創に取り組んでいます。
        </p>

        <div class="stats">
          <div class="stat stat-pink">
            <div class="stat-num">47</div>
            <div class="stat-label">都道府県</div>
          </div>
          <div class="stat stat-yellow">
            <div class="stat-num">DAO</div>
            <div class="stat-label">自律分散型組織</div>
          </div>
          <div class="stat stat-green">
            <div class="stat-num">∞</div>
            <div class="stat-label">共創のカタチ</div>
          </div>
          <div class="stat stat-blue">
            <div class="stat-num">Web3</div>
            <div class="stat-label">新しい仕組み</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Vision -->
    <section id="vision" class="vision">
      <div class="vision-inner">
        <div class="sec-label sec-label-light">
          <span class="sec-num">02</span>
          <span class="sec-tag">Vision</span>
        </div>
        <h2 class="vision-h">
          一人では小さくても、<br />
          みんなで動けば、<span class="hl">地域は変わる。</span>
        </h2>

        <div class="cards">
          <div class="card card-pink">
            <div class="card-num">01</div>
            <div class="card-icon">
              <svg viewBox="0 0 64 64" aria-hidden="true">
                <circle cx="32" cy="32" r="28" fill="#FFF8E7"/>
                <circle cx="22" cy="28" r="5" fill="#1a1a3a"/>
                <circle cx="42" cy="28" r="5" fill="#1a1a3a"/>
                <path d="M20 42 Q32 52 44 42" stroke="#1a1a3a" stroke-width="3" fill="none" stroke-linecap="round"/>
              </svg>
            </div>
            <h3>知恵の共有</h3>
            <p>各地の協力隊員が持つノウハウ・経験を、コミュニティの資産として蓄積し、次の挑戦者へ受け継ぐ。</p>
          </div>

          <div class="card card-yellow">
            <div class="card-num">02</div>
            <div class="card-icon">
              <svg viewBox="0 0 64 64" aria-hidden="true">
                <circle cx="18" cy="32" r="10" fill="#FF6B9D"/>
                <circle cx="46" cy="32" r="10" fill="#4D96FF"/>
                <circle cx="32" cy="32" r="10" fill="#6BCB77" fill-opacity="0.9"/>
              </svg>
            </div>
            <h3>越境する協働</h3>
            <p>地域の壁を越えて、共通の課題を持つ隊員同士がプロジェクトを立ち上げ、協働する場を提供する。</p>
          </div>

          <div class="card card-blue">
            <div class="card-num">03</div>
            <div class="card-icon">
              <svg viewBox="0 0 64 64" aria-hidden="true">
                <path d="M32 8 L38 26 L56 26 L42 38 L48 56 L32 44 L16 56 L22 38 L8 26 L26 26 Z" fill="#FFD93D"/>
              </svg>
            </div>
            <h3>持続する仕組み</h3>
            <p>DAOの仕組みを活用し、特定の誰かに依存しない、持続可能なコミュニティ運営を実現していく。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="join" class="cta">
      <div class="cta-inner">
        <svg class="cta-star cta-star-1" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M50 5 L61 39 L97 39 L68 60 L79 95 L50 74 L21 95 L32 60 L3 39 L39 39 Z" fill="#FF6B9D"/>
        </svg>
        <svg class="cta-star cta-star-2" viewBox="0 0 100 100" aria-hidden="true">
          <path d="M50 5 L61 39 L97 39 L68 60 L79 95 L50 74 L21 95 L32 60 L3 39 L39 39 Z" fill="#4D96FF"/>
        </svg>

        <p class="cta-label">Join the DAO</p>
        <h2 class="cta-h">
          あなたの地域の物語を、<br />
          <span class="cta-hl">ここから</span>はじめよう。
        </h2>
        <a href="#" class="btn btn-big">コミュニティに参加する →</a>
        <p class="cta-note">運営: 株式会社あるやうむ</p>
      </div>
    </section>

    <a href="/" class="back-link">← デザイン一覧に戻る</a>
  </div>
</Base>

<style>
  .pop {
    font-family: 'Noto Sans JP', 'Inter', sans-serif;
    color: #1a1a3a;
    background: #FFF8E7;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
  }

  /* 背景装飾 */
  .deco {
    position: absolute;
    pointer-events: none;
    z-index: 0;
  }
  .deco-star.deco-1 {
    width: 80px; height: 80px;
    top: 18%; right: 8%;
    animation: spin 18s linear infinite;
  }
  .deco-flower.deco-2 {
    width: 110px; height: 110px;
    top: 70%; left: 4%;
    animation: bob 6s ease-in-out infinite;
  }
  .deco-blob.deco-3 {
    width: 320px; height: 320px;
    top: 42%; right: -80px;
    opacity: 0.35;
    animation: bob 10s ease-in-out infinite reverse;
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(8deg); }
  }
  @keyframes tilt {
    0%, 100% { transform: rotate(-2deg); }
    50% { transform: rotate(2deg); }
  }

  /* Nav */
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(255, 248, 231, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid #1a1a3a;
  }
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
    font-size: 1.05rem;
    letter-spacing: 0.05em;
  }
  .nav-logo-dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: #FF6B9D;
    box-shadow: 0 0 0 3px #FFD93D;
  }
  .nav-links {
    display: flex;
    gap: 28px;
    align-items: center;
    font-size: 0.9rem;
    font-weight: 700;
  }
  .nav-links a {
    transition: color 0.2s;
  }
  .nav-links a:hover { color: #FF6B9D; }
  .nav-cta {
    padding: 10px 20px;
    background: #1a1a3a;
    color: #FFF8E7 !important;
    border-radius: 999px;
    border: 2px solid #1a1a3a;
    transition: transform 0.2s, background 0.2s;
  }
  .nav-cta:hover {
    background: #FF6B9D;
    transform: translateY(-2px);
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    padding: 140px 48px 180px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    border: 2px solid #1a1a3a;
    border-radius: 999px;
    background: #FFD93D;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-bottom: 32px;
    transform: rotate(-1.5deg);
  }
  .hero-badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #FF6B9D;
    animation: pulse 1.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.6; }
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 6rem);
    font-weight: 900;
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: 36px;
  }
  .hero-word {
    display: inline-block;
    padding: 0 16px;
    border-radius: 999px;
    position: relative;
  }
  .hero-word-1 {
    background: #FF6B9D;
    color: #FFF8E7;
    transform: rotate(-2deg);
    animation: tilt 4s ease-in-out infinite;
  }
  .hero-word-2 {
    background: #4D96FF;
    color: #FFF8E7;
    transform: rotate(1.5deg);
    animation: tilt 4s ease-in-out infinite 0.5s;
  }
  .hero-word-3 {
    background: #6BCB77;
    color: #1a1a3a;
    transform: rotate(-1deg);
    animation: tilt 4s ease-in-out infinite 1s;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 2;
    color: #3a3a5a;
    max-width: 520px;
    margin-bottom: 40px;
    font-weight: 500;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-block;
    padding: 16px 32px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.95rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    border: 2px solid #1a1a3a;
  }
  .btn-primary {
    background: #FF6B9D;
    color: #FFF8E7;
    box-shadow: 4px 4px 0 #1a1a3a;
  }
  .btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #1a1a3a;
  }
  .btn-ghost {
    background: #FFF8E7;
    color: #1a1a3a;
  }
  .btn-ghost:hover {
    background: #FFD93D;
    transform: translateY(-2px);
  }
  .btn-big {
    padding: 22px 48px;
    font-size: 1.05rem;
    background: #FFD93D;
    color: #1a1a3a;
    box-shadow: 6px 6px 0 #1a1a3a;
  }
  .btn-big:hover {
    transform: translate(-3px, -3px);
    box-shadow: 9px 9px 0 #1a1a3a;
  }

  /* 浮遊パーツ */
  .float {
    position: absolute;
    border-radius: 50%;
    z-index: -1;
  }
  .float-a {
    width: 100px; height: 100px;
    background: #4D96FF;
    top: 12%;
    left: 42%;
    animation: bob 7s ease-in-out infinite;
  }
  .float-b {
    width: 60px; height: 60px;
    background: #FF6B9D;
    bottom: 30%;
    left: 55%;
    animation: bob 5s ease-in-out infinite 0.5s;
  }
  .float-c {
    width: 140px; height: 140px;
    background: #6BCB77;
    top: 55%;
    left: 68%;
    opacity: 0.4;
    animation: bob 9s ease-in-out infinite 1s;
  }

  .hero-wave {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    width: 100%;
    height: 90px;
    display: block;
  }

  /* About */
  .about {
    background: #FFD93D;
    padding: 140px 48px;
    position: relative;
    z-index: 1;
    border-top: 3px solid #1a1a3a;
    border-bottom: 3px solid #1a1a3a;
  }
  .about-inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .sec-label {
    display: inline-flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 28px;
    font-family: 'Inter', sans-serif;
  }
  .sec-num {
    font-size: 0.85rem;
    font-weight: 700;
    padding: 4px 12px;
    background: #1a1a3a;
    color: #FFF8E7;
    border-radius: 999px;
  }
  .sec-tag {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .about-h {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.35;
    font-weight: 900;
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }
  .marker {
    background: linear-gradient(transparent 55%, #FF6B9D 55%);
    padding: 0 4px;
  }
  .about-p {
    font-size: 1rem;
    line-height: 2.1;
    max-width: 720px;
    font-weight: 500;
    margin-bottom: 56px;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .stat {
    padding: 32px 24px;
    border-radius: 28px;
    border: 3px solid #1a1a3a;
    text-align: center;
    transition: transform 0.25s;
  }
  .stat:hover {
    transform: translateY(-6px) rotate(-1deg);
  }
  .stat-pink { background: #FF6B9D; color: #FFF8E7; }
  .stat-yellow { background: #FFF8E7; }
  .stat-green { background: #6BCB77; color: #1a1a3a; }
  .stat-blue { background: #4D96FF; color: #FFF8E7; }
  .stat-num {
    font-family: 'Inter', sans-serif;
    font-size: 2.4rem;
    font-weight: 900;
    line-height: 1;
    margin-bottom: 10px;
  }
  .stat-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  /* Vision */
  .vision {
    background: #1a1a3a;
    color: #FFF8E7;
    padding: 140px 48px;
    position: relative;
    z-index: 1;
    overflow: hidden;
  }
  .vision::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 300px; height: 300px;
    border-radius: 50%;
    background: #FF6B9D;
    opacity: 0.25;
    z-index: 0;
  }
  .vision::after {
    content: '';
    position: absolute;
    bottom: -100px; left: -60px;
    width: 260px; height: 260px;
    border-radius: 50%;
    background: #6BCB77;
    opacity: 0.22;
    z-index: 0;
  }
  .vision-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .sec-label-light .sec-num {
    background: #FFD93D;
    color: #1a1a3a;
  }
  .sec-label-light .sec-tag { color: #FFF8E7; }

  .vision-h {
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.4;
    font-weight: 900;
    margin-bottom: 64px;
    letter-spacing: -0.01em;
  }
  .hl {
    color: #FFD93D;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }
  .card {
    padding: 36px 28px;
    border-radius: 32px;
    border: 3px solid #1a1a3a;
    color: #1a1a3a;
    position: relative;
    transition: transform 0.3s;
  }
  .card:hover {
    transform: translateY(-8px) rotate(-1deg);
  }
  .card-pink { background: #FF6B9D; color: #FFF8E7; }
  .card-yellow { background: #FFD93D; }
  .card-blue { background: #4D96FF; color: #FFF8E7; }

  .card-num {
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 800;
    padding: 4px 12px;
    background: #FFF8E7;
    color: #1a1a3a;
    border-radius: 999px;
    border: 2px solid #1a1a3a;
    display: inline-block;
    margin-bottom: 20px;
  }
  .card-icon {
    width: 72px; height: 72px;
    background: #FFF8E7;
    border-radius: 50%;
    border: 3px solid #1a1a3a;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
  }
  .card-icon svg {
    width: 52px; height: 52px;
  }
  .card h3 {
    font-size: 1.35rem;
    font-weight: 900;
    margin-bottom: 12px;
  }
  .card p {
    font-size: 0.9rem;
    line-height: 1.9;
    font-weight: 500;
  }

  /* CTA */
  .cta {
    background: #FFEAF2;
    padding: 160px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
    z-index: 1;
  }
  .cta-inner {
    max-width: 720px;
    margin: 0 auto;
    position: relative;
  }
  .cta-star {
    position: absolute;
    pointer-events: none;
  }
  .cta-star-1 {
    width: 70px; height: 70px;
    top: -40px; left: 10%;
    animation: spin 14s linear infinite;
  }
  .cta-star-2 {
    width: 55px; height: 55px;
    bottom: -30px; right: 12%;
    animation: spin 20s linear infinite reverse;
  }

  .cta-label {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #1a1a3a;
    padding: 6px 16px;
    background: #FFD93D;
    border-radius: 999px;
    border: 2px solid #1a1a3a;
    margin-bottom: 28px;
  }
  .cta-h {
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.4;
    font-weight: 900;
    margin-bottom: 48px;
    letter-spacing: -0.01em;
  }
  .cta-hl {
    color: #FF6B9D;
  }
  .cta-note {
    margin-top: 32px;
    font-size: 0.85rem;
    color: #3a3a5a;
    font-weight: 600;
  }

  .back-link {
    display: block;
    text-align: center;
    padding: 32px;
    font-family: 'Inter', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: #1a1a3a;
    background: #FFF8E7;
    border-top: 3px solid #1a1a3a;
    transition: background 0.2s, color 0.2s;
  }
  .back-link:hover {
    background: #1a1a3a;
    color: #FFD93D;
  }

  @media (max-width: 768px) {
    .nav {
      padding: 14px 20px;
    }
    .nav-links { gap: 14px; font-size: 0.8rem; }
    .nav-cta { padding: 8px 14px; }

    .hero {
      padding: 120px 24px 140px;
    }
    .hero-title {
      line-height: 1.25;
    }
    .hero-word {
      padding: 0 10px;
    }
    .hero-ctas { flex-direction: column; }
    .btn { text-align: center; }

