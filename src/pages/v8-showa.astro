---
import Base from '../layouts/Base.astro';
---

<Base title="昭和レトロ — 地域おこし協力隊DAO">
  <div class="showa">
    <!-- Navigation -->
    <nav class="nav">
      <div class="nav-inner">
        <div class="nav-logo">
          <span class="nav-logo-mark">◉</span>
          <span class="nav-logo-text">協力隊DAO</span>
        </div>
        <div class="nav-links">
          <a href="#about">知る</a>
          <a href="#vision">理念</a>
          <a href="#join">参加する</a>
        </div>
      </div>
      <div class="nav-rule"></div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-noise"></div>
      <div class="hero-stamp">
        <span class="hero-stamp-text">NO. 昭和九拾九年</span>
      </div>
      <div class="hero-inner">
        <div class="hero-kicker">
          <span class="hero-kicker-line"></span>
          <span class="hero-kicker-text">地域おこし協力隊 DAO</span>
          <span class="hero-kicker-line"></span>
        </div>
        <h1 class="hero-title">
          <span class="hero-title-row">つながれば、</span>
          <span class="hero-title-row hero-title-accent">里は灯る。</span>
        </h1>
        <div class="hero-divider">
          <span class="hero-divider-dot">◆</span>
        </div>
        <p class="hero-desc">
          全国津々浦々の協力隊員が、ひとつの寄合に集う。<br />
          知恵を持ち寄り、地域の未来を共に耕す、<br />
          新時代の自律分散型コミュニティ。
        </p>
        <div class="hero-cta-row">
          <a href="#join" class="hero-cta">▶ 入会のご案内</a>
          <a href="#about" class="hero-sub-link">詳しく知る ／</a>
        </div>
      </div>
      <div class="hero-marquee">
        <span>HOMETOWN ★ DAO ★ WEB3 ★ COMMUNITY ★ SINCE 20XX ★ HOMETOWN ★ DAO ★ WEB3 ★ COMMUNITY ★ SINCE 20XX ★</span>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="about">
      <div class="about-header">
        <span class="section-num">［第壱号］</span>
        <h2 class="about-h2">地域おこし協力隊DAO<br />とは何ぞや</h2>
        <div class="about-rule"></div>
      </div>
      <div class="about-body">
        <p class="about-lead">
          地域おこし協力隊の経験者・現役隊員・地域に関わる有志を結ぶ、分散型の寄合所。株式会社あるやうむが運営し、ウェブ参の仕組みを活用しながら、地域課題の解決と新しい価値の創造に取り組んでおります。
        </p>
        <div class="about-stats">
          <div class="stat">
            <span class="stat-cap">一</span>
            <span class="stat-num">47</span>
            <span class="stat-label">都道府県</span>
          </div>
          <div class="stat">
            <span class="stat-cap">二</span>
            <span class="stat-num">DAO</span>
            <span class="stat-label">自律分散型組織</span>
          </div>
          <div class="stat">
            <span class="stat-cap">三</span>
            <span class="stat-num">共創</span>
            <span class="stat-label">隊員 × 地域 × 技術</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Vision -->
    <section id="vision" class="vision">
      <div class="vision-noise"></div>
      <div class="vision-header">
        <span class="section-num light">［第弐号］</span>
        <h2 class="vision-h2">
          一人の力は微かなれど、<br />
          集えば、地は動く。
        </h2>
      </div>
      <div class="vision-cards">
        <article class="vision-card">
          <div class="vision-card-head">
            <span class="vision-card-num">壱</span>
            <span class="vision-card-en">CHIE</span>
          </div>
          <h3>知恵の持ち寄り</h3>
          <p>各地の協力隊員が培うたノウハウ・経験を、コミュニティ全体の財産として蓄え、次の挑戦者へと手渡してゆく。</p>
        </article>
        <article class="vision-card">
          <div class="vision-card-head">
            <span class="vision-card-num">弐</span>
            <span class="vision-card-en">ETSUKYO</span>
          </div>
          <h3>越境する協働</h3>
          <p>地域の垣根を越えて、共通の課題を持つ隊員同士が肩を組み、プロジェクトを立ち上げる場を提供する。</p>
        </article>
        <article class="vision-card">
          <div class="vision-card-head">
            <span class="vision-card-num">参</span>
            <span class="vision-card-en">JIZOKU</span>
          </div>
          <h3>続いてゆく仕組み</h3>
          <p>DAOの仕組みを活かし、特定の誰かに寄りかからぬ、末長く続くコミュニティ運営を実らせる。</p>
        </article>
      </div>
    </section>

    <!-- CTA -->
    <section id="join" class="cta">
      <div class="cta-noise"></div>
      <div class="cta-inner">
        <div class="cta-badge">
          <span class="cta-badge-outer">★</span>
          <span class="cta-badge-text">入会募集中</span>
          <span class="cta-badge-outer">★</span>
        </div>
        <h2 class="cta-h2">
          あなたの町の物語を、<br />
          此処から始めませんか。
        </h2>
        <p class="cta-desc">
          地域を想う隊員同士の寄合へ、<br />どうぞお気軽にお越しください。
        </p>
        <a href="#" class="cta-button">
          <span class="cta-button-label">コミュニティに参加する</span>
          <span class="cta-button-arrow">▶</span>
        </a>
        <div class="cta-meta">
          <div class="cta-meta-line"></div>
          <p class="cta-note">運営 ／ 株式会社あるやうむ</p>
          <p class="cta-note-small">ARUYAUMU INC.　—　HOKKAIDO, JAPAN</p>
        </div>
      </div>
    </section>

    <a href="/" class="back-link">← デザイン一覧に戻る</a>
  </div>
</Base>

<style>
  .showa {
    font-family: 'BIZ UDGothic', 'Noto Sans JP', sans-serif;
    color: #2a1f15;
    background: #f4ead5;
    min-height: 100vh;
    font-weight: 400;
    position: relative;
  }

  .showa::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(rgba(42, 31, 21, 0.08) 1px, transparent 1px),
      radial-gradient(rgba(42, 31, 21, 0.05) 1px, transparent 1px);
    background-size: 3px 3px, 7px 7px;
    background-position: 0 0, 1px 2px;
    pointer-events: none;
    z-index: 1;
    opacity: 0.7;
  }

  .showa > * {
    position: relative;
    z-index: 2;
  }

  /* Nav */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: #f4ead5;
    border-bottom: 3px double #2a1f15;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .nav-rule {
    height: 2px;
    background: #2a1f15;
    margin-top: 2px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1.05rem;
    letter-spacing: 0.1em;
  }

  .nav-logo-mark {
    color: #8b2e1a;
    font-size: 1rem;
  }

  .nav-links {
    display: flex;
    gap: 28px;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .nav-links a {
    letter-spacing: 0.12em;
    padding: 4px 10px;
    border: 1.5px solid transparent;
    transition: all 0.2s;
  }

  .nav-links a:hover {
    border-color: #2a1f15;
    background: #d4923c;
    color: #f4ead5;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    padding: 120px 40px 0;
    position: relative;
    background:
      linear-gradient(135deg, rgba(212, 146, 60, 0.12) 0%, rgba(244, 234, 213, 0) 60%),
      repeating-linear-gradient(45deg, rgba(139, 46, 26, 0.04) 0 2px, transparent 2px 18px),
      #f4ead5;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .hero-stamp {
    position: absolute;
    top: 140px;
    right: 50px;
    transform: rotate(-8deg);
    border: 2px solid #8b2e1a;
    padding: 10px 18px;
    color: #8b2e1a;
    font-family: 'Inter', 'BIZ UDGothic', sans-serif;
    font-weight: 700;
    font-size: 0.75rem;
    letter-spacing: 0.25em;
    opacity: 0.85;
  }

  .hero-stamp::before {
    content: '';
    position: absolute;
    inset: 3px;
    border: 1px solid #8b2e1a;
    pointer-events: none;
  }

  .hero-inner {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    max-width: 960px;
    margin: 0 auto;
    width: 100%;
    padding: 40px 0;
  }

  .hero-kicker {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 36px;
    color: #8b2e1a;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.3em;
  }

  .hero-kicker-line {
    width: 40px;
    height: 2px;
    background: #8b2e1a;
  }

  .hero-title {
    font-family: 'BIZ UDGothic', 'Noto Sans JP', sans-serif;
    font-weight: 700;
    font-size: clamp(2.6rem, 7vw, 5.2rem);
    line-height: 1.25;
    letter-spacing: 0.04em;
    text-shadow: 4px 4px 0 rgba(212, 146, 60, 0.35);
  }

  .hero-title-row {
    display: block;
  }

  .hero-title-accent {
    color: #8b2e1a;
    text-shadow: 4px 4px 0 rgba(45, 74, 43, 0.18);
  }

  .hero-divider {
    margin: 32px 0;
    width: 100%;
    max-width: 480px;
    border-top: 3px double #2a1f15;
    position: relative;
    height: 14px;
  }

  .hero-divider-dot {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background: #f4ead5;
    padding: 0 12px;
    color: #2d4a2b;
    font-size: 0.9rem;
  }

  .hero-desc {
    font-size: 1.02rem;
    line-height: 2.15;
    color: #4a3828;
    max-width: 620px;
    font-weight: 400;
  }

  .hero-cta-row {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-top: 44px;
    flex-wrap: wrap;
  }

  .hero-cta {
    display: inline-block;
    padding: 16px 36px;
    background: #2d4a2b;
    color: #f4ead5;
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: 0.15em;
    border: 2px solid #2a1f15;
    box-shadow: 5px 5px 0 #2a1f15;
    transition: all 0.15s;
  }

  .hero-cta:hover {
    transform: translate(3px, 3px);
    box-shadow: 2px 2px 0 #2a1f15;
    background: #8b2e1a;
  }

  .hero-sub-link {
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    color: #2a1f15;
    border-bottom: 2px solid #2a1f15;
    padding-bottom: 4px;
  }

  .hero-marquee {
    margin: 60px -40px 0;
    background: #8b2e1a;
    color: #f4ead5;
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
    border-top: 2px solid #2a1f15;
    border-bottom: 2px solid #2a1f15;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.25em;
  }

  .hero-marquee span {
    display: inline-block;
    animation: marquee 28s linear infinite;
    padding-left: 100%;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  /* About */
  .about {
    padding: 120px 40px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .about-header {
    text-align: center;
    margin-bottom: 64px;
  }

  .section-num {
    display: inline-block;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: #d4923c;
    background: #2a1f15;
    padding: 6px 16px;
    margin-bottom: 24px;
  }

  .section-num.light {
    background: #d4923c;
    color: #2a1f15;
  }

  .about-h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.6;
    letter-spacing: 0.02em;
    font-family: 'BIZ UDGothic', 'Noto Sans JP', sans-serif;
  }

  .about-rule {
    width: 80px;
    height: 5px;
    background: #8b2e1a;
    margin: 28px auto 0;
    position: relative;
  }

  .about-rule::before,
  .about-rule::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 20px;
    height: 1.5px;
    background: #8b2e1a;
    transform: translateY(-50%);
  }

  .about-rule::before { left: -40px; }
  .about-rule::after { right: -40px; }

  .about-body {
    max-width: 820px;
    margin: 0 auto;
  }

  .about-lead {
    font-size: 1rem;
    line-height: 2.2;
    text-align: justify;
    margin-bottom: 64px;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    padding: 40px 0;
    border-top: 3px double #2a1f15;
    border-bottom: 3px double #2a1f15;
  }

  .stat {
    text-align: center;
    padding: 0 12px;
    border-right: 1px dashed rgba(42, 31, 21, 0.3);
  }

  .stat:last-child {
    border-right: none;
  }

  .stat-cap {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #8b2e1a;
    margin-bottom: 10px;
    letter-spacing: 0.2em;
  }

  .stat-num {
    display: block;
    font-size: 2.8rem;
    font-weight: 700;
    color: #2d4a2b;
    font-family: 'BIZ UDGothic', 'Noto Serif JP', serif;
    letter-spacing: 0.02em;
    margin-bottom: 8px;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: #4a3828;
    letter-spacing: 0.1em;
    font-weight: 700;
  }

  /* Vision */
  .vision {
    padding: 120px 40px;
    background:
      repeating-linear-gradient(90deg, rgba(244, 234, 213, 0.04) 0 4px, transparent 4px 20px),
      #2d4a2b;
    color: #f4ead5;
    position: relative;
    overflow: hidden;
    border-top: 4px solid #2a1f15;
    border-bottom: 4px solid #2a1f15;
  }

  .vision::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(244, 234, 213, 0.05) 1px, transparent 1px);
    background-size: 4px 4px;
    pointer-events: none;
  }

  .vision-header {
    max-width: 1100px;
    margin: 0 auto 72px;
    position: relative;
  }

  .vision-h2 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    line-height: 1.7;
    letter-spacing: 0.03em;
    margin-top: 20px;
  }

  .vision-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
  }

  .vision-card {
    background: #f4ead5;
    color: #2a1f15;
    padding: 36px 30px;
    border: 2px solid #2a1f15;
    box-shadow: 7px 7px 0 #d4923c;
    position: relative;
  }

  .vision-card::before {
    content: '';
    position: absolute;
    inset: 6px;
    border: 1px solid rgba(42, 31, 21, 0.2);
    pointer-events: none;
  }

  .vision-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 16px;
    margin-bottom: 20px;
    border-bottom: 2px solid #8b2e1a;
  }

  .vision-card-num {
    font-size: 2.4rem;
    font-weight: 700;
    color: #8b2e1a;
    font-family: 'Noto Serif JP', serif;
    line-height: 1;
  }

  .vision-card-en {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: #d4923c;
    background: #2a1f15;
    padding: 4px 10px;
    font-family: 'Inter', sans-serif;
  }

  .vision-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 14px;
    letter-spacing: 0.05em;
  }

  .vision-card p {
    font-size: 0.88rem;
    line-height: 2;
    color: #4a3828;
  }

  /* CTA */
  .cta {
    padding: 120px 40px;
    text-align: center;
    background:
      radial-gradient(circle at 50% 40%, rgba(212, 146, 60, 0.22) 0%, rgba(244, 234, 213, 0) 55%),
      #f4ead5;
    position: relative;
  }

  .cta-inner {
    max-width: 680px;
    margin: 0 auto;
  }

  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 22px;
    background: #8b2e1a;
    color: #f4ead5;
    font-weight: 700;
    font-size: 0.85rem;
    letter-spacing: 0.25em;
    margin-bottom: 36px;
    border: 2px solid #2a1f15;
    box-shadow: 4px 4px 0 #2a1f15;
  }

  .cta-badge-outer {
    color: #d4923c;
  }

  .cta-h2 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 700;
    line-height: 1.7;
    letter-spacing: 0.03em;
    margin-bottom: 28px;
  }

  .cta-h2::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: #8b2e1a;
    margin: 24px auto 0;
  }

  .cta-desc {
    font-size: 0.95rem;
    line-height: 2;
    color: #4a3828;
    margin-bottom: 48px;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    padding: 20px 48px;
    background: #2a1f15;
    color: #f4ead5;
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: 0.18em;
    border: 2px solid #2a1f15;
    box-shadow: 6px 6px 0 #d4923c;
    transition: all 0.15s;
  }

  .cta-button:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 #d4923c;
    background: #8b2e1a;
  }

  .cta-button-arrow {
    font-size: 0.8rem;
    color: #d4923c;
  }

  .cta-meta {
    margin-top: 72px;
  }

  .cta-meta-line {
    width: 120px;
    height: 1px;
    background: #2a1f15;
    margin: 0 auto 24px;
  }

  .cta-note {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: #2a1f15;
    margin-bottom: 8px;
  }

  .cta-note-small {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    color: #8b2e1a;
    font-family: 'Inter', sans-serif;
    font-weight: 500;
  }

  /* Back */
  .back-link {
    display: block;
    text-align: center;
    padding: 28px;
    font-size: 0.85rem;
    font-weight: 700;
    color: #4a3828;
    background: #2a1f15;
    color: #f4ead5;
    letter-spacing: 0.15em;
    transition: all 0.2s;
  }

  .back-link:hover {
    background: #8b2e1a;
    color: #d4923c;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .nav-inner { padding: 12px 20px; }
    .nav-links { gap: 14px; font-size: 0.78rem; }
    .nav-links a { padding: 3px 6px; }

    .hero {
      padding: 110px 22px 0;
      min-height: auto;
    }
    .hero-stamp {
      top: 95px;
      right: 18px;
      font-size: 0.65rem;
      padding: 8px 12px;
    }
    .hero-inner { padding: 20px 0; }
    .hero-kicker { font-size: 0.72rem; gap: 10px; margin-bottom: 24px; }
    .hero-kicker-line { width: 22px; }
    .hero-title { text-shadow: 3px 3px 0 rgba(212, 146, 60, 0.3); }
    .hero-divider { margin: 24px 0; }
    .hero-desc { font-size: 0.92rem; line-height: 2; }
    .hero-cta-row { gap: 18px; margin-top: 32px; }
    .hero-cta { padding: 14px 24px; font-size: 0.85rem; }
    .hero-marquee { margin: 48px -22px 0; font-size: 0.75rem; }

    .about { padding: 72px 22px; }
    .about-header { margin-bottom: 44px; }
    .about-rule::before, .about-rule::after { display: none; }
    .about-lead { font-size: 0.92rem; line-height: 2; margin-bottom: 40px; }
    .about-stats {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 28px 0;
    }
    .stat {
