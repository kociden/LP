---
import Base from '../layouts/Base.astro';
---

<Base title="ネオブルータリズム — 地域おこし協力隊DAO">
  <div class="brut">
    <!-- Navigation -->
    <nav class="nav">
      <div class="nav-logo">
        <span class="logo-mark">[▚]</span>
        <span class="logo-text">KYORYOKUTAI_DAO</span>
      </div>
      <div class="nav-links">
        <a href="#about">知る/ABOUT</a>
        <a href="#vision">理念/VISION</a>
        <a href="#join" class="nav-cta">参加する →</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-ticker">
        <span>// LIVE</span>
        <span>NODE_COUNT: 047</span>
        <span>TIMESTAMP: 2026.04</span>
        <span>STATUS: OPEN</span>
      </div>
      <div class="hero-grid">
        <div class="hero-tag">
          <span class="tag-num">No.006</span>
          <span class="tag-label">REGIONAL × DAO × WEB3</span>
        </div>
        <h1 class="hero-title">
          <span class="title-line-1">地域を</span>
          <span class="title-line-2">ハック<span class="title-slash">/</span>せよ。</span>
        </h1>
        <div class="hero-block">
          <p class="hero-desc">
            全国の地域おこし協力隊が<br />
            DAOでつながり、<br />
            地域課題を <span class="mark">共創</span> する。
          </p>
        </div>
        <div class="hero-ctas">
          <a href="#join" class="btn-primary">NOW_JOIN →</a>
          <a href="#about" class="btn-ghost">↓ 詳しく</a>
        </div>
      </div>
      <div class="hero-sticker sticker-1">REGIONAL<br/>REVOLT</div>
      <div class="hero-sticker sticker-2">★ DAO ★</div>
    </section>

    <!-- About -->
    <section id="about" class="about">
      <div class="section-head">
        <span class="section-num">[01]</span>
        <span class="section-label">ABOUT // 地域おこし協力隊DAOとは</span>
      </div>
      <div class="about-grid">
        <h2 class="about-h2">
          地域と<br />
          <span class="hl-yellow">Web3</span> の、<br />
          生々しい交差点。
        </h2>
        <div class="about-text">
          <p>
            地域おこし協力隊DAOは、全国の現役・元協力隊員、そして地域に関わるすべての人をつなぐ分散型コミュニティだ。株式会社あるやうむが運営し、DAOの仕組みで知見と熱量を束ねる。
          </p>
          <p>
            肩書きも、地域も、世代も関係ない。やりたい奴が、やる。
          </p>
        </div>
      </div>
      <div class="stats">
        <div class="stat-card">
          <span class="stat-num">47</span>
          <span class="stat-label">都道府県 / PREFECTURES</span>
        </div>
        <div class="stat-card stat-card-alt">
          <span class="stat-num">DAO</span>
          <span class="stat-label">自律分散型 / DECENTRALIZED</span>
        </div>
        <div class="stat-card stat-card-blue">
          <span class="stat-num">∞</span>
          <span class="stat-label">共創の余地 / OPEN SOURCE</span>
        </div>
      </div>
    </section>

    <!-- Vision -->
    <section id="vision" class="vision">
      <div class="vision-head">
        <span class="section-num inv">[02]</span>
        <span class="section-label inv">VISION // 三本の柱</span>
      </div>
      <h2 class="vision-h2">
        一人の力は小さい。<br />
        <span class="hl-vermi">繋がれば、</span>地域が動く。
      </h2>
      <div class="vision-cards">
        <article class="v-card">
          <div class="v-card-top">
            <span class="v-num">01</span>
            <span class="v-dot">●</span>
          </div>
          <h3>知恵の共有</h3>
          <p>各地の隊員が持つノウハウ・失敗・成功を、コミュニティの共有資産として蓄積。次の挑戦者へ、バトンを渡す。</p>
          <div class="v-tag">#knowledge</div>
        </article>
        <article class="v-card v-card-yellow">
          <div class="v-card-top">
            <span class="v-num">02</span>
            <span class="v-dot">●</span>
          </div>
          <h3>越境する協働</h3>
          <p>地域の壁を越え、同じ課題を持つ隊員同士がプロジェクトを立ち上げる。自分の地域だけじゃ解けない問いに、みんなで挑む。</p>
          <div class="v-tag">#collaboration</div>
        </article>
        <article class="v-card v-card-blue">
          <div class="v-card-top">
            <span class="v-num">03</span>
            <span class="v-dot">●</span>
          </div>
          <h3>持続する仕組み</h3>
          <p>DAOの仕組みを使い、特定の誰かに依存しない運営を。誰かが抜けても、コミュニティは動き続ける。</p>
          <div class="v-tag">#sustainable</div>
        </article>
      </div>
    </section>

    <!-- CTA -->
    <section id="join" class="cta">
      <div class="cta-marquee">
        <span>JOIN // 参加する // JOIN // 参加する // JOIN // 参加する // JOIN // 参加する //</span>
      </div>
      <div class="cta-inner">
        <span class="section-num">[03]</span>
        <h2 class="cta-h2">
          あなたの地域の物語を、<br />
          <span class="hl-underline">ここから</span> 始めよう。
        </h2>
        <p class="cta-sub">登録無料。いつでも離脱OK。気軽にどうぞ。</p>
        <a href="#" class="btn-cta">
          <span>コミュニティに参加する</span>
          <span class="btn-cta-arrow">→</span>
        </a>
        <div class="cta-meta">
          <span>運営 / OPERATED_BY</span>
          <strong>株式会社あるやうむ</strong>
        </div>
      </div>
    </section>

    <a href="/" class="back-link">← デザイン一覧に戻る</a>
  </div>
</Base>

<style>
  .brut {
    font-family: 'BIZ UDGothic', 'Noto Sans JP', sans-serif;
    color: #000;
    background: #faf8f0;
    min-height: 100vh;
    font-weight: 700;
  }

  /* ============ NAV ============ */
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 32px;
    border-bottom: 4px solid #000;
    background: #faf8f0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Inter', monospace;
    font-weight: 900;
  }

  .logo-mark {
    background: #FF4500;
    color: #faf8f0;
    padding: 4px 6px;
    font-family: monospace;
  }

  .logo-text {
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .nav-links {
    display: flex;
    gap: 20px;
    font-family: 'Inter', monospace;
    font-size: 0.8rem;
  }

  .nav-links a {
    padding: 6px 10px;
    border: 2px solid transparent;
    transition: all 0.1s;
  }

  .nav-links a:hover {
    border-color: #000;
    background: #FFEE00;
  }

  .nav-cta {
    background: #000;
    color: #faf8f0;
    border: 2px solid #000 !important;
  }

  .nav-cta:hover {
    background: #FFEE00 !important;
    color: #000 !important;
  }

  /* ============ HERO ============ */
  .hero {
    position: relative;
    padding: 0 0 80px;
    overflow: hidden;
  }

  .hero-ticker {
    display: flex;
    gap: 40px;
    padding: 10px 32px;
    background: #000;
    color: #FFEE00;
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    white-space: nowrap;
    overflow: hidden;
    border-bottom: 4px solid #000;
  }

  .hero-grid {
    padding: 60px 32px 40px;
    max-width: 1200px;
    position: relative;
    z-index: 2;
  }

  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 8px 14px;
    background: #FFEE00;
    border: 3px solid #000;
    box-shadow: 6px 6px 0 #000;
    font-family: monospace;
    font-size: 0.8rem;
    margin-bottom: 40px;
    transform: rotate(-1deg);
  }

  .tag-num {
    background: #000;
    color: #FFEE00;
    padding: 2px 6px;
  }

  .hero-title {
    font-size: clamp(3rem, 9vw, 8rem);
    line-height: 0.95;
    font-weight: 900;
    letter-spacing: -0.03em;
    margin-bottom: 40px;
  }

  .title-line-1 {
    display: block;
  }

  .title-line-2 {
    display: inline-block;
    background: #FF4500;
    color: #faf8f0;
    padding: 0 16px;
    transform: translateX(40px) rotate(-1deg);
    box-shadow: 10px 10px 0 #000;
    border: 4px solid #000;
  }

  .title-slash {
    color: #FFEE00;
  }

  .hero-block {
    max-width: 520px;
    padding: 20px 24px;
    background: #faf8f0;
    border: 4px solid #000;
    box-shadow: 8px 8px 0 #000;
    margin-bottom: 40px;
  }

  .hero-desc {
    font-size: 1.05rem;
    line-height: 1.9;
    font-weight: 500;
  }

  .mark {
    background: #FFEE00;
    padding: 2px 8px;
    border: 2px solid #000;
    font-weight: 900;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .btn-primary {
    padding: 18px 28px;
    background: #000;
    color: #FFEE00;
    border: 4px solid #000;
    font-family: monospace;
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.05em;
    box-shadow: 8px 8px 0 #FF4500;
    transition: all 0.1s;
  }

  .btn-primary:hover {
    transform: translate(4px, 4px);
    box-shadow: 4px 4px 0 #FF4500;
  }

  .btn-ghost {
    padding: 18px 28px;
    background: transparent;
    color: #000;
    border: 4px solid #000;
    font-family: monospace;
    font-weight: 700;
    font-size: 1rem;
    transition: all 0.1s;
  }

  .btn-ghost:hover {
    background: #000;
    color: #faf8f0;
  }

  .hero-sticker {
    position: absolute;
    font-family: 'Inter', monospace;
    font-weight: 900;
    text-align: center;
    line-height: 1;
    letter-spacing: -0.02em;
    pointer-events: none;
  }

  .sticker-1 {
    top: 120px;
    right: 6%;
    font-size: 2rem;
    color: #0044FF;
    padding: 16px 18px;
    border: 4px solid #000;
    background: #faf8f0;
    transform: rotate(8deg);
    box-shadow: 6px 6px 0 #000;
  }

  .sticker-2 {
    bottom: 60px;
    right: 12%;
    font-size: 1.4rem;
    color: #faf8f0;
    padding: 12px 16px;
    background: #FF4500;
    border: 3px solid #000;
    transform: rotate(-6deg);
  }

  /* ============ ABOUT ============ */
  .about {
    padding: 100px 32px;
    border-top: 6px solid #000;
    border-bottom: 6px solid #000;
    background: repeating-linear-gradient(
      45deg,
      #faf8f0,
      #faf8f0 10px,
      #f0ede0 10px,
      #f0ede0 11px
    );
  }

  .section-head {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: monospace;
    font-size: 0.85rem;
    margin-bottom: 48px;
    font-weight: 700;
  }

  .section-num {
    background: #000;
    color: #FFEE00;
    padding: 4px 10px;
  }

  .inv {
    background: #FFEE00;
    color: #000;
  }

  .section-label {
    letter-spacing: 0.05em;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 60px;
    align-items: start;
    max-width: 1200px;
    margin: 0 auto 60px;
  }

  .about-h2 {
    font-size: clamp(2rem, 5vw, 3.8rem);
    line-height: 1.1;
    font-weight: 900;
    letter-spacing: -0.02em;
  }

  .hl-yellow {
    background: #FFEE00;
    padding: 0 10px;
    border: 3px solid #000;
    display: inline-block;
  }

  .about-text {
    padding: 28px;
    background: #faf8f0;
    border: 4px solid #000;
    box-shadow: 8px 8px 0 #0044FF;
  }

  .about-text p {
    font-size: 0.95rem;
    line-height: 2;
    font-weight: 500;
    margin-bottom: 16px;
  }

  .about-text p:last-child {
    margin-bottom: 0;
    font-family: monospace;
    font-size: 1rem;
    padding-top: 16px;
    border-top: 2px dashed #000;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    border: 4px solid #000;
  }

  .stat-card {
    padding: 40px 28px;
    background: #faf8f0;
    border-right: 4px solid #000;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .stat-card:last-child {
    border-right: none;
  }

  .stat-card-alt {
    background: #FFEE00;
  }

  .stat-card-blue {
    background: #0044FF;
    color: #faf8f0;
  }

  .stat-num {
    font-family: 'Inter', sans-serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .stat-label {
    font-family: monospace;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    font-weight: 700;
  }

  /* ============ VISION ============ */
  .vision {
    padding: 100px 32px;
    background: #000;
    color: #faf8f0;
    position: relative;
  }

  .vision-head {
    display: flex;
    align-items: center;
    gap: 16px;
    font-family: monospace;
    font-size: 0.85rem;
    margin-bottom: 40px;
  }

  .vision-head .section-label {
    color: #faf8f0;
  }

  .vision-h2 {
    font-size: clamp(2rem, 5.5vw, 4.2rem);
    line-height: 1.1;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 64px;
    max-width: 1100px;
  }

  .hl-vermi {
    background: #FF4500;
    color: #faf8f0;
    padding: 0 10px;
    transform: skew(-4deg);
    display: inline-block;
  }

  .vision-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 1200px;
  }

  .v-card {
    background: #faf8f0;
    color: #000;
    border: 4px solid #000;
    padding: 28px;
    box-shadow: 10px 10px 0 #FF4500;
    transition: all 0.15s;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .v-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 14px 14px 0 #FF4500;
  }

  .v-card-yellow {
    background: #FFEE00;
    box-shadow: 10px 10px 0 #0044FF;
  }

  .v-card-yellow:hover {
    box-shadow: 14px 14px 0 #0044FF;
  }

  .v-card-blue {
    background: #0044FF;
    color: #faf8f0;
    box-shadow: 10px 10px 0 #FFEE00;
  }

  .v-card-blue:hover {
    box-shadow: 14px 14px 0 #FFEE00;
  }

  .v-card-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: monospace;
    border-bottom: 2px solid currentColor;
    padding-bottom: 10px;
  }

  .v-num {
    font-size: 1.4rem;
    font-weight: 900;
  }

  .v-dot {
    font-size: 1rem;
  }

  .v-card h3 {
    font-size: 1.4rem;
    font-weight: 900;
    line-height: 1.3;
  }

  .v-card p {
    font-size: 0.9rem;
    line-height: 1.9;
    font-weight: 500;
  }

  .v-tag {
    font-family: monospace;
    font-size: 0.8rem;
    margin-top: auto;
    padding-top: 8px;
    opacity: 0.7;
  }

  /* ============ CTA ============ */
  .cta {
    background: #FFEE00;
    border-top: 6px solid #000;
    position: relative;
    overflow: hidden;
  }

  .cta-marquee {
    background: #000;
    color: #FFEE00;
    padding: 14px 0;
    overflow: hidden;
    white-space: nowrap;
    font-family: monospace;
    font-size: 1.1rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    border-bottom: 4px solid #000;
  }

  .cta-marquee span {
    display: inline-block;
    animation: marquee 20s linear infinite;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .cta-inner {
    padding: 100px 32px;
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-inner .section-num {
    display: inline-block;
    margin-bottom: 24px;
  }

  .cta-h2 {
    font-size: clamp(2rem, 5vw, 3.6rem);
    line-height: 1.2;
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }

  .hl-underline {
    border-bottom: 8px solid #FF4500;
    padding-bottom: 2px;
  }

  .cta-sub {
    font-family: monospace;
    font-size: 0.95rem;
    font-weight: 500;
    margin-bottom: 40px;
  }

  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    padding: 24px 40px;
    background: #000;
    color: #faf8f0;
    border: 4px solid #000;
    font-weight: 900;
    font-size: 1.1rem;
    box-shadow: 10px 10px 0 #FF4500;
    transition: all 0.1s;
  }

  .btn-cta:hover {
    transform: translate(4px, 4px);
    box-shadow: 4px 4px 0 #FF4500;
    background: #FF4500;
  }

  .btn-cta-arrow {
    font-family: monospace;
  }

  .cta-meta {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 3px solid #000;
    display: flex;
    justify-content: center;
    gap: 12px;
    font-family: monospace;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .cta-meta strong {
    font-weight: 900;
  }

  /* ============ BACK LINK ============ */
  .back-link {
    display: block;
    text-align: center;
    padding: 28px;
    font-family: monospace;
    font-size: 0.85rem;
    font-weight: 700;
    background: #000;
    color: #faf8f0;
    transition: all 0.1s;
  }

  .back-link:hover {
    background: #FF4500;
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 768px) {
    .nav {
      flex-direction: column;
      gap: 12px;
      padding: 14px 20px;
    }

    .nav-links {
      gap: 8px;
      font-size: 0.7rem;
    }

    .hero-ticker {
      gap: 20px;
      padding: 8px 20px;
      font-size: 0.7rem;
    }

    .hero-grid {
      padding: 40px 20px 20px;
    }

    .title-line-2 {
      transform: translateX(0) rotate(-1deg);
    }

    .sticker-1 {
      top: auto;
      bottom: -20px;
      right: 4%;
      font-size: 1.2rem;
      padding: 10px 12px;
    }

    .sticker-2 {
      display: none;
    }

    .about {
      padding: 60px 20px;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .stats {
      grid-template-columns: 1fr;
    }

    .stat-card {
      border-right: none;
      border-bottom: 4px solid #000;
    }

    .stat-card:last-child {
      border-bottom: none;
    }

    .vision {
      padding: 60px 20px;
    }

    .vision-cards {
      grid-template-columns: 1fr;
    }

    .cta-inner {
      padding: 60px 20px;
    }

    .btn-cta {
      padding: 18px 24px;
      font-size: 0.95rem;
    }

    .cta-meta {
      flex-direction: column;
      gap: 4px;
    }
  }
</style>
