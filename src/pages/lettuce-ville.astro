---
import Base from '../layouts/Base.astro';

/**
 * === レタスペビレッジ（川上村DAO）LP ===
 * 素材差し替え用データ。frontmatter を書き換えれば差し替え可能。
 */
const community = {
  name: 'レタスペビレッジ',
  nameEn: 'LETTUCE-VILLE',
  village: '川上村',
  prefecture: '長野県',
  operator: '地域おこし協力隊員 つっちー',
  catchcopy: 'レタスから、宇宙まで。<br />日本一の村と、つながる。',
  lead: '長野県川上村のDAOコミュニティ「レタスペビレッジ」。村のイベント・体験・人と出会いながら、関係人口の輪をひろげる場所です。',
  lineUrl: '#',
  discordUrl: '#',
};

const numbers = [
  { value: '100', unit: '+', label: '参加メンバー', note: '2026.04.16時点' },
  { value: '最短', unit: '',  label: '100名突破記録', note: 'コミュニティ内' },
  { value: '1/16', unit: '',  label: 'オプチャ開設日', note: '2025年' },
  { value: '月3', unit: '回', label: 'SNS更新',      note: '月・水・金' },
];

const features = [
  { icon: '💬', title: 'LINEで毎日つながる',     body: 'オープンチャットで村の最新情報・イベント告知を受け取れる。誰でも気軽に参加OK。' },
  { icon: '📸', title: 'SNSで村のリアル',       body: '月・水・金にInstagram / Threadsを更新。日常や旬の風景をお届け。' },
  { icon: '🏕️', title: '現地で体験する',        body: '活動費は全額、村のイベント・体験・宿泊・飲食へ。来るたびに発見がある。' },
  { icon: '🗓️', title: 'イベントを企画する',    body: '川上村に来るイベントをオプチャ内で企画・告知。やりたいを形にできる。' },
  { icon: '🤝', title: '村について考える会議', body: 'ハイブリッド形式で定期開催。村の未来を一緒に考える対話の場。' },
  { icon: '🛸', title: 'コアメンへの一歩',     body: '気が合えばDiscordへ。本気で村を盛り上げる仲間として活動できます。' },
];

// プレスリリース／ニュース（差し替え用プレースホルダー）
const news = [
  {
    date: '2026.04.16',
    tag: 'milestone',
    tagLabel: 'マイルストーン',
    title: 'LINEオープンチャット参加者が100名を突破しました',
    excerpt: '2025年1月の開設から最短記録での100名到達。村内議員・村外大学生・参加者の自主的な認知活動が拡大の原動力に。',
    href: '#',
  },
  {
    date: '2026.03.20',
    tag: 'event',
    tagLabel: 'イベント',
    title: '春のレタス植え付け体験ツアー（仮）の告知',
    excerpt: '高原野菜のシーズン開幕にあわせて、村内農家との連携イベントを企画中。詳細はオプチャでお知らせします。',
    href: '#',
  },
  {
    date: '2026.02.10',
    tag: 'press',
    tagLabel: 'プレスリリース',
    title: '川上村DAO「レタスペビレッジ」始動についての記事掲載（差し替え予定）',
    excerpt: 'メディア掲載・取材実績はここにリンク予定。素材到着後に差し替えます。',
    href: '#',
  },
];

const steps = [
  { n: '01', title: 'LINEオープンチャットに参加', body: 'まずは入口へ。匿名OK・退出自由なので、気負わず覗いてみてください。' },
  { n: '02', title: '川上村の情報・イベントを知る', body: '村のリアルタイムな情報や現地イベント、体験プログラムをキャッチ。気になるものに参加してみる。' },
  { n: '03', title: '気が合ったらDiscordへ',       body: '「もっと深く関わりたい」と思ったら、コアメンとしてDiscordへ。村を盛り上げる活動が始まります。' },
];

const faqs = [
  { q: '川上村に住んでいなくても参加できますか？', a: 'もちろんです。むしろ「村外から関わる人」を増やしたくて運営しています。住んでいなくても、行ったことがなくても歓迎です。' },
  { q: '参加に費用はかかりますか？',               a: 'LINEオープンチャット・Discordの利用は無料です。現地イベント参加時の交通費・宿泊費・飲食費等は自己負担となります。' },
  { q: '「DAO」って難しそう。Web3の知識は必要？',  a: '一切不要です。「みんなで自律的に村を盛り上げるコミュニティ」くらいの気持ちでOK。' },
  { q: '顔出し・本名は必要ですか？',               a: '不要です。ニックネーム・匿名で参加可能。慣れてきたらご自身のタイミングでオープンに。' },
  { q: '退出したくなったらどうすれば？',           a: 'いつでも自由に退出できます。引き止めや確認は一切ありません。' },
  { q: '運営は誰ですか？',                         a: '川上村の地域おこし協力隊員「つっちー」が運営。村役場・村内外メンバーと連携して運営しています。' },
];
---

<Base
  title={`${community.name} — ${community.prefecture}${community.village}DAO`}
  description={`${community.prefecture}${community.village}のDAOコミュニティ「${community.name}」。レタス生産量日本一・宇宙飛行士を輩出した村で、関係人口を増やす仲間を募集中。`}
>
  <div class="page">
    <!-- Nav -->
    <nav class="nav">
      <a href="#hero" class="nav-logo">
        <span class="nav-mark">🥬</span>
        <span class="nav-text">{community.name}</span>
      </a>
      <div class="nav-links">
        <a href="#about">川上村とは</a>
        <a href="#features">できること</a>
        <a href="#news">ニュース</a>
        <a href="#steps">参加の流れ</a>
        <a href="#faq">FAQ</a>
        <a href={community.lineUrl} class="nav-cta">LINEで参加</a>
      </div>
    </nav>

    <!-- Hero -->
    <section id="hero" class="hero">
      <div class="hero-blob hero-blob-1" aria-hidden="true"></div>
      <div class="hero-blob hero-blob-2" aria-hidden="true"></div>
      <div class="hero-emoji hero-emoji-1" aria-hidden="true">🥬</div>
      <div class="hero-emoji hero-emoji-2" aria-hidden="true">🚀</div>
      <div class="hero-emoji hero-emoji-3" aria-hidden="true">⭐</div>

      <div class="hero-inner">
        <span class="hero-badge">
          <span class="hero-badge-dot"></span>
          川上村DAO・参加者100名突破
        </span>
        <h1 class="hero-title" set:html={community.catchcopy}></h1>
        <p class="hero-lead">{community.lead}</p>
        <div class="hero-actions">
          <a href={community.lineUrl} class="btn btn-primary btn-lg">
            <span>LINEオープンチャットに参加する</span>
            <span class="btn-arrow">→</span>
          </a>
          <a href="#about" class="btn btn-ghost">まずは村のことを知る</a>
        </div>
        <p class="hero-note">登録無料／いつでも退出OK／顔出し不要</p>
      </div>
    </section>

    <!-- About: 2軸コンセプト -->
    <section id="about" class="about">
      <header class="section-head">
        <span class="section-num">01</span>
        <span class="section-tag">ABOUT KAWAKAMI</span>
      </header>
      <h2 class="section-title">
        川上村って、<br class="br-sm" />こんな村。
      </h2>
      <p class="section-lead">
        標高1,100mの高原に広がる、長野県南佐久郡の小さな村。<br />
        「食」と「宇宙」、ふたつの強烈なアイデンティティがあります。
      </p>

      <div class="about-grid">
        <article class="concept concept-lettuce">
          <div class="concept-emoji">🥬</div>
          <h3>レタス生産量、<br />日本一の村。</h3>
          <p>夏秋レタスの生産量で日本一。標高の高さと冷涼な気候、火山灰土壌が、シャキッと美味しいレタスを育てます。</p>
          <ul>
            <li><span>●</span>夏秋レタスの一大産地</li>
            <li><span>●</span>若手就農者が全国から集まる</li>
            <li><span>●</span>農業 × デジタルの可能性</li>
          </ul>
        </article>

        <article class="concept concept-cosmos">
          <div class="concept-emoji">🚀</div>
          <h3>宇宙飛行士を、<br />輩出した村。</h3>
          <p>標高1,100m、空に近い村。日本人宇宙飛行士・油井亀美也さんの故郷。村の子どもたちは「宇宙に近い」感覚と共に育ちます。</p>
          <ul>
            <li><span>★</span>日本トップクラスの星空</li>
            <li><span>★</span>クライミングの聖地・小川山</li>
            <li><span>★</span>宇宙への憧れが文化に</li>
          </ul>
        </article>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="features">
      <header class="section-head">
        <span class="section-num">02</span>
        <span class="section-tag">WHAT WE DO</span>
      </header>
      <h2 class="section-title">
        レタスペビレッジで、<br class="br-sm" />できること。
      </h2>
      <p class="section-lead">
        オンラインで気軽に。リアルでがっつり。<br />
        自分のペースで、川上村と関わりを持てます。
      </p>

      <div class="features-grid">
        {features.map((f) => (
          <div class="feature">
            <div class="feature-icon">{f.icon}</div>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Stats -->
    <section id="stats" class="stats">
      <header class="section-head light">
        <span class="section-num">03</span>
        <span class="section-tag">BY THE NUMBERS</span>
      </header>
      <h2 class="section-title light">
        数字で見る、<br class="br-sm" />レタスペビレッジ。
      </h2>

      <div class="stats-grid">
        {numbers.map((n) => (
          <div class="stat">
            <p class="stat-value">{n.value}<span class="stat-unit">{n.unit}</span></p>
            <p class="stat-label">{n.label}</p>
            <p class="stat-note">{n.note}</p>
          </div>
        ))}
      </div>

      <p class="stats-foot">
        村内議員・村外大学生・参加者が、自主的に認知活動を展開中。<br />
        コミュニティの広がり方も「自律分散型」です。
      </p>
    </section>

    <!-- News / Press Release -->
    <section id="news" class="news">
      <header class="section-head">
        <span class="section-num">04</span>
        <span class="section-tag">NEWS &amp; PRESS</span>
      </header>
      <div class="news-top">
        <h2 class="section-title">
          ニュース・<br class="br-sm" />プレスリリース。
        </h2>
        <a href="#" class="news-all">すべて見る →</a>
      </div>

      <ul class="news-list">
        {news.map((n) => (
          <li class="news-item">
            <a href={n.href} class="news-link">
              <div class="news-meta">
                <time class="news-date">{n.date}</time>
                <span class={`news-tag news-tag-${n.tag}`}>{n.tagLabel}</span>
              </div>
              <h3 class="news-title">{n.title}</h3>
              <p class="news-excerpt">{n.excerpt}</p>
              <span class="news-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </section>

    <!-- Steps -->
    <section id="steps" class="steps">
      <header class="section-head">
        <span class="section-num">05</span>
        <span class="section-tag">HOW TO JOIN</span>
      </header>
      <h2 class="section-title">参加の流れは、3ステップ。</h2>

      <ol class="steps-list">
        {steps.map((s) => (
          <li class="step">
            <div class="step-num">{s.n}</div>
            <div class="step-body">
              <h3>{s.title}</h3>
              <p>{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- FAQ -->
    <section id="faq" class="faq">
      <header class="section-head">
        <span class="section-num">06</span>
        <span class="section-tag">FAQ</span>
      </header>
      <h2 class="section-title">よくある質問</h2>

      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>
              <span>{f.q}</span>
              <span class="faq-icon" aria-hidden="true">＋</span>
            </summary>
            <div class="faq-body">{f.a}</div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section id="cta" class="cta">
      <div class="cta-emoji cta-emoji-1" aria-hidden="true">🥬</div>
      <div class="cta-emoji cta-emoji-2" aria-hidden="true">🚀</div>
      <div class="cta-inner">
        <p class="cta-eyebrow">JOIN LETTUCE-VILLE</p>
        <h2>
          日本一の村の<br class="br-sm" />101人目に、<br />
          あなたを待っています。
        </h2>
        <p class="cta-lead">
          「ちょっと興味あるかも」のテンションで大丈夫。<br />
          まずはLINEオープンチャットを覗いてみてください。
        </p>
        <a href={community.lineUrl} class="btn btn-primary btn-xl">
          <span>LINEオープンチャットに参加する</span>
          <span class="btn-arrow">→</span>
        </a>
        <p class="cta-note">登録無料／いつでも退出OK／顔出し不要</p>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <div>
          <p class="footer-name">
            <span class="nav-mark">🥬</span> {community.name}
          </p>
          <p class="footer-note">{community.prefecture}{community.village}DAOコミュニティ／運営：{community.operator}</p>
        </div>
        <div class="footer-meta">
          <p>{community.prefecture}南佐久郡 {community.village}</p>
          <p>© 2026 Lettuce-Ville Community</p>
        </div>
      </div>
    </footer>

    <!-- Mobile sticky CTA -->
    <a href={community.lineUrl} class="sticky-cta">LINEで参加する →</a>
  </div>
</Base>

<style>
  /* ============ Tokens ============ */
  .page {
    --lettuce-50:  #f1faec;
    --lettuce-100: #dff3d2;
    --lettuce-300: #9bd175;
    --lettuce-500: #4ea83a;
    --lettuce-600: #3d8a2c;
    --lettuce-700: #2f6d22;
    --lettuce-900: #163810;

    --cosmos-500: #3b3f8a;
    --cosmos-700: #262a63;
    --cosmos-900: #0f1238;

    --cream:   #fbf7ee;
    --paper:   #ffffff;
    --line:    #d9e7cf;
    --ink:     #163810;
    --ink-soft:#3d5630;
    --ink-mute:#75897a;
    --gold:    #f5c14a;

    color: var(--ink);
    background: var(--cream);
    font-family: 'Noto Sans JP', sans-serif;
    min-height: 100vh;
  }

  /* ============ Buttons ============ */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 28px;
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: 999px;
    border: 2px solid var(--lettuce-900);
    transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s, color 0.2s;
  }
  .btn-primary {
    background: var(--lettuce-500);
    color: #fff;
    box-shadow: 5px 5px 0 var(--lettuce-900);
  }
  .btn-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 8px 8px 0 var(--lettuce-900);
  }
  .btn-ghost {
    background: var(--cream);
    color: var(--ink);
  }
  .btn-ghost:hover { background: var(--lettuce-100); }
  .btn-lg  { padding: 18px 34px; font-size: 1rem; }
  .btn-xl  { padding: 22px 44px; font-size: 1.1rem; box-shadow: 7px 7px 0 var(--lettuce-900); }
  .btn-xl:hover { box-shadow: 10px 10px 0 var(--lettuce-900); }
  .btn-arrow { font-family: 'Inter', sans-serif; }

  /* ============ Nav ============ */
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 32px;
    background: rgba(251, 247, 238, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 2px solid var(--lettuce-100);
  }
  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 900;
    color: var(--lettuce-900);
  }
  .nav-mark {
    display: inline-flex;
    width: 32px;
    height: 32px;
    align-items: center;
    justify-content: center;
    background: radial-gradient(circle at 35% 35%, var(--lettuce-300) 0%, var(--lettuce-500) 55%, var(--lettuce-700) 100%);
    border-radius: 50%;
    font-size: 1.1rem;
    box-shadow: 3px 3px 0 var(--lettuce-900);
  }
  .nav-text { letter-spacing: 0.05em; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--ink-soft);
  }
  .nav-links a:hover { color: var(--lettuce-500); }
  .nav-cta {
    padding: 8px 18px;
    background: var(--lettuce-500);
    color: #fff !important;
    border-radius: 999px;
    box-shadow: 3px 3px 0 var(--lettuce-900);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .nav-cta:hover {
    transform: translate(-1px, -1px);
    box-shadow: 5px 5px 0 var(--lettuce-900);
  }

  /* ============ Hero ============ */
  .hero {
    position: relative;
    padding: 140px 32px 120px;
    background:
      radial-gradient(circle at 18% 30%, rgba(78, 168, 58, 0.18) 0, transparent 22%),
      radial-gradient(circle at 82% 60%, rgba(78, 168, 58, 0.14) 0, transparent 22%),
      var(--cream);
    overflow: hidden;
  }
  .hero-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    opacity: 0.4;
  }
  .hero-blob-1 {
    width: 360px; height: 360px;
    background: var(--lettuce-300);
    top: -100px; left: -120px;
  }
  .hero-blob-2 {
    width: 280px; height: 280px;
    background: var(--cosmos-500);
    bottom: -80px; right: -100px;
    opacity: 0.25;
  }
  .hero-emoji {
    position: absolute;
    pointer-events: none;
    user-select: none;
    line-height: 1;
    animation: float-y 5s ease-in-out infinite;
  }
  .hero-emoji-1 { top: 130px; right: 8%; font-size: 5.5rem; }
  .hero-emoji-2 { bottom: 80px; left: 6%; font-size: 4.5rem; animation-delay: 1s; }
  .hero-emoji-3 { top: 45%; left: 55%; font-size: 2rem; animation-delay: 2s; }
  @keyframes float-y {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-12px); }
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px;
    background: #fff;
    border: 2px solid var(--lettuce-900);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--lettuce-900);
    box-shadow: 4px 4px 0 var(--lettuce-900);
    margin-bottom: 28px;
  }
  .hero-badge-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--lettuce-500);
    animation: pulse 1.5s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.6; }
  }

  .hero-title {
    font-family: 'Noto Serif JP', serif;
    font-size: clamp(2.4rem, 6vw, 4.6rem);
    font-weight: 900;
    line-height: 1.3;
    color: var(--lettuce-900);
    margin-bottom: 24px;
  }
  .hero-lead {
    font-size: 1rem;
    line-height: 2;
    color: var(--ink-soft);
    max-width: 620px;
    margin: 0 auto 36px;
  }
  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }
  .hero-note {
    margin-top: 24px;
    font-size: 0.78rem;
    color: var(--ink-mute);
  }

  /* ============ Section common ============ */
  .section-head {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ink-mute);
  }
  .section-head .section-num {
    padding: 4px 10px;
    background: var(--lettuce-900);
    color: var(--cream);
    border-radius: 4px;
  }
  .section-head.light { color: rgba(251,247,238,0.7); }
