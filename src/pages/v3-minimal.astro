---
import Base from '../layouts/Base.astro';
---

<Base title="ミニマル白 — 地域おこし協力隊DAO">
  <div class="minimal">
    <!-- Nav -->
    <nav class="nav">
      <span class="nav-name">地域おこし協力隊DAO</span>
      <div class="nav-right">
        <a href="#about">About</a>
        <a href="#how">How</a>
        <a href="#join" class="nav-join">Join</a>
      </div>
    </nav>

    <!-- Hero -->
    <section class="hero">
      <div class="hero-center">
        <p class="hero-eyebrow">A Decentralized Community for Regional Revitalization</p>
        <h1>地域を、<br />自分ごとにする。</h1>
      </div>
      <div class="hero-footer">
        <span>by 株式会社あるやうむ</span>
        <span>Est. 2024</span>
      </div>
    </section>

    <!-- Statement -->
    <section class="statement">
      <div class="statement-inner">
        <p>
          地域おこし協力隊員は、全国に約7,200人。<br />
          それぞれの地域で、それぞれの課題と向き合っている。<br /><br />
          でも、一人じゃない。<br />
          同じ志を持つ仲間が、全国にいる。
        </p>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="about">
      <div class="about-row">
        <div class="about-left">
          <span class="label">What we do</span>
        </div>
        <div class="about-right">
          <h2>つながる。学ぶ。動く。</h2>
          <p>地域おこし協力隊DAOは、Web3の仕組みを活用した分散型コミュニティ。特定のリーダーに依存しない、全員が主役の組織です。</p>
        </div>
      </div>
    </section>

    <!-- How -->
    <section id="how" class="how">
      <div class="how-header">
        <span class="label">How it works</span>
        <h2>3つの仕組み</h2>
      </div>
      <div class="how-items">
        <div class="how-item">
          <div class="how-num">1</div>
          <div class="how-content">
            <h3>コミュニティに参加する</h3>
            <p>現役隊員、OB/OG、地域に関わりたい誰でも参加可能。まずはDiscordへ。</p>
          </div>
        </div>
        <div class="how-item">
          <div class="how-num">2</div>
          <div class="how-content">
            <h3>知恵を共有する</h3>
            <p>活動報告、ノウハウ、失敗談。あなたの経験が、誰かの助けになる。</p>
          </div>
        </div>
        <div class="how-item">
          <div class="how-num">3</div>
          <div class="how-content">
            <h3>プロジェクトを立ち上げる</h3>
            <p>共通の課題を見つけたら、地域横断でプロジェクトを提案。DAOで意思決定。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Numbers -->
    <section class="numbers">
      <div class="numbers-grid">
        <div class="number-item">
          <span class="number-big">47</span>
          <span class="number-label">都道府県をカバー</span>
        </div>
        <div class="number-item">
          <span class="number-big">DAO</span>
          <span class="number-label">分散型自律組織</span>
        </div>
        <div class="number-item">
          <span class="number-big">Web3</span>
          <span class="number-label">次世代の仕組み</span>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="join" class="cta">
      <h2>始めよう。</h2>
      <p>あなたの「地域を変えたい」という気持ちが、最初の一歩。</p>
      <a href="#" class="cta-btn">参加する</a>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <span>地域おこし協力隊DAO</span>
        <span>運営: 株式会社あるやうむ</span>
      </div>
    </footer>

    <a href="/" class="back-link">← デザイン一覧に戻る</a>
  </div>
</Base>

<style>
  .minimal {
    font-family: 'Noto Sans JP', sans-serif;
    color: #111;
    background: #fff;
  }

  .label {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #aaa;
  }

  /* Nav */
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 64px;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid #f0f0f0;
  }

  .nav-name {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.03em;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 32px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
  }

  .nav-right a {
    color: #888;
    transition: color 0.2s;
  }

  .nav-right a:hover {
    color: #111;
  }

  .nav-join {
    color: #111 !important;
    font-weight: 600;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 0 64px;
    position: relative;
  }

  .hero-eyebrow {
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: #bbb;
    margin-bottom: 40px;
  }

  .hero h1 {
    font-size: clamp(3rem, 8vw, 7rem);
    font-weight: 900;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .hero-footer {
    position: absolute;
    bottom: 48px;
    left: 64px;
    right: 64px;
    display: flex;
    justify-content: space-between;
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    color: #ccc;
    letter-spacing: 0.1em;
  }

  /* Statement */
  .statement {
    padding: 160px 64px;
    border-top: 1px solid #f0f0f0;
  }

  .statement-inner {
    max-width: 560px;
    margin: 0 auto;
  }

  .statement p {
    font-size: 1.1rem;
    line-height: 2.4;
    font-weight: 300;
    color: #444;
    text-align: center;
  }

  /* About */
  .about {
    padding: 120px 64px;
    border-top: 1px solid #f0f0f0;
  }

  .about-row {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 80px;
    max-width: 900px;
  }

  .about-left {
    padding-top: 8px;
  }

  .about-right h2 {
    font-size: 2rem;
    font-weight: 900;
    margin-bottom: 24px;
    letter-spacing: -0.01em;
  }

  .about-right p {
    font-size: 0.95rem;
    line-height: 2.2;
    color: #666;
    font-weight: 300;
    max-width: 480px;
  }

  /* How */
  .how {
    padding: 120px 64px;
    border-top: 1px solid #f0f0f0;
  }

  .how-header {
    margin-bottom: 80px;
  }

  .how-header h2 {
    font-size: 1.5rem;
    font-weight: 900;
    margin-top: 12px;
  }

  .how-items {
    display: flex;
    flex-direction: column;
    max-width: 700px;
  }

  .how-item {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 32px;
    padding: 40px 0;
    border-top: 1px solid #eee;
  }

  .how-num {
    font-family: 'Inter', sans-serif;
    font-size: 2.5rem;
    font-weight: 200;
    color: #ddd;
    line-height: 1;
  }

  .how-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 8px;
  }

  .how-content p {
    font-size: 0.85rem;
    line-height: 1.9;
    color: #888;
    font-weight: 300;
  }

  /* Numbers */
  .numbers {
    padding: 100px 64px;
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
  }

  .numbers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    text-align: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .number-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .number-big {
    font-family: 'Inter', sans-serif;
    font-size: 3rem;
    font-weight: 200;
    letter-spacing: -0.02em;
  }

  .number-label {
    font-size: 0.75rem;
    color: #bbb;
  }

  /* CTA */
  .cta {
    padding: 200px 64px;
    text-align: center;
  }

  .cta h2 {
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    margin-bottom: 20px;
  }

  .cta p {
    font-size: 0.9rem;
    color: #888;
    font-weight: 300;
    margin-bottom: 48px;
  }

  .cta-btn {
    display: inline-block;
    padding: 16px 64px;
    background: #111;
    color: #fff;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    transition: transform 0.3s, opacity 0.3s;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    opacity: 0.85;
  }

  /* Footer */
  .footer {
    border-top: 1px solid #f0f0f0;
    padding: 32px 64px;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    font-size: 0.7rem;
    color: #ccc;
    font-family: 'Inter', sans-serif;
  }

  .back-link {
    display: block;
    text-align: center;
    padding: 32px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #ccc;
    transition: color 0.3s;
  }

  .back-link:hover {
    color: #111;
  }

  @media (max-width: 768px) {
    .nav { padding: 16px 24px; }
    .hero { padding: 0 24px; }
    .hero-footer { left: 24px; right: 24px; }
    .statement { padding: 80px 24px; }
    .about { padding: 80px 24px; }
    .about-row { grid-template-columns: 1fr; gap: 24px; }
    .how { padding: 80px 24px; }
    .numbers { padding: 60px 24px; }
    .numbers-grid { grid-template-columns: 1fr; gap: 40px; }
    .cta { padding: 120px 24px; }
    .footer { padding: 24px; }
  }
</style>
